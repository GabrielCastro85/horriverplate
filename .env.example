# App
NODE_ENV=development
PORT=3000
SITE_URL=http://localhost:3000
ASSET_VERSION=local-dev

# Database
DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/YOUR_DB_NAME
LOCAL_DATABASE_URL=postgresql://YOUR_LOCAL_DB_USER:YOUR_LOCAL_DB_PASSWORD@YOUR_LOCAL_DB_HOST:5432/YOUR_LOCAL_DB_NAME

# Admin seed / auth
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
JWT_SECRET=CHANGE_ME_JWT_SECRET

# PDF / browser rendering
PUPPETEER_EXECUTABLE_PATH=C:/path/to/chrome.exe
CHROME_PATH=C:/path/to/chrome.exe

# Import scripts
EXCEL_FILE=imports/your-file.xlsx
CSV_FILE=imports/your-file.csv
