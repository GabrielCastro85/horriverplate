<%
  const fmtDateTimeBR = (d) =>
    d ? new Date(d).toLocaleString("pt-BR", { timeZone: "America/Sao_Paulo", hour12: false }) : "-";
  const sessionClosed = !!(
    session &&
    session.expiresAt &&
    new Date(session.expiresAt).getTime() <= Date.now()
  );
  const integritySummary = voteIntegritySummary || {
    totalBallots: ballots ? ballots.length : 0,
    validBallots: ballots ? ballots.length : 0,
    invalidBallots: 0,
    invalidByCode: {},
  };
%>

<section class="space-y-6 animate-fadeIn">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h1 class="text-xl md:text-2xl font-semibold text-horriver-light">
        Votos da pelada
      </h1>
      <p class="text-xs md:text-sm text-horriver-gray mt-1">
        <span class="text-horriver-orange">
          <%= new Date(match.playedAt).toLocaleDateString("pt-BR", { timeZone: "America/Sao_Paulo" }) %>
        </span>
        <% if (match.description) { %> - <%= match.description %> <% } %>
      </p>
      <% if (session) { %>
        <p class="text-[11px] text-horriver-gray/80">
          Sessao criada em <%= fmtDateTimeBR(session.createdAt) %>
          <% if (session.expiresAt) { %>
            - expira em <%= fmtDateTimeBR(session.expiresAt) %>
          <% } else { %>
            - sem expiracao
          <% } %>
        </p>
        <span class="status-chip <%= sessionClosed ? 'status-danger' : 'status-info' %>">
          <%= sessionClosed ? "Votacao encerrada" : "Votacao ativa" %>
        </span>
      <% } else { %>
        <span class="status-chip status-danger">Nenhuma sessao de votacao encontrada</span>
      <% } %>
    </div>
    <a
      href="/admin/matches/<%= match.id %>"
      class="w-full sm:w-auto text-center px-3 py-2 rounded-full border border-horriver-orange text-[11px] md:text-xs text-horriver-orange hover:bg-horriver-orange hover:text-horriver-bg transition"
    >
      Voltar
    </a>
  </div>

  <% if (voteDeleted) { %>
    <div class="rounded-2xl border border-emerald-500/40 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-200">
      Voto excluido com sucesso. O link desse jogador foi liberado para votar novamente.
    </div>
  <% } %>

  <% if (voteValidated) { %>
    <div class="rounded-2xl border border-emerald-500/40 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-200">
      Voto validado manualmente com sucesso. Ele voltou para a apuracao final.
    </div>
  <% } %>

  <% if (voteDeleteError === "notFound") { %>
    <div class="rounded-2xl border border-red-500/40 bg-red-500/10 px-4 py-3 text-sm text-red-200">
      Nao foi possivel localizar esse voto para exclusao.
    </div>
  <% } else if (voteDeleteError === "server") { %>
    <div class="rounded-2xl border border-red-500/40 bg-red-500/10 px-4 py-3 text-sm text-red-200">
      Ocorreu um erro ao excluir o voto. Tente novamente.
    </div>
  <% } %>

  <% if (voteValidateError === "notFound") { %>
    <div class="rounded-2xl border border-red-500/40 bg-red-500/10 px-4 py-3 text-sm text-red-200">
      Nao foi possivel localizar esse voto para validacao manual.
    </div>
  <% } else if (voteValidateError === "alreadyValid") { %>
    <div class="rounded-2xl border border-yellow-500/40 bg-yellow-500/10 px-4 py-3 text-sm text-yellow-100">
      Esse voto ja esta valido na apuracao e nao precisava de liberacao manual.
    </div>
  <% } else if (voteValidateError === "server") { %>
    <div class="rounded-2xl border border-red-500/40 bg-red-500/10 px-4 py-3 text-sm text-red-200">
      Ocorreu um erro ao validar o voto manualmente. Tente novamente.
    </div>
  <% } %>

  <% if (session && ballots.length) { %>
    <div class="grid gap-3 sm:grid-cols-3">
      <div class="rounded-2xl border border-horriver-border bg-black/30 px-4 py-3">
        <p class="text-[11px] uppercase tracking-[0.18em] text-horriver-gray/80">Total de votos</p>
        <p class="mt-2 text-2xl font-semibold text-horriver-light"><%= integritySummary.totalBallots %></p>
        <p class="mt-1 text-xs text-horriver-gray">Ballots registrados nesta sessao.</p>
      </div>
      <div class="rounded-2xl border border-emerald-500/25 bg-emerald-500/8 px-4 py-3">
        <p class="text-[11px] uppercase tracking-[0.18em] text-emerald-200/80">Votos validos</p>
        <p class="mt-2 text-2xl font-semibold text-emerald-100"><%= integritySummary.validBallots %></p>
        <p class="mt-1 text-xs text-emerald-100/70">Considerados normalmente na apuracao.</p>
      </div>
      <div class="rounded-2xl border border-red-500/30 bg-red-500/8 px-4 py-3">
        <p class="text-[11px] uppercase tracking-[0.18em] text-red-200/80">Votos anulados</p>
        <p class="mt-2 text-2xl font-semibold text-red-100"><%= integritySummary.invalidBallots %></p>
        <p class="mt-1 text-xs text-red-100/70">Tirados da apuracao por padrao suspeito.</p>
      </div>
    </div>

    <% if (integritySummary.invalidBallots > 0) { %>
      <div class="rounded-2xl border border-red-500/30 bg-gradient-to-r from-red-500/12 to-red-500/5 px-4 py-4 space-y-3">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <p class="text-sm font-semibold text-red-100">Protecao anti-voto-sabotado ativa</p>
            <p class="mt-1 text-xs text-red-100/75">
              Os votos anulados continuam salvos para auditoria, mas nao entram no calculo final do Craque da Semana.
            </p>
          </div>
          <div class="flex flex-wrap gap-2 text-[11px]">
            <% if (integritySummary.invalidByCode.EXCESSO_NOTA_MINIMA) { %>
              <span class="status-chip status-danger">
                <%= integritySummary.invalidByCode.EXCESSO_NOTA_MINIMA %> por excesso de nota 1
              </span>
            <% } %>
            <% if (integritySummary.invalidByCode.REPETICAO_EXCESSIVA) { %>
              <span class="status-chip status-danger">
                <%= integritySummary.invalidByCode.REPETICAO_EXCESSIVA %> por repeticao de nota 1
              </span>
            <% } %>
          </div>
        </div>
      </div>
    <% } %>
  <% } %>

  <% if (!session || !ballots.length) { %>
    <p class="text-sm text-horriver-gray">
      Nenhum voto registrado para esta pelada.
    </p>
  <% } else { %>
    <div class="space-y-4">
      <% ballots.forEach((b, idx) => { %>
        <%
          const validation = b.voteValidation || {};
          const isInvalid = !!validation.isInvalid;
          const wasValidatedManually = !!validation.wasValidatedManually;
          const cardClass = isInvalid
            ? "bg-red-950/10 border-red-500/35"
            : wasValidatedManually
              ? "bg-emerald-950/10 border-emerald-500/30"
              : "bg-black/40 border-horriver-border";
        %>
        <div class="<%= cardClass %> border rounded-2xl p-4 space-y-3">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 text-[12px]">
            <div class="space-y-1">
              <p class="text-horriver-light font-semibold">
                Voto <%= idx + 1 %> - <%= b.token.player?.name || "Jogador" %>
              </p>
              <% if (b.token.player?.nickname) { %>
                <p class="text-horriver-gray">
                  "<%= b.token.player.nickname %>"
                </p>
              <% } %>
              <p class="text-horriver-gray/80">
                Enviado em <%= fmtDateTimeBR(b.createdAt) %>
              </p>
            </div>
            <div class="flex flex-col gap-2 sm:items-end">
              <span class="status-chip <%= isInvalid ? 'status-danger' : 'status-ok' %>">
                <%= validation.badgeLabel || 'Voto valido' %>
              </span>
              <% if (wasValidatedManually) { %>
                <span class="text-[11px] text-emerald-200/80">
                  liberado manualmente
                  <% if (validation.validatedManuallyAt) { %>
                    em <%= fmtDateTimeBR(validation.validatedManuallyAt) %>
                  <% } %>
                </span>
              <% } %>
              <div class="text-[11px] text-horriver-gray flex flex-col gap-1 sm:text-right sm:items-end">
                <span class="status-chip <%= b.token.usedAt ? 'status-ok' : 'status-pending' %>">
                  <%= b.token.usedAt ? "Token usado" : "Token pendente" %>
                </span>
                <% if (b.token.usedAt) { %>
                  <span>em <%= fmtDateTimeBR(b.token.usedAt) %></span>
                <% } else { %>
                  <span>ainda nao utilizado</span>
                <% } %>
              </div>

              <% if (isInvalid) { %>
                <form
                  action="/admin/matches/<%= match.id %>/votes/<%= b.id %>/validate"
                  method="POST"
                  onsubmit="return confirm('Validar manualmente o voto de <%= (b.token.player?.name || 'este jogador').replace(/'/g, '\\\\\'') %> e recolocar esse voto na apuracao final?');"
                >
                  <button
                    type="submit"
                    class="w-full sm:w-auto px-3 py-2 rounded-full border border-emerald-500/60 text-[11px] font-semibold text-emerald-200 hover:bg-emerald-500 hover:text-white transition"
                  >
                    Validar voto
                  </button>
                </form>
              <% } %>

              <form
                action="/admin/matches/<%= match.id %>/votes/<%= b.id %>/delete"
                method="POST"
                onsubmit="return confirm('Excluir o voto de <%= (b.token.player?.name || 'este jogador').replace(/'/g, '\\\\\'') %> e liberar o link para votar novamente?');"
              >
                <button
                  type="submit"
                  class="w-full sm:w-auto px-3 py-2 rounded-full border border-red-500/60 text-[11px] font-semibold text-red-200 hover:bg-red-500 hover:text-white transition"
                >
                  Excluir voto
                </button>
              </form>
            </div>
          </div>

          <% if (isInvalid) { %>
            <div class="rounded-2xl border border-red-500/30 bg-gradient-to-r from-red-500/10 to-transparent px-4 py-4 space-y-3">
              <div class="flex items-start gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full border border-red-400/35 bg-red-500/15 text-lg font-black text-red-100">
                  !
                </div>
                <div class="space-y-1">
                  <p class="text-sm font-semibold text-red-100"><%= validation.adminTitle || "Padrao suspeito detectado" %></p>
                  <p class="text-xs text-red-100/80">Motivo: <%= validation.invalidReason || "Voto anulado por padrao suspeito" %></p>
                  <p class="text-xs text-red-100/65"><%= validation.playfulLine || "Comissao da resenha acionada." %></p>
                </div>
              </div>

              <div class="grid gap-2 sm:grid-cols-3 text-[11px]">
                <div class="rounded-xl border border-red-500/20 bg-black/20 px-3 py-2">
                  <span class="block uppercase tracking-[0.18em] text-red-100/55">Maior repeticao</span>
                  <strong class="mt-1 block text-sm text-red-100"><%= validation.maxRepeatedPercentage %>%</strong>
                  <span class="mt-1 block text-red-100/65">Nota <%= validation.maxRepeatedRating ?? '-' %></span>
                </div>
                <div class="rounded-xl border border-red-500/20 bg-black/20 px-3 py-2">
                  <span class="block uppercase tracking-[0.18em] text-red-100/55">Nota 1</span>
                  <strong class="mt-1 block text-sm text-red-100"><%= validation.lowRatingPercentage %>%</strong>
                  <span class="mt-1 block text-red-100/65">Nota 1 em <%= validation.lowRatingCount %> de <%= validation.totalRatings %></span>
                </div>
                <div class="rounded-xl border border-red-500/20 bg-black/20 px-3 py-2">
                  <span class="block uppercase tracking-[0.18em] text-red-100/55">Status</span>
                  <strong class="mt-1 block text-sm text-red-100"><%= validation.statusText || "Desconsiderado na apuracao" %></strong>
                  <span class="mt-1 block text-red-100/65">Mantido no admin apenas para auditoria.</span>
                </div>
              </div>
            </div>
          <% } else if (wasValidatedManually) { %>
            <div class="rounded-2xl border border-emerald-500/25 bg-gradient-to-r from-emerald-500/10 to-transparent px-4 py-4 space-y-3">
              <div class="flex items-start gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full border border-emerald-400/35 bg-emerald-500/15 text-lg font-black text-emerald-100">
                  OK
                </div>
                <div class="space-y-1">
                  <p class="text-sm font-semibold text-emerald-100"><%= validation.adminTitle || "Voto liberado pelo admin" %></p>
                  <% if (validation.detectedInvalidReason) { %>
                    <p class="text-xs text-emerald-100/80">Alerta automatico original: <%= validation.detectedInvalidReason %></p>
                  <% } %>
                  <p class="text-xs text-emerald-100/65"><%= validation.playfulLine || "Esse voto voltou para a apuracao por decisao manual." %></p>
                </div>
              </div>

              <div class="grid gap-2 sm:grid-cols-3 text-[11px]">
                <div class="rounded-xl border border-emerald-500/20 bg-black/20 px-3 py-2">
                  <span class="block uppercase tracking-[0.18em] text-emerald-100/55">Maior repeticao</span>
                  <strong class="mt-1 block text-sm text-emerald-100"><%= validation.maxRepeatedPercentage %>%</strong>
                  <span class="mt-1 block text-emerald-100/65">Nota <%= validation.maxRepeatedRating ?? '-' %></span>
                </div>
                <div class="rounded-xl border border-emerald-500/20 bg-black/20 px-3 py-2">
                  <span class="block uppercase tracking-[0.18em] text-emerald-100/55">Nota 1</span>
                  <strong class="mt-1 block text-sm text-emerald-100"><%= validation.lowRatingPercentage %>%</strong>
                  <span class="mt-1 block text-emerald-100/65">Nota 1 em <%= validation.lowRatingCount %> de <%= validation.totalRatings %></span>
                </div>
                <div class="rounded-xl border border-emerald-500/20 bg-black/20 px-3 py-2">
                  <span class="block uppercase tracking-[0.18em] text-emerald-100/55">Status</span>
                  <strong class="mt-1 block text-sm text-emerald-100">Considerado na apuracao</strong>
                  <span class="mt-1 block text-emerald-100/65">Liberado manualmente pelo admin.</span>
                </div>
              </div>
            </div>
          <% } %>

          <div class="border <%= isInvalid ? 'border-red-500/20 bg-black/20' : wasValidatedManually ? 'border-emerald-500/20 bg-black/20' : 'border-horriver-border/60 bg-black/30' %> rounded-xl p-3 text-[12px]">
            <div class="mb-3 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
              <p class="font-semibold <%= isInvalid ? 'text-red-100' : wasValidatedManually ? 'text-emerald-100' : 'text-horriver-orange' %>">
                <%= isInvalid ? "Notas do voto anulado (auditoria)" : wasValidatedManually ? "Notas do voto validado manualmente" : "Notas (1-5)" %>
              </p>
              <span class="text-[11px] text-horriver-gray">
                <%= b.ratings && b.ratings.length ? `${b.ratings.length} nota(s) registradas` : "Sem notas registradas" %>
              </span>
            </div>
            <% if (!b.ratings || !b.ratings.length) { %>
              <p class="text-horriver-gray">Sem notas registradas.</p>
            <% } else { %>
              <ul class="space-y-2">
                <% b.ratings
                  .sort((a, b) => (a.player?.name || "").localeCompare(b.player?.name || ""))
                  .forEach((r) => { %>
                  <li class="grid grid-cols-[minmax(0,1fr),auto] items-center gap-3 rounded-xl border border-white/5 bg-black/15 px-3 py-2">
                    <div class="min-w-0">
                      <span class="block truncate text-horriver-light font-medium">
                        <%= r.player?.name || "Jogador" %>
                      </span>
                      <% if (r.player?.nickname) { %>
                        <span class="block truncate text-horriver-gray text-[11px]">"<%= r.player.nickname %>"</span>
                      <% } %>
                    </div>
                    <span class="<%= r.rating === 1 ? 'border-red-500/30 bg-red-500/10 text-red-100' : 'border-horriver-orange/30 bg-horriver-orange/10 text-horriver-orange' %> min-w-[44px] rounded-full border px-3 py-1 text-center font-semibold">
                      <%= r.rating %>
                    </span>
                  </li>
                <% }) %>
              </ul>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>
