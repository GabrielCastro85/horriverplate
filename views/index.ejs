            <p class="text-sm text-center">Nenhum dado de fotos ainda.</p>
          </div>
        <% } else { %>
          <div class="space-y-0.5">
            <% fotos.forEach((p, idx) => { %>
              <div class="rk-row">
                <span class="w-5 text-center text-[11px] font-bold shrink-0 <%= idx===0?'rk-rank-1':idx===1?'rk-rank-2':idx===2?'rk-rank-3':'rk-rank-other' %>"><%= idx+1 %></span>
                <div class="w-7 h-7 rounded-full bg-horriver-orange/10 border border-horriver-orange/20 flex items-center justify-center text-[10px] font-bold text-horriver-orange shrink-0 overflow-hidden">
                  <% if (p.photoUrl) { %><img src="<%= thumbUrl(p.photoUrl, 56) %>" alt="" class="w-full h-full object-cover" loading="lazy" /><% } else { %><%= p.name.charAt(0).toUpperCase() %><% } %>
                </div>
