  <!-- ELENCO PREVIEW -->
  <section class="space-y-3">
    <div class="flex items-center justify-between gap-2">
      <div>
        <p class="text-[10px] text-horriver-gray/60 uppercase tracking-[0.18em] mb-0.5">Conheça o time</p>
        <h2 class="font-title text-2xl text-horriver-light">Elenco em destaque</h2>
      </div>
      <a href="/elenco" class="section-link">Ver todos →</a>
    </div>

    <% if (!players || !players.length) { %>
      <div class="flex flex-col items-center gap-2 py-6 text-horriver-gray/70">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
        <p class="text-sm text-center">Nenhum jogador cadastrado ainda.</p>
      </div>
    <% } else { %>
      <div id="players-preview" class="player-cards-scroll text-xs">
        <% players.forEach((p) => { %>
          <%
            const pOvr = p.overallDynamic != null ? p.overallDynamic : (p.baseOverall || null);
          %>
          <div class="player-card-snap card-unified p-3 flex flex-col gap-2" data-player-card>
            <div class="flex items-center gap-3">
              <div class="avatar-glow h-12 w-12 rounded-full bg-horriver-orange/10 flex items-center justify-center overflow-hidden shrink-0">
                <% if (p.photoUrl) { %>
                  <img
                    src="<%= thumbUrl(p.photoUrl, 96) %>"
                    srcset="<%= thumbUrl(p.photoUrl, 96) %> 1x, <%= thumbUrl(p.photoUrl, 192) %> 2x"
                    sizes="48px"
                    alt="<%= p.name %>"
                    width="48" height="48"
                    class="h-full w-full object-cover"
                    loading="lazy"
                  />
                <% } else { %>
                  <span class="text-base font-bold text-horriver-orange"><%= p.name.charAt(0).toUpperCase() %></span>
                <% } %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-horriver-light text-[12px] truncate"><%= p.name %></p>
                <% if (p.nickname) { %><p class="text-[10px] text-horriver-gray truncate">"<%= p.nickname %>"</p><% } %>
                <p class="text-[10px] text-horriver-orange uppercase"><%= p.position %></p>
              </div>
              <% if (pOvr) { %>
                <div class="shrink-0 w-9 h-9 rounded-xl bg-horriver-red/15 border border-horriver-red/30 flex flex-col items-center justify-center">
                  <span class="text-[8px] text-horriver-gray/60 uppercase leading-none">OVR</span>
                  <span class="text-[13px] font-bold text-horriver-light leading-tight"><%= pOvr %></span>
                </div>
              <% } %>
            </div>
            <% if ((p.totalGoals || 0) > 0 || (p.totalAssists || 0) > 0) { %>
              <div class="player-card-stats">
                <% if ((p.totalGoals || 0) > 0) { %><span class="player-card-stat"><strong><%= p.totalGoals %></strong> gols</span><% } %>
                <% if ((p.totalAssists || 0) > 0) { %><span class="player-card-stat"><strong><%= p.totalAssists %></strong> assist.</span><% } %>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>

  
  <!-- ÚLTIMAS PELADAS -->
  <section class="space-y-4">
    <h2 class="font-title text-2xl text-horriver-light">
      Últimas peladas
    </h2>

    <% if (!recentMatches || !recentMatches.length) { %>
      <div class="flex flex-col items-center gap-2 py-6 text-horriver-gray/70">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
        <p class="text-sm text-center">Nenhuma pelada cadastrada ainda.</p>
      </div>
    <% } else { %>
      <div class="space-y-2 text-xs">
        <% recentMatches.forEach((m) => { %>
          <div class="card-unified flex items-center justify-between px-3 py-2">
            <div>
              <p class="text-horriver-light font-medium">
                <%= fmtDate(m.playedAt) %>
              </p>
              <p class="text-[11px] text-horriver-gray">
                <%= m.description || "Sem descrição" %>
              </p>
            </div>
            <div class="text-right text-[11px]">
              <p class="text-horriver-orange">
                <% if (m.winnerTeam) { %>
                  <%= m.winnerTeam %>
                <% } else if (m.winnerColor) { %>
                  Time <%= m.winnerColor %>
                <% } else { %>
                  Sem time vencedor
                <% } %>
              </p>
              <a
                href="/matches/<%= m.id %>"
                class="inline-flex items-center px-2.5 py-1 rounded-full border border-horriver-border
                       text-horriver-gray hover:border-horriver-orange hover:text-horriver-orange
                       transition-colors text-[10px]"
              >
                Ver stats →
              </a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>

  <!-- FEED DE ATIVIDADES -->
  <%
    const _feed = typeof activityFeed !== 'undefined' ? activityFeed : [];
    const _relTime = function(ts) {
      if (!ts) return '';
      const diff = Date.now() - new Date(ts).getTime();
      const mins = Math.floor(diff / 60000);
      const hrs  = Math.floor(diff / 3600000);
      const days = Math.floor(diff / 86400000);
      if (days >= 30) { const m = Math.floor(days / 30); return m + (m > 1 ? ' meses' : ' mês') + ' atrás'; }
      if (days >= 1) return days + (days > 1 ? ' dias' : ' dia') + ' atrás';
      if (hrs >= 1)  return hrs + 'h atrás';
      if (mins >= 1) return mins + 'min atrás';
      return 'agora';
    };
  %>
  <% if (_feed.length) { %>
  <section class="space-y-3">
    <div class="flex items-center justify-between gap-2">
      <div>
        <p class="text-[10px] text-horriver-gray/60 uppercase tracking-[0.18em] mb-0.5">Atividade recente</p>
        <h2 class="font-title text-2xl text-horriver-light">Feed</h2>
      </div>
    </div>

    <div class="relative">
      <!-- Linha de timeline -->
      <div class="absolute left-[19px] top-4 bottom-4 w-px bg-gradient-to-b from-horriver-orange/40 via-horriver-border to-transparent pointer-events-none"></div>

      <div class="space-y-1.5">
        <% _feed.forEach(function(item) { %>
          <%
            const _isAward = item.type === 'weekly_award' || item.type === 'monthly_award';
            const _isHat   = item.type === 'hat_trick';
            const _isMatch = item.type === 'match';
            const _iconBg  = _isHat   ? 'bg-yellow-500/15 border-yellow-500/40 text-yellow-400'
                           : _isAward ? 'bg-horriver-orange/15 border-horriver-orange/40 text-horriver-orange'
                           : 'bg-horriver-red/15 border-horriver-red/30 text-horriver-gray';
          %>
          <div class="flex items-start gap-3 pl-1">
            <!-- Ícone / dot -->
            <div class="shrink-0 mt-0.5 w-9 h-9 rounded-full border flex items-center justify-center <%= _iconBg %>">
              <% if (_isHat) { %>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <% } else if (item.type === 'weekly_award') { %>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="8" r="6"/><path stroke-linecap="round" stroke-linejoin="round" d="M8.21 13.89L7 23l5-3 5 3-1.21-9.12"/></svg>
              <% } else if (item.type === 'monthly_award') { %>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
              <% } else { %>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
              <% } %>
            </div>

            <!-- Conteúdo -->
            <div class="flex-1 min-w-0 rounded-2xl border border-horriver-border bg-white/[0.025] px-3 py-2.5">
              <div class="flex items-start justify-between gap-2 flex-wrap">
                <div class="min-w-0">
                  <!-- Foto do jogador (quando houver) -->
                  <% if (item.player && item.player.photoUrl) { %>
                    <div class="flex items-center gap-2 mb-1.5">
                      <div class="w-6 h-6 rounded-full overflow-hidden border border-horriver-orange/30 shrink-0">
                        <img src="<%= thumbUrl(item.player.photoUrl, 48) %>" alt="" class="w-full h-full object-cover" loading="lazy" />
                      </div>
                      <span class="text-[10px] text-horriver-gray/70 uppercase tracking-wider"><%= item.player.position || '' %></span>
                    </div>
                  <% } %>
                  <p class="text-xs font-semibold text-horriver-light leading-snug"><%= item.label %></p>
                  <p class="text-[10px] text-horriver-gray/70 mt-0.5 leading-snug"><%= item.sub %></p>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                  <% if (item.timestamp) { %>
                    <span class="text-[10px] text-horriver-gray/50 whitespace-nowrap"><%= _relTime(item.timestamp) %></span>
                  <% } %>
                  <% if (item.matchId) { %>
                    <a href="/matches/<%= item.matchId %>"
                       class="text-[10px] px-2 py-0.5 rounded-full border border-horriver-border text-horriver-gray hover:border-horriver-orange hover:text-horriver-orange transition-colors whitespace-nowrap">
                      Ver →
                    </a>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- TEXTO FINAL -->
  <section class="mt-10 pt-6 border-t border-horriver-border text-center">
    <div class="max-w-xl mx-auto space-y-3">
      <div
        class="section-badge inline-flex items-center gap-2 px-3 py-1 rounded-full
               bg-horriver-red/20 border border-horriver-red/60 text-[11px]
               text-horriver-gray"
      >
        Desde 2024 • Pelada e resenha
      </div>

      <h2 class="font-title text-3xl text-horriver-orange">
        Horriver Plate
      </h2>
      <p class="text-sm text-horriver-gray">
        Estatísticas de pelada com cara de time profissional. Acompanhe gols,
        assistências, notas, presenças e destaques da nossa resenha. Tudo
        organizado como se fosse clube grande — mas sempre com o espírito da
        pelada entre amigos.
      </p>
    </div>
  </section>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // ==========================
    // Tabs de ranking na home
    // ==========================
    const rkBtns = document.querySelectorAll(".rk-home-btn");
    const rkTabs = document.querySelectorAll(".rk-home-tab");

    rkBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.dataset.target;

        rkBtns.forEach((b) => {
          b.classList.remove("bg-horriver-red", "text-horriver-light");
          b.classList.add("text-horriver-gray");
        });
        rkTabs.forEach((t) => t.classList.add("hidden"));

        btn.classList.add("bg-horriver-red", "text-horriver-light");
        const tab = document.getElementById(target);
        if (tab) tab.classList.remove("hidden");
      });
    });

    // ==========================
    // Elenco em destaque: sorteia 8 jogadores
    // ==========================
    const playerCards = Array.from(
      document.querySelectorAll("[data-player-card]")
    );
    if (playerCards.length > 8) {
      const shuffled = [...playerCards].sort(() => Math.random() - 0.5);
      shuffled.forEach((card, index) => {
        card.style.display = index < 8 ? "" : "none";
      });
    }

    // ==========================
    // Carrossel Hall da Fama
    // ==========================
    const hallCarousel = document.getElementById("hallCarousel");
    const hallSlidesEls = Array.from(document.querySelectorAll(".hall-slide"));
    const hallDots = Array.from(document.querySelectorAll(".hall-dot"));
    const prevBtn = document.getElementById("hallPrev");
    const nextBtn = document.getElementById("hallNext");

    let hallIndex = 0;
    let hallTimer = null;

    function setHallActive(idx) {
      if (!hallSlidesEls.length) return;
      const total = hallSlidesEls.length;
      const newIndex = ((idx % total) + total) % total;

      hallSlidesEls.forEach((slide, i) => {
        if (i === newIndex) {
          slide.classList.remove("opacity-0", "translate-x-6", "pointer-events-none", "z-0");
          slide.classList.add("opacity-100", "translate-x-0", "pointer-events-auto", "z-10");
        } else {
          slide.classList.remove("opacity-100", "translate-x-0", "pointer-events-auto", "z-10");
          slide.classList.add("opacity-0", "translate-x-6", "pointer-events-none", "z-0");
        }
      });

      hallDots.forEach((dot, i) => {
        if (i === newIndex) {
          dot.classList.add("bg-horriver-orange");
        } else {
          dot.classList.remove("bg-horriver-orange");
        }
      });

      hallIndex = newIndex;
    }

    function nextHall() {
      setHallActive(hallIndex + 1);
    }

    function prevHall() {
      setHallActive(hallIndex - 1);
    }

    function startHallAuto() {
      if (hallTimer || hallSlidesEls.length <= 1) return;
      hallTimer = setInterval(nextHall, 6000);
    }

    function stopHallAuto() {
      if (hallTimer) {
        clearInterval(hallTimer);
        hallTimer = null;
      }
    }

    if (hallSlidesEls.length) {
      startHallAuto();

      if (nextBtn) nextBtn.addEventListener("click", () => {
        stopHallAuto();
        nextHall();
        startHallAuto();
      });

      if (prevBtn) prevBtn.addEventListener("click", () => {
        stopHallAuto();
        prevHall();
        startHallAuto();
      });

      hallDots.forEach((dot) => {
        dot.addEventListener("click", () => {
          const idx = parseInt(dot.dataset.index, 10) || 0;
          stopHallAuto();
          setHallActive(idx);
          startHallAuto();
        });
      });

      if (hallCarousel) {
        hallCarousel.addEventListener("mouseenter", stopHallAuto);
        hallCarousel.addEventListener("mouseleave", startHallAuto);
      }
    }

    // ==========================
    // Hero Carousel
    // ==========================
    const HERO_DURATION = 6000;
    const heroEl      = document.getElementById("heroCarousel");
    const hSlides     = Array.from(document.querySelectorAll(".hero-slide"));
    const hDots       = Array.from(document.querySelectorAll(".hero-dot"));
    const hPrev       = document.getElementById("heroPrev");
    const hNext       = document.getElementById("heroNext");
    const hProgressEl = document.getElementById("heroProgress");

    let hIdx = 0;
    let hTimer = null;

    function runProgress() {
      if (!hProgressEl || hSlides.length <= 1) return;
      hProgressEl.style.transition = "none";
      hProgressEl.style.width = "0%";
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          hProgressEl.style.transition = `width ${HERO_DURATION}ms linear`;
          hProgressEl.style.width = "100%";
        });
      });
    }
    function stopProgress() {
      if (!hProgressEl) return;
      hProgressEl.style.transition = "none";
      hProgressEl.style.width = "0%";
    }

    function setHeroActive(idx) {
      if (!hSlides.length) return;
      const n = hSlides.length;
      const next = ((idx % n) + n) % n;
      const prev = hIdx;

      hSlides.forEach((s, i) => {
        s.classList.remove("is-active", "is-leaving");
        if (i === next) {
          s.classList.add("is-active");
        } else if (i === prev && prev !== next) {
          s.classList.add("is-leaving");
          setTimeout(() => s.classList.remove("is-leaving"), 500);
        }
      });

      hDots.forEach((d, i) => d.classList.toggle("is-active", i === next));
      hIdx = next;
    }

    function nextHero() { setHeroActive(hIdx + 1); }
    function prevHero() { setHeroActive(hIdx - 1); }

    function startHeroAuto() {
      if (hTimer || hSlides.length <= 1) return;
      runProgress();
      hTimer = setInterval(() => { nextHero(); runProgress(); }, HERO_DURATION);
    }
    function stopHeroAuto() {
      if (hTimer) { clearInterval(hTimer); hTimer = null; }
      stopProgress();
    }

    if (hSlides.length) {
      setHeroActive(0);
      startHeroAuto();

      if (hPrev) hPrev.addEventListener("click", () => { stopHeroAuto(); prevHero(); startHeroAuto(); });
      if (hNext) hNext.addEventListener("click", () => { stopHeroAuto(); nextHero(); startHeroAuto(); });

      hDots.forEach((d) => {
        d.addEventListener("click", () => {
          const i = parseInt(d.dataset.index, 10) || 0;
          stopHeroAuto(); setHeroActive(i); startHeroAuto();
        });
      });

      if (heroEl) {
        heroEl.addEventListener("mouseenter", stopHeroAuto);
        heroEl.addEventListener("mouseleave", startHeroAuto);

        let tStart = 0;
        heroEl.addEventListener("touchstart", (e) => {
          tStart = e.changedTouches[0].screenX;
        }, { passive: true });
        heroEl.addEventListener("touchend", (e) => {
          const delta = e.changedTouches[0].screenX - tStart;
          if (Math.abs(delta) > 50) {
            stopHeroAuto();
            delta < 0 ? nextHero() : prevHero();
            startHeroAuto();
          }
        }, { passive: true });
      }
    }
  });
</script>






