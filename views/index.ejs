                  </div>
                </div>
              <% } %>
              <div class="grid grid-cols-4 gap-2 w-full max-w-[20rem] md:max-w-sm">
                <div class="flex flex-col items-center justify-center gap-1 py-2 px-1 rounded-xl bg-black/50 border border-white/[0.11] min-w-0">
                  <span class="block text-[9px] text-horriver-gray/60 uppercase tracking-wider leading-none whitespace-nowrap">Gols</span>
                  <span class="block text-[17px] font-bold text-horriver-light leading-none"><%= mStats ? mStats.goals : 0 %></span>
                </div>
                <div class="flex flex-col items-center justify-center gap-1 py-2 px-1 rounded-xl bg-black/50 border border-white/[0.11] min-w-0">
                  <span class="block text-[9px] text-horriver-gray/60 uppercase tracking-wider leading-none whitespace-nowrap">Assist.</span>
                  <span class="block text-[17px] font-bold text-horriver-light leading-none"><%= mStats ? mStats.assists : 0 %></span>
                </div>
                <div class="flex flex-col items-center justify-center gap-1 py-2 px-1 rounded-xl bg-black/50 border border-white/[0.11] min-w-0">
                  <span class="block text-[9px] text-horriver-gray/60 uppercase tracking-wider leading-none whitespace-nowrap">Jogos</span>
                  <span class="block text-[17px] font-bold text-horriver-light leading-none"><%= mStats ? mStats.matches : 0 %></span>
                </div>
                <div class="flex flex-col items-center justify-center gap-1 py-2 px-1 rounded-xl bg-black/50 border border-white/[0.11] min-w-0">
                  <span class="block text-[9px] text-horriver-gray/60 uppercase tracking-wider leading-none whitespace-nowrap">Nota</span>
                  <span class="block text-[17px] font-bold text-horriver-light leading-none"><%= mStats ? fmtRating(mStats.avgRating) : '0,00' %></span>
                </div>
              </div>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Slide 2: Foto da semana (condicional) -->
      <% if (weeklyAward && weeklyAward.teamPhotoUrl) { %>
        <div class="hero-slide px-5 pb-7 pt-4 md:px-8 md:pb-8" data-index="2">
          <div class="flex flex-col gap-4">
            <div class="flex items-center justify-between gap-2 flex-wrap">
              <span class="section-badge inline-flex items-center px-3 py-1 rounded-full bg-horriver-red/30 border border-horriver-red/60 text-[11px] text-horriver-gray">Time da semana</span>
              <% if (weeklyAward.winningMatch) { %>
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-black/30 border border-horriver-border text-[10px] text-horriver-gray">
                  Pelada <span class="text-horriver-light font-semibold ml-1"><%= fmtDate(weeklyAward.winningMatch.playedAt) %></span>
                </div>
              <% } %>
            </div>
            <div class="rounded-2xl overflow-hidden bg-black/80 border border-horriver-orange/40 flex items-center justify-center" style="max-height:260px;">
              <img src="<%= weeklyAward.teamPhotoUrl %>" alt="Time da semana"
                   class="w-full h-auto object-contain" style="max-height:260px;" loading="lazy" />
            </div>
            <% if (weeklyAward.winningMatch && weeklyAward.winningMatch.description) { %>
              <p class="text-[12px] text-horriver-gray text-center"><%= weeklyAward.winningMatch.description %></p>
            <% } %>
          </div>
        </div>
      <% } %>

    </div><!-- /hero-track -->
    <div class="hero-progress" id="heroProgress"></div>
  </section>

  <!-- ======================================================
       RANKINGS RÁPIDOS
  ======================================================= -->
  <section class="space-y-3">
