<%
  // ===============================
  // Helpers gerais
  // ===============================
  const fmtDate = (d) =>
    d ? new Date(d).toLocaleDateString("pt-BR", { timeZone: 'America/Sao_Paulo' }) : "-";

  const limit = (arr, n) => (arr && arr.length ? arr.slice(0, n) : []);

  const fmtRating = (val) => {
    if ((!val && val !== 0) || Number.isNaN(val)) return "0,00";
    return Number(val).toFixed(2).replace(".", ",");
  };

  const monthNames = [
    "Janeiro","Fevereiro","Março","Abril","Maio","Junho",
    "Julho","Agosto","Setembro","Outubro","Novembro","Dezembro"
  ];

  // Stats do mês (craque)
  const mStats =
    (typeof monthlyStats !== "undefined" && monthlyStats) || null;

  // Stats da semana (craque da semana)
  const wStats =
    (typeof weeklyStats !== "undefined" && weeklyStats) || null;

  // ===============================
  // Hall da Fama - Destaques da temporada (carrossel)
  // ===============================
  const highlightAwards = Array.isArray(seasonHighlightAwards)
    ? seasonHighlightAwards
    : [];

  const hallYear = typeof seasonHighlightYear !== "undefined"
    ? seasonHighlightYear
    : null;

  const awardByCat = {};
  highlightAwards.forEach((a) => {
    awardByCat[a.category] = a;
  });

  const catLabelMap = {
    melhor_jogador: "Craque da temporada",
    artilheiro: "Artilheiro da temporada",
    assistente: "Rei das assistências",
    melhor_goleiro: "Muralha da temporada",
    melhor_zagueiro: "Melhor zagueiro",
    melhor_meia: "Maestro da temporada",
    melhor_atacante: "Melhor atacante"
  };

  // Gradientes pensados pra combinar com o site e com a ideia de prêmio
  const catGradientMap = {
    melhor_jogador: "from-yellow-300 via-amber-300 to-yellow-500", // Ballon d'Or vibes
    artilheiro: "from-yellow-400 via-amber-400 to-orange-500",      // ouro quente
    assistente: "from-emerald-400 via-emerald-500 to-emerald-700",  // verde (assist)
    melhor_goleiro: "from-sky-400 via-cyan-500 to-blue-600",
    melhor_zagueiro: "from-slate-500 via-slate-600 to-slate-800",
    melhor_meia: "from-purple-400 via-violet-500 to-fuchsia-500",
    melhor_atacante: "from-rose-500 via-red-500 to-orange-500"
  };

  const hasHallCarousel = highlightAwards.length > 0;

  // Monta slides em ordem:
  // 1) Craque
  // 2) Artilheiro + Assistente
  // 3) Goleiro + Zagueiro
  // 4) Meia + Atacante
  const hallSlides = [];

  if (awardByCat.melhor_jogador) {
    hallSlides.push({
      key: "craque",
      type: "single",
      title: "Craque da temporada",
      awards: [awardByCat.melhor_jogador]
    });
  }

  const ataqueAwards = [];
  if (awardByCat.artilheiro) ataqueAwards.push(awardByCat.artilheiro);
  if (awardByCat.assistente) ataqueAwards.push(awardByCat.assistente);
  if (ataqueAwards.length) {
    hallSlides.push({
      key: "ataque",
      type: "pair",
      title: "Reis do ataque",
      awards: ataqueAwards
    });
  }

  const defesaAwards = [];
  if (awardByCat.melhor_goleiro) defesaAwards.push(awardByCat.melhor_goleiro);
  if (awardByCat.melhor_zagueiro) defesaAwards.push(awardByCat.melhor_zagueiro);
  if (defesaAwards.length) {
    hallSlides.push({
      key: "defesa",
      type: "pair",
      title: "Muralhas lá atrás",
      awards: defesaAwards
    });
  }

  const criacaoAwards = [];
  if (awardByCat.melhor_meia) criacaoAwards.push(awardByCat.melhor_meia);
  if (awardByCat.melhor_atacante) criacaoAwards.push(awardByCat.melhor_atacante);
  if (criacaoAwards.length) {
    hallSlides.push({
      key: "criacao",
      type: "pair",
      title: "Maestro e matador",
      awards: criacaoAwards
    });
  }
%>

<section class="home-sections flex flex-col gap-7 md:gap-10 animate-fadeIn overflow-x-hidden">

  <!-- ======================================================
       HALL DA FAMA – CARROSSEL DA TEMPORADA
  ======================================================= -->
  <% if (hasHallCarousel && hallSlides.length) { %>
    <section
      id="hallCarousel"
      class="card-inner rounded-3xl px-5 py-6 md:px-8 md:py-8 space-y-4 relative overflow-hidden"
      style="min-height: 280px;"
    >
      <div class="flex items-start justify-between gap-4 mb-2">
        <div>
          <p class="text-[11px] text-horriver-gray/80 uppercase tracking-[0.20em]">
            Temporada <%= hallYear || "" %> • Premiação
          </p>
          <h1 class="text-2xl md:text-3xl font-title text-horriver-light">
            Hall da Fama – Campeões da temporada
          </h1>
          <p class="text-xs md:text-sm text-horriver-gray mt-1 max-w-xl">
            Destaques oficiais da temporada <%= hallYear || '' %>, em evidência na home
            até o fim do ano. Depois, eles ficam eternizados na página do Hall da Fama.
          </p>
        </div>

        <!-- Dots -->
        <div class="flex flex-col items-center md:items-end gap-1 text-[10px]">
          <div class="flex items-center gap-2 mb-1">
            <% hallSlides.forEach((slide, i) => { %>
              <button
                type="button"
                class="hall-dot w-2 h-2 rounded-full border border-horriver-orange/70
                       <%= i === 0 ? 'bg-horriver-orange' : 'bg-transparent' %>"
                data-index="<%= i %>"
                aria-label="Ir para slide <%= i + 1 %>"
              ></button>
            <% }) %>
          </div>
          <span class="text-horriver-gray/70">
            Use as setas ou clique nos pontos
          </span>
        </div>
      </div>

      <!-- Slides -->
      <div class="relative mt-3 h-[260px] md:h-[320px] lg:h-[360px]">
        <% hallSlides.forEach((slide, idx) => { %>
          <div
            class="hall-slide absolute inset-0 transition-all duration-500 ease-out
                   <%= idx === 0
                        ? 'opacity-100 translate-x-0 pointer-events-auto z-10'
                        : 'opacity-0 translate-x-6 pointer-events-none z-0' %>"
            data-index="<%= idx %>"
          >
            <% if (slide.type === "single") {
                 const a = slide.awards[0];
                 const p = a.player || {};
                 const grad = catGradientMap[a.category] || "from-slate-500 via-slate-600 to-slate-800";
                 const label = catLabelMap[a.category] || a.category;
            %>
              <!-- Card único: Craque da temporada (Ballon d'Or style) -->
              <div
                class="relative w-full h-full bg-gradient-to-r <%= grad %> rounded-3xl
                       shadow-card-soft flex flex-col md:flex-row items-center
                       gap-6 px-5 md:px-10 py-6 md:py-8 overflow-hidden"
              >
                <!-- Aureola dourada no fundo -->
                <div
                  class="pointer-events-none absolute -right-16 -bottom-16 w-56 h-56 rounded-full
                         border border-yellow-300/40 bg-yellow-300/10 blur-md"
                ></div>

                <!-- Estrela de destaque -->
                <div
                  class="section-badge absolute top-4 left-4 inline-flex items-center gap-2 px-3 py-1
                         rounded-full bg-black/40 border border-yellow-300/70"
                >
                  <span class="text-yellow-300 text-base">?</span>
                  <span class="text-[11px] text-yellow-100 tracking-[0.18em] uppercase">
                    Craque máximo
                  </span>
                </div>

                <div class="flex-1 space-y-3 relative z-10">
                  <p class="text-[11px] uppercase tracking-[0.2em] text-black/70">
                    <%= label %>
                  </p>
                  <h2 class="text-2xl md:text-3xl font-title text-black">
                    <%= p.name || 'Jogador' %>
                  </h2>
                  <% if (p.nickname) { %>
                    <p class="text-sm text-black/80">
                      "<%= p.nickname %>"
                    </p>
                  <% } %>
                  <% if (p.position) { %>
                    <p class="text-[11px] text-black/75 uppercase">
                      <%= p.position %>
                    </p>
                  <% } %>
                  <p class="text-[11px] text-black/75 mt-2 max-w-md">
                    Eleito o grande nome da temporada <%= hallYear || '' %>.
                    Aquele nível de futebol que vira referência na resenha por muito tempo.
                  </p>
                </div>

                <!-- Foto grande -->
                <div
                  class="relative z-10 w-32 h-32 md:w-40 md:h-40 rounded-full border-[5px] border-yellow-200/95
                         bg-black/30 flex items-center justify-center overflow-hidden shadow-xl"
                >
                  <% if (p.photoUrl) { %>
                    <img
                      src="<%= thumbUrl(p.photoUrl, 320) %>"
                      srcset="<%= thumbUrl(p.photoUrl, 320) %> 1x, <%= thumbUrl(p.photoUrl, 640) %> 2x"
                      sizes="160px"
                      alt="<%= p.name %>"
                      class="w-full h-full object-cover"
                    />
                  <% } else if (p.name) { %>
                    <span class="text-4xl font-semibold text-white">
                      <%= p.name.charAt(0).toUpperCase() %>
                    </span>
                  <% } else { %>
                    <span class="text-3xl font-semibold text-white">?</span>
                  <% } %>
                </div>
              </div>

            <% } else { %>
              <!-- Slides em pares (artilheiro+assistente, etc.) -->
              <div
                class="w-full h-full flex flex-col gap-4 md:gap-6 justify-center"
              >
                <p class="text-[11px] text-horriver-gray/80 uppercase tracking-[0.20em]">
                  <%= slide.title %>
                </p>

                <div class="grid md:grid-cols-2 gap-4 md:gap-6">
                  <% slide.awards.forEach((a) => {
                       const p = a.player || {};
                       const grad = catGradientMap[a.category] || "from-slate-500 via-slate-600 to-slate-800";
                       const label = catLabelMap[a.category] || a.category;
                  %>
                    <div
                      class="bg-gradient-to-r <%= grad %> rounded-3xl px-4 md:px-6 py-4 md:py-6
                             shadow-card-soft flex items-center gap-4 md:gap-6 relative overflow-hidden"
                    >
                      <!-- leve overlay escuro pra aproximar do tema do site -->
                      <div class="pointer-events-none absolute inset-0 bg-black/10"></div>

                      <div class="flex-1 space-y-2 relative z-10">
                        <p class="text-[10px] md:text-[11px] uppercase tracking-[0.18em] text-black/80">
                          <%= label %>
                        </p>
                        <p class="text-lg md:text-xl font-semibold text-black">
                          <%= p.name || 'Jogador' %>
                          <% if (p.nickname) { %>
                            <span class="text-[12px] text-black/75">
                              ("<%= p.nickname %>")
                            </span>
                          <% } %>
                        </p>
                        <% if (p.position) { %>
                          <p class="text-[10px] text-black/75 uppercase">
                            <%= p.position %>
                          </p>
                        <% } %>
                      </div>

                      <div
                        class="relative z-10 w-16 h-16 md:w-20 md:h-20 rounded-full border-[3px] border-white/85
                               bg-black/20 flex items-center justify-center overflow-hidden shrink-0"
                      >
                        <% if (p.photoUrl) { %>
                          <img
                            src="<%= thumbUrl(p.photoUrl, 160) %>"
                            srcset="<%= thumbUrl(p.photoUrl, 160) %> 1x, <%= thumbUrl(p.photoUrl, 320) %> 2x"
                            sizes="80px"
                            alt="<%= p.name %>"
                            class="w-full h-full object-cover"
                          />
                        <% } else if (p.name) { %>
                          <span class="text-2xl font-semibold text-white">
                            <%= p.name.charAt(0).toUpperCase() %>
                          </span>
                        <% } else { %>
                          <span class="text-xl font-semibold text-white">?</span>
                        <% } %>
                      </div>
                    </div>
                  <% }) %>
                </div>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>

      <% if (hallSlides.length > 1) { %>
        <!-- Controles -->
        <div class="mt-4 flex items-center justify-between text-[11px]">
          <button
            id="hallPrev"
            type="button"
            class="inline-flex items-center gap-1 px-3 py-1 rounded-full
                   bg-black/40 border border-horriver-border text-horriver-gray
                   hover:border-horriver-orange hover:text-horriver-orange transition-colors"
          >
            ? Anterior
          </button>
          <button
            id="hallNext"
            type="button"
            class="inline-flex items-center gap-1 px-3 py-1 rounded-full
                   bg-black/40 border border-horriver-border text-horriver-gray
                   hover:border-horriver-orange hover:text-horriver-orange transition-colors"
          >
            Próximo ?
          </button>
        </div>
      <% } %>
    </section>
  <% } %>

  <!-- ======================================================
       HERO CAROUSEL — Craque da Semana / Craque do Mês / Foto
  ======================================================= -->
  <%
    const heroSlides = [];
    heroSlides.push({ type: 'weekly', label: 'Craque da semana' });
    heroSlides.push({ type: 'monthly', label: 'Craque do mês' });
    if (weeklyAward && weeklyAward.teamPhotoUrl) {
      heroSlides.push({ type: 'photo', label: 'Time da semana' });
    }
  %>
  <section
    id="heroCarousel"
    class="relative rounded-3xl border border-horriver-border overflow-hidden"
    style="background: radial-gradient(circle at 18% 0%, rgba(139,19,32,0.28), transparent 52%), radial-gradient(circle at 82% 100%, rgba(255,122,26,0.1), transparent 44%), rgba(0,0,0,0.42); box-shadow: 0 18px 40px rgba(0,0,0,0.38);"
  >
    <!-- Top shine line -->
    <div class="absolute inset-x-0 top-0 h-px pointer-events-none" style="background: linear-gradient(90deg, transparent, rgba(255,122,26,0.55), transparent);"></div>
    <!-- Top bar: dots + nav -->
    <div class="flex items-center justify-between px-5 pt-5 pb-0 md:px-8 md:pt-6">
      <div class="flex items-center gap-1.5">
        <% heroSlides.forEach((s, i) => { %>
          <button
            type="button"
            class="hero-dot"
            data-index="<%= i %>"
            aria-label="Ir para: <%= s.label %>"
          ></button>
        <% }) %>
      </div>
      <% if (heroSlides.length > 1) { %>
        <div class="flex items-center gap-1">
          <button id="heroPrev" type="button"
            class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-black/40 border border-horriver-border text-horriver-gray hover:border-horriver-orange hover:text-horriver-orange transition-colors"
            aria-label="Slide anterior"
          ><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg></button>
          <button id="heroNext" type="button"
            class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-black/40 border border-horriver-border text-horriver-gray hover:border-horriver-orange hover:text-horriver-orange transition-colors"
            aria-label="Próximo slide"
          ><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></button>
        </div>
      <% } %>
    </div>

    <!-- Slide track -->
    <div class="hero-track">

      <!-- Slide 0: Craque da Semana -->
      <div class="hero-slide px-5 pb-6 pt-3 md:px-8 md:pb-8" data-index="0">
        <% if (!weeklyAward || !weeklyAward.bestPlayer) { %>
          <div class="flex flex-col items-center gap-3 py-8 text-horriver-gray/70">
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-horriver-red/20 border border-horriver-red/40 text-[11px] text-horriver-gray">Craque da semana</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
            <p class="text-sm text-center">Nenhum craque da semana definido ainda.</p>
          </div>
        <% } else { %>
          <div class="flex items-center gap-4 md:gap-10">
            <!-- Avatar -->
            <div class="shrink-0 md:order-last w-20 h-20 md:w-36 md:h-36 rounded-full overflow-hidden border-[2px] md:border-[3px] border-horriver-orange bg-black/70 flex items-center justify-center" style="box-shadow: 0 0 22px rgba(255,140,0,0.38);">
              <% if (weeklyAward.bestPlayer.photoUrl) { %>
                <img src="<%= thumbUrl(weeklyAward.bestPlayer.photoUrl, 288) %>"
                     srcset="<%= thumbUrl(weeklyAward.bestPlayer.photoUrl, 288) %> 1x, <%= thumbUrl(weeklyAward.bestPlayer.photoUrl, 576) %> 2x"
                     sizes="(min-width:768px) 144px, 80px"
                     alt="<%= weeklyAward.bestPlayer.name %>"
                     class="w-full h-full object-cover" loading="lazy" />
              <% } else { %>
                <span class="text-3xl font-bold text-horriver-orange"><%= weeklyAward.bestPlayer.name.charAt(0).toUpperCase() %></span>
              <% } %>
            </div>
            <%
              const weeklyOvr = weeklyAward.bestPlayer.overallDynamic != null
                ? weeklyAward.bestPlayer.overallDynamic
                : (weeklyAward.bestPlayer.baseOverall || null);
            %>
            <!-- Info -->
            <div class="flex-1 flex flex-col gap-2.5 min-w-0">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full bg-horriver-red/20 border border-horriver-red/40 text-[10px] text-horriver-gray tracking-wide">Craque da semana</span>
                <% if (weeklyAward.winningMatch) { %>
                  <span class="text-[10px] text-horriver-gray/50"><%= fmtDate(weeklyAward.winningMatch.playedAt) %></span>
                <% } %>
              </div>
              <div class="space-y-0.5">
                <h2 class="font-title text-xl md:text-3xl text-horriver-light leading-tight"><%= weeklyAward.bestPlayer.name %></h2>
                <div class="flex items-center gap-2 flex-wrap">
                  <% if (weeklyAward.bestPlayer.position) { %><span class="text-[10px] text-horriver-orange uppercase tracking-wide"><%= weeklyAward.bestPlayer.position %></span><% } %>
                  <% if (weeklyOvr) { %><span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded-md bg-horriver-red/20 border border-horriver-red/30 text-[9px]"><span class="text-horriver-gray/55 uppercase tracking-wider">OVR</span>&nbsp;<span class="font-bold text-horriver-light"><%= weeklyOvr %></span></span><% } %>
                </div>
              </div>
              <div class="grid grid-cols-3 gap-2 w-full max-w-[17rem] md:max-w-xs">
                <div class="flex flex-col items-center justify-center gap-1 py-2 px-1 rounded-xl bg-black/50 border border-white/[0.11] min-w-0">
                  <span class="block text-[9px] text-horriver-gray/60 uppercase tracking-wider leading-none whitespace-nowrap">Gols</span>
                  <span class="block text-[17px] font-bold text-horriver-light leading-none"><%= wStats ? wStats.goals : 0 %></span>
                </div>
                <div class="flex flex-col items-center justify-center gap-1 py-2 px-1 rounded-xl bg-black/50 border border-white/[0.11] min-w-0">
                  <span class="block text-[9px] text-horriver-gray/60 uppercase tracking-wider leading-none whitespace-nowrap">Assist.</span>
                  <span class="block text-[17px] font-bold text-horriver-light leading-none"><%= wStats ? wStats.assists : 0 %></span>
                </div>
                <div class="flex flex-col items-center justify-center gap-1 py-2 px-1 rounded-xl bg-black/50 border border-white/[0.11] min-w-0">
                  <span class="block text-[9px] text-horriver-gray/60 uppercase tracking-wider leading-none whitespace-nowrap">Nota</span>
                  <span class="block text-[17px] font-bold text-horriver-light leading-none"><%= wStats ? fmtRating(wStats.avgRating) : '0,00' %></span>
                </div>
              </div>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Slide 1: Craque do Mês -->
      <div class="hero-slide px-5 pb-6 pt-3 md:px-8 md:pb-8" data-index="1">
        <% if (!monthlyCraque) { %>
          <div class="flex flex-col items-center gap-3 py-8 text-horriver-gray/70">
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-horriver-red/20 border border-horriver-red/40 text-[11px] text-horriver-gray">Craque do mês</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
            <p class="text-sm text-center">Nenhum craque do mês cadastrado ainda.</p>
          </div>
        <% } else { %>
          <%
            const monthlyOvr = monthlyCraque.craque && monthlyCraque.craque.overallDynamic != null
              ? monthlyCraque.craque.overallDynamic
              : (monthlyCraque.craque && monthlyCraque.craque.baseOverall ? monthlyCraque.craque.baseOverall : null);
          %>
          <div class="flex items-center gap-4 md:gap-10">
            <!-- Avatar -->
            <div class="shrink-0 md:order-last w-20 h-20 md:w-40 md:h-40 rounded-full overflow-hidden border-[2px] md:border-[4px] border-horriver-orange bg-black/70 flex items-center justify-center" style="box-shadow: 0 0 26px rgba(255,140,0,0.42);">
              <% if (monthlyCraque.craque && monthlyCraque.craque.photoUrl) { %>
                <img src="<%= thumbUrl(monthlyCraque.craque.photoUrl, 320) %>"
                     srcset="<%= thumbUrl(monthlyCraque.craque.photoUrl, 320) %> 1x, <%= thumbUrl(monthlyCraque.craque.photoUrl, 640) %> 2x"
                     sizes="(min-width:768px) 160px, 80px"
                     alt="<%= monthlyCraque.craque.name %>"
                     class="w-full h-full object-cover" loading="lazy" />
              <% } else if (monthlyCraque.craque) { %>
                <span class="text-3xl font-bold text-horriver-orange"><%= monthlyCraque.craque.name.charAt(0).toUpperCase() %></span>
              <% } %>
            </div>
            <!-- Info -->
            <div class="flex-1 flex flex-col gap-2.5 min-w-0">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full bg-horriver-red/20 border border-horriver-red/40 text-[10px] text-horriver-gray tracking-wide">Craque do mês</span>
                <span class="text-[10px] text-horriver-gray/50"><%= monthNames[(monthlyStatsMonth || monthlyCraque.month) - 1] %> <%= (monthlyStatsYear || monthlyCraque.year) %></span>
              </div>
              <% if (monthlyCraque.craque) { %>
                <div class="space-y-0.5">
                  <h2 class="font-title text-xl md:text-3xl text-horriver-light leading-tight"><%= monthlyCraque.craque.name %></h2>
                  <div class="flex items-center gap-2 flex-wrap">
                    <% if (monthlyCraque.craque.position) { %><span class="text-[10px] text-horriver-orange uppercase tracking-wide"><%= monthlyCraque.craque.position %></span><% } %>
