<%
  // ===============================
  // Helpers e preparação de dados
  // ===============================
  const fmtDate = (d) =>
    d ? new Date(d).toLocaleDateString("pt-BR", { timeZone: 'America/Sao_Paulo' }) : "-";

  const fmtRating = (val) => {
    if (!val && val !== 0) return "0,00";
    const num = Number(val);
    if (Number.isNaN(num)) return "0,00";
    return num.toFixed(2).replace(".", ",");
  };
  const fmtRating3 = fmtRating;

  const safeArr = (arr) => (Array.isArray(arr) ? arr : []);

  const goals   = safeArr(rankings && rankings.goals);
  const assists = safeArr(rankings && rankings.assists);
  const ga      = safeArr(rankings && rankings.ga);
  const ratings = safeArr(rankings && rankings.ratings);
  const matches = safeArr(rankings && rankings.matches);
  const photos  = safeArr(rankings && rankings.photos);

  // novos rankings calculados no backend
  const overall = safeArr(rankings && rankings.overall); // overallScore
  const last10  = safeArr(rankings && rankings.last10);  // last10Score

  const weeklyAwards  = safeArr(rankings && rankings.weeklyAwards);
  const monthlyAwards = safeArr(rankings && rankings.monthlyAwards);
  const colorWins = safeArr(rankings && rankings.colorWins);

  const monthNames = [
    "Janeiro","Fevereiro","Março","Abril","Maio","Junho",
    "Julho","Agosto","Setembro","Outubro","Novembro","Dezembro"
  ];

  const selYear = (typeof year === "string" && year === "all")
    ? "all"
    : Number(year || new Date().getFullYear());

  const selMonth = typeof month !== "undefined" ? Number(month) : 0; // 0 = todos
  const selPos = typeof selPosition !== "undefined" ? selPosition : "all";

  const posLabel = (p) => {
    if (!p || p === "all") return "Todas";
    return p;
  };

  const periodLabel = () => {
    if (selYear === "all") return "Geral (todos os anos)";
    if (selMonth === 0) return `Ano de ${selYear}`;
    const mName = monthNames[(selMonth || 1) - 1] || "";
    return `${mName} / ${selYear}`;
  };

  const topRowClass = (idx) => {
    if (idx === 0) return "rk-row-gold";
    if (idx === 1) return "rk-row-silver";
    if (idx === 2) return "rk-row-bronze";
    return "";
  };

  const colorMeta = {
    Amarelo: "border-yellow-400/40 text-yellow-300 bg-yellow-400/10",
    Azul: "border-blue-400/40 text-blue-300 bg-blue-400/10",
    Preto: "border-slate-400/40 text-slate-200 bg-slate-500/10",
    Vermelho: "border-red-400/40 text-red-300 bg-red-500/10",
  };
  const colorBoxClass = (name) =>
    colorMeta[name] || "border-horriver-border text-horriver-light bg-white/5";
  const leaderName = (row) =>
    row && row.player
      ? `${row.player.name}${row.player.nickname ? ` (${row.player.nickname})` : ""}`
      : "Sem dados";
  const playerDisplayName = (row) =>
    row && row.player
      ? `${row.player.name}${row.player.nickname ? ` (${row.player.nickname})` : ""}`
      : "-";
  const escapeHtml = (value) =>
    String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  const medalMeta = [
    { label: "1", title: "Ouro", cls: "rk-podium-card--gold" },
    { label: "2", title: "Prata", cls: "rk-podium-card--silver" },
    { label: "3", title: "Bronze", cls: "rk-podium-card--bronze" },
  ];
  const renderRankingPodium = (rows, metrics) => {
    const top = safeArr(rows).slice(0, 3);
    if (!top.length) return "";
    const cards = top.map((row, idx) => {
      const meta = medalMeta[idx] || medalMeta[2];
      const metricHtml = safeArr(metrics).map((metric) => {
        const raw = typeof metric.value === "function" ? metric.value(row) : row[metric.key];
        const value = raw === null || raw === undefined || raw === "" ? "0" : raw;
        return `
          <span class="rk-podium-metric">
            <span>${escapeHtml(metric.label)}</span>
            <strong>${escapeHtml(value)}</strong>
          </span>
        `;
      }).join("");
      return `
        <article class="rk-podium-card ${meta.cls}">
          <div class="rk-podium-rank">
            <span>${meta.label}</span>
          </div>
          <div class="rk-podium-body">
            <span class="rk-podium-medal">${meta.title}</span>
            <strong>${escapeHtml(playerDisplayName(row))}</strong>
            <span>${escapeHtml(row.player?.position || "-")}</span>
          </div>
          <div class="rk-podium-metrics">
            ${metricHtml}
          </div>
        </article>
      `;
    }).join("");
    return `<div class="rk-podium hidden md:grid">${cards}</div>`;
  };
  const topGoal = goals[0] || null;
  const topAssist = assists[0] || null;
  const topRating = ratings[0] || null;
  const topOverall = overall[0] || null;
  const pillClass = "inline-flex items-center gap-2 rounded-full border border-horriver-border bg-white/[0.04] px-3 py-2 text-[11px] leading-none text-horriver-light";
  const accentPillClass = "inline-flex items-center gap-2 rounded-full border border-horriver-orange/30 bg-horriver-orange/10 px-3 py-2 text-[11px] leading-none text-horriver-light";
  const emptyStateClass = "rounded-[1.5rem] border border-dashed border-horriver-border bg-gradient-to-br from-horriver-orange/8 via-black/30 to-black/40 px-5 py-5";
  const emptyEyebrowClass = "inline-flex items-center rounded-full border border-horriver-orange/20 bg-horriver-orange/10 px-3 py-1 text-[10px] uppercase tracking-[0.16em] text-[#ffb685]";

  const sponsorNameByLabel = {
    Amarelo: "Natureza em Flores",
    Vermelho: "Matheus Gomes Barbearia",
    Azul: "Carrocerias Santana",
    Preto: "Advance Compressores",
  };
  const colorDisplayName = (name) => sponsorNameByLabel[name] || name;
%>

