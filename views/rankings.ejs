  }
</style>

<section class="page-shell animate-fadeIn">
  <!-- TITULO E FILTROS -->
  <header class="page-hero space-y-4">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-3">
      <div class="space-y-2">
        <span class="hero-badge text-horriver-gray">
          <span class="hero-icon">RK</span>
          Rankings
        </span>
        <h1 class="font-title text-3xl text-horriver-light">
          Rankings completos
        </h1>
        <p class="text-sm text-horriver-gray">
          Veja os rankings gerais ou filtrados por ano/mes e posicao.
        </p>
      </div>

      <!-- Resumo do filtro atual -->
      <div class="text-xs text-horriver-gray md:text-right space-y-2">
        <p>
          Periodo:
          <span class="text-horriver-orange font-medium"><%= periodLabel() %></span>
        </p>
        <p>
          Posicao:
          <span class="text-horriver-orange font-medium"><%= posLabel(selPos) %></span>
        </p>

      </div>
    </div>

    <form
      method="GET"
      action="/rankings"
      class="page-section"
    >
      <div class="page-section__inner">
        <div class="page-toolbar text-[11px] md:text-xs">
          <div class="flex flex-wrap gap-2">
            <span class="<%= accentPillClass %>">Filtro ativo</span>
            <span class="<%= pillClass %>"><strong class="text-horriver-orange font-semibold"><%= periodLabel() %></strong></span>
            <span class="<%= pillClass %>"><strong class="text-horriver-orange font-semibold"><%= posLabel(selPos) %></strong></span>
          </div>

          <div class="flex flex-wrap items-end gap-3">
            <div class="min-w-[120px]">
              <label class="block text-horriver-gray mb-1">Ano</label>
              <select
                name="year"
                class="w-full bg-horriver-dark border border-horriver-border rounded-xl px-3 py-2 text-horriver-light"
              >
                <option value="all" <%= selYear === "all" ? "selected" : "" %>>
                  Todos os anos
                </option>
                <% for (let y = currentYear; y >= 2025; y--) { %>
                  <option value="<%= y %>" <%= selYear === y ? "selected" : "" %>>
                    <%= y %>
                  </option>
                <% } %>
              </select>
            </div>

            <div class="min-w-[120px]">
              <label class="block text-horriver-gray mb-1">Mes</label>
              <select
                name="month"
                class="w-full bg-horriver-dark border border-horriver-border rounded-xl px-3 py-2 text-horriver-light"
              >
                <option value="0" <%= Number(selMonth) === 0 ? "selected" : "" %>>Todos</option>
                <% monthNames.forEach((mn, idx) => {
                     const mVal = idx + 1;
                %>
                  <option value="<%= mVal %>" <%= Number(selMonth) === mVal ? "selected" : "" %>>
                    <%= mn %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="min-w-[130px]">
              <label class="block text-horriver-gray mb-1">Posicao</label>
              <select
                name="position"
                class="w-full bg-horriver-dark border border-horriver-border rounded-xl px-3 py-2 text-horriver-light"
              >
                <% const posicoes = ["Todas", "Goleiro", "Zagueiro", "Meia", "Atacante"]; %>
                <% posicoes.forEach((pos) => {
                     const val = pos === "Todas" ? "all" : pos;
                %>
                  <option
                    value="<%= val %>"
                    <%= (selPos === val || (!selPos && val === "all")) ? "selected" : "" %>
                  >
                    <%= pos %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="flex items-center gap-2 md:pb-[1px]">
              <button
                type="submit"
                class="px-4 py-2 rounded-full bg-horriver-orange text-black font-semibold hover:bg-orange-500 transition"
              >
                Aplicar
              </button>
              <a
                href="/rankings"
                class="px-4 py-2 rounded-full border border-horriver-border text-horriver-light hover:border-horriver-orange hover:text-horriver-orange transition"
              >
                Limpar
              </a>
            </div>
          </div>
        </div>
      </div>
    </form>
  </header>

  <section class="quick-stats">
    <article class="quick-stat quick-stat--accent">
      <span class="quick-stat__label">
        Artilheiro do filtro
      </span>
      <strong class="quick-stat__value">
        <%= topGoal ? topGoal.goals || 0 : 0 %>
      </strong>
      <span class="quick-stat__sub text-horriver-light/90">
        <%= leaderName(topGoal) %>
      </span>
    </article>

    <article class="quick-stat">
      <span class="quick-stat__label">
        Lider em assistencias
      </span>
      <strong class="quick-stat__value">
        <%= topAssist ? topAssist.assists || 0 : 0 %>
      </strong>
      <span class="quick-stat__sub">
        <%= leaderName(topAssist) %>
      </span>
    </article>

    <article class="quick-stat">
      <span class="quick-stat__label">
        Melhor media
      </span>
      <strong class="quick-stat__value">
        <%= topRating ? fmtRating(topRating.rating) : "0,00" %>
      </strong>
      <span class="quick-stat__sub">
        <%= leaderName(topRating) %>
      </span>
    </article>

    <article class="quick-stat">
      <span class="quick-stat__label">
        Overall lider
      </span>
      <strong class="quick-stat__value">
        <%= topOverall ? topOverall.overallScore || 60 : 60 %>
      </strong>
      <span class="quick-stat__sub">
        <%= leaderName(topOverall) %>
      </span>
    </article>
  </section>

  <nav class="rk-jump-nav" aria-label="Ir para ranking" data-rk-jump-nav>
    <div class="rk-jump-nav__scroller">
      <a href="#ranking-gols" class="is-active">Gols</a>
      <a href="#ranking-assistencias">Assist.</a>
      <a href="#ranking-ga">G/A</a>
      <a href="#ranking-medias">Medias</a>
      <a href="#ranking-fotos">Fotos</a>
      <a href="#ranking-presencas">Presencas</a>
      <a href="#ranking-overall">Overall</a>
      <a href="#ranking-ultimos-10">10J</a>
      <a href="#ranking-semana">Semana</a>
      <a href="#ranking-mes">Mes</a>
    </div>
  </nav>

  <!-- VITORIAS POR COR -->
  <section class="space-y-6 mt-4">
    <h2 class="font-title text-2xl text-horriver-light">
      Vitorias por cor
    </h2>

    <div class="card-highlight rounded-3xl p-[1px]">
      <div class="card-inner p-4 md:p-5">
        <div class="flex items-center justify-between gap-3">
          <div>
            <h3 class="font-title text-lg text-horriver-light">
              Times vencedores por cor
            </h3>
            <p class="text-[11px] text-horriver-gray">
              Contagem das peladas filtradas com cor do time vencedor.
            </p>
          </div>
          <span
            class="badge-pulse inline-flex items-center px-3 py-1 rounded-full
                   bg-black/60 border border-horriver-red/70 text-[11px] text-horriver-orange"
          >
            Cores
          </span>
        </div>

        <div class="mt-4">
          <% if (!colorWins.length) { %>
            <div class="<%= emptyStateClass %>">
              <span class="<%= emptyEyebrowClass %>">Sem vitorias</span>
              <h3 class="mt-4 text-[1.05rem] font-bold text-horriver-light">Nenhuma cor venceu neste recorte</h3>
              <p class="mt-2 text-sm leading-relaxed text-horriver-gray/90">
                Ajuste o periodo ou a posicao para comparar outro intervalo.
              </p>
            </div>
          <% } else { %>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
              <% colorWins.forEach((row) => { %>
                <div class="rounded-2xl border px-3 py-3 text-center <%= colorBoxClass(row.name) %>">
                  <p class="text-[11px] uppercase tracking-[0.18em] text-horriver-gray">
                    <%= colorDisplayName(row.name) %>
                  </p>
                  <p class="text-2xl font-semibold text-horriver-light">
                    <%= row.count || 0 %>
                  </p>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </section>

  <!-- GRID DE RANKINGS PRINCIPAIS -->
  <section class="space-y-6">
    <!-- 1ª LINHA: GOLS + ASSISTS -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- ================= GOLS ================= -->
      <div id="ranking-gols" class="card-highlight rounded-3xl p-[1px] rk-anchor">
        <div class="card-inner p-4 md:p-5 flex flex-col h-full min-h-[380px]">
          <div class="flex items-center justify-between gap-3">
            <div>
              <h2 class="font-title text-lg text-horriver-light">Artilheiros</h2>
              <p class="text-[11px] text-horriver-gray mt-0.5">
                Quem mais balançou a rede.
              </p>
            </div>
            <span
              class="badge-pulse inline-flex items-center px-3 py-1 rounded-full
                     bg-black/60 border border-horriver-red/70 text-[11px] text-horriver-orange"
            >
              Gols
            </span>
          </div>

          <div class="mt-4 flex-1 overflow-hidden">
            <% if (!goals.length) { %>
              <p class="text-sm text-horriver-gray">
                Nenhum dado para este período.
              </p>
            <% } else { %>
              <%- renderRankingPodium(goals, [
                { label: "Gols", value: (row) => row.goals || 0 },
                { label: "Assist.", value: (row) => row.assists || 0 },
                { label: "G/A", value: (row) => (row.goals || 0) + (row.assists || 0) },
              ]) %>
              <div class="rk-scroll h-full overflow-y-auto" data-skeleton="list">
                <table class="table-sticky w-full text-[11px] rk-has-podium" data-rk-type="goals">
                  <thead class="bg-black/50 sticky top-0 z-10">
                    <tr>
                      <th class="text-left px-2 py-1">#</th>
                      <th class="text-left px-2 py-1">Jogador</th>
                      <th class="text-left px-2 py-1">Posição</th>
                      <th class="text-center px-2 py-1 text-horriver-orange">Gols</th>
                      <th class="text-center px-2 py-1">Assist.</th>
                      <th class="text-center px-2 py-1">Part. G/A</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% goals.forEach((row, idx) => { %>
                      <tr class="border-t border-horriver-border/40 <%= topRowClass(idx) %>">
                        <td class="px-2 py-1"><%= idx + 1 %></td>
                        <td class="px-2 py-1">
                          <%= row.player.name %>
                          <% if (row.player.nickname) { %>
                            (<%= row.player.nickname %>)
                          <% } %>
                        </td>
                        <td class="px-2 py-1 text-horriver-orange text-[10px]">
                          <%= row.player.position %>
                        </td>
                        <td class="px-2 py-1 text-center font-semibold text-horriver-orange">
                          <%= row.goals || 0 %>
                        </td>
                        <td class="px-2 py-1 text-center">
                          <%= row.assists || 0 %>
                        </td>
                        <td class="px-2 py-1 text-center">
                          <%= (row.goals || 0) + (row.assists || 0) %>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- ================= ASSISTÊNCIAS ================= -->
      <div id="ranking-assistencias" class="card-highlight rounded-3xl p-[1px] rk-anchor">
        <div class="card-inner p-4 md:p-5 flex flex-col h-full min-h-[380px]">
          <div class="flex items-center justify-between gap-3">
            <div>
              <h2 class="font-title text-lg text-horriver-light">Garçons</h2>
              <p class="text-[11px] text-horriver-gray mt-0.5">
                Quem mais serviu gols.
              </p>
            </div>
            <span
              class="badge-pulse inline-flex items-center px-3 py-1 rounded-full
                     bg-black/60 border border-horriver-red/70 text-[11px] text-horriver-orange"
            >
              Assist.
            </span>
          </div>

          <div class="mt-4 flex-1 overflow-hidden">
            <% if (!assists.length) { %>
              <p class="text-sm text-horriver-gray">
                Nenhum dado para este período.
              </p>
            <% } else { %>
              <%- renderRankingPodium(assists, [
                { label: "Assist.", value: (row) => row.assists || 0 },
                { label: "Gols", value: (row) => row.goals || 0 },
                { label: "G/A", value: (row) => (row.goals || 0) + (row.assists || 0) },
              ]) %>
              <div class="rk-scroll h-full overflow-y-auto" data-skeleton="list">
                <table class="table-sticky w-full text-[11px] rk-has-podium" data-rk-type="assists">
                  <thead class="bg-black/50 sticky top-0 z-10">
                    <tr>
                      <th class="text-left px-2 py-1">#</th>
                      <th class="text-left px-2 py-1">Jogador</th>
                      <th class="text-left px-2 py-1">Posição</th>
                      <th class="text-center px-2 py-1 text-horriver-orange">Assist.</th>
                      <th class="text-center px-2 py-1">Gols</th>
                      <th class="text-center px-2 py-1">Part. G/A</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% assists.forEach((row, idx) => { %>
                      <tr class="border-t border-horriver-border/40 <%= topRowClass(idx) %>">
                        <td class="px-2 py-1"><%= idx + 1 %></td>
                        <td class="px-2 py-1">
                          <%= row.player.name %>
                          <% if (row.player.nickname) { %>
                            (<%= row.player.nickname %>)
                          <% } %>
                        </td>
                        <td class="px-2 py-1 text-horriver-orange text-[10px]">
                          <%= row.player.position %>
                        </td>
                        <td class="px-2 py-1 text-center font-semibold text-horriver-orange">
                          <%= row.assists || 0 %>
                        </td>
                        <td class="px-2 py-1 text-center">
                          <%= row.goals || 0 %>
                        </td>
                        <td class="px-2 py-1 text-center">
                          <%= (row.goals || 0) + (row.assists || 0) %>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- 2ª LINHA: GA + MÉDIA DE NOTAS -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- ================= GOLS + ASSISTÊNCIAS ================= -->
      <div id="ranking-ga" class="card-highlight rounded-3xl p-[1px] rk-anchor">
        <div class="card-inner p-4 md:p-5 flex flex-col h-full min-h-[380px]">
          <div class="flex items-center justify-between gap-3">
            <div>
              <h2 class="font-title text-lg text-horriver-light">
                Participações em gol
              </h2>
              <p class="text-[11px] text-horriver-gray mt-0.5">
                Soma de gols + assistências.
              </p>
            </div>
            <span
              class="badge-pulse inline-flex items-center px-3 py-1 rounded-full
                     bg-black/60 border border-horriver-red/70 text-[11px] text-horriver-orange"
            >
              G + A
            </span>
          </div>

          <div class="mt-4 flex-1 overflow-hidden">
            <% if (!ga.length) { %>
              <p class="text-sm text-horriver-gray">
                Nenhum dado para este período.
              </p>
            <% } else { %>
              <%- renderRankingPodium(ga, [
                { label: "Total", value: (row) => (row.goals || 0) + (row.assists || 0) },
                { label: "Gols", value: (row) => row.goals || 0 },
                { label: "Assist.", value: (row) => row.assists || 0 },
              ]) %>
              <div class="rk-scroll h-full overflow-y-auto" data-skeleton="list">
                <table class="table-sticky w-full text-[11px] rk-has-podium" data-rk-type="ga">
                  <thead class="bg-black/50 sticky top-0 z-10">
                    <tr>
                      <th class="text-left px-2 py-1">#</th>
                      <th class="text-left px-2 py-1">Jogador</th>
                      <th class="text-left px-2 py-1">Posição</th>
                      <th class="text-center px-2 py-1">Gols</th>
                      <th class="text-center px-2 py-1">Assist.</th>
                      <th class="text-center px-2 py-1 text-horriver-orange">Total</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% ga.forEach((row, idx) => { %>
                      <tr class="border-t border-horriver-border/40 <%= topRowClass(idx) %>">
                        <td class="px-2 py-1"><%= idx + 1 %></td>
                        <td class="px-2 py-1">
                          <%= row.player.name %>
                          <% if (row.player.nickname) { %>
                            (<%= row.player.nickname %>)
                          <% } %>
                        </td>
                        <td class="px-2 py-1 text-horriver-orange text-[10px]">
                          <%= row.player.position %>
                        </td>
                        <td class="px-2 py-1 text-center">
                          <%= row.goals || 0 %>
                        </td>
                        <td class="px-2 py-1 text-center">
                          <%= row.assists || 0 %>
                        </td>
                        <td class="px-2 py-1 text-center font-semibold text-horriver-orange">
                          <%= (row.goals || 0) + (row.assists || 0) %>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- ================= NOTAS ================= -->
      <div id="ranking-medias" class="card-highlight rounded-3xl p-[1px] rk-anchor">
        <div class="card-inner p-4 md:p-5 flex flex-col h-full min-h-[380px]">
          <div class="flex items-center justify-between gap-3">
            <div>
              <h2 class="font-title text-lg text-horriver-light">
                Maiores médias de nota
              </h2>
              <p class="text-[11px] text-horriver-gray mt-0.5">
                Jogadores mais bem avaliados.
              </p>
            </div>
            <span
              class="badge-pulse inline-flex items-center px-3 py-1 rounded-full
                     bg-black/60 border border-horriver-red/70 text-[11px] text-horriver-orange"
            >
              Notas
            </span>
          </div>

          <div class="mt-4 flex-1 overflow-hidden">
            <% if (!ratings.length) { %>
              <p class="text-sm text-horriver-gray">
                Nenhum dado para este período.
              </p>
            <% } else { %>
              <%- renderRankingPodium(ratings, [
                { label: "Media", value: (row) => fmtRating(row.rating) },
                { label: "Pres.", value: (row) => row.matches || 0 },
                { label: "G/A", value: (row) => (row.goals || 0) + (row.assists || 0) },
              ]) %>
              <div class="rk-scroll h-full overflow-y-auto" data-skeleton="list">
                <table class="table-sticky w-full text-[11px] rk-has-podium" data-rk-type="ratings">
                  <thead class="bg-black/50 sticky top-0 z-10">
                    <tr>
                      <th class="text-left px-2 py-1">#</th>
                      <th class="text-left px-2 py-1">Jogador</th>
                      <th class="text-left px-2 py-1">Posição</th>
                      <th class="text-center px-2 py-1">Presenças</th>
                      <th class="text-center px-2 py-1 text-horriver-orange">Média</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% ratings.forEach((row, idx) => { %>
                      <tr class="border-t border-horriver-border/40 <%= topRowClass(idx) %>">
                        <td class="px-2 py-1"><%= idx + 1 %></td>
                        <td class="px-2 py-1">
                          <%= row.player.name %>
                          <% if (row.player.nickname) { %>
                            (<%= row.player.nickname %>)
                          <% } %>
                        </td>
                        <td class="px-2 py-1 text-horriver-orange text-[10px]">
                          <%= row.player.position %>
                        </td>
                        <td class="px-2 py-1 text-center">
                          <%= row.matches || 0 %>
                        </td>
                        <td class="px-2 py-1 text-center font-semibold text-horriver-orange">
                          <%= fmtRating(row.rating) %>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- 3ª LINHA: REI DAS FOTOS + REI DAS PRESENÇAS -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- ================= FOTOS ================= -->
      <div id="ranking-fotos" class="card-highlight rounded-3xl p-[1px] rk-anchor">
        <div class="card-inner p-4 md:p-5 flex flex-col h-full min-h-[380px]">
          <div class="flex items-center justify-between gap-3">
            <div>
              <h2 class="font-title text-lg text-horriver-light">
                Rei das fotos
              </h2>
              <p class="text-[11px] text-horriver-gray mt-0.5">
                Quem mais apareceu nos registros.
              </p>
            </div>
            <span
              class="badge-pulse inline-flex items-center px-3 py-1 rounded-full
                     bg-black/60 border border-horriver-red/70 text-[11px] text-horriver-orange"
            >
              Fotos
            </span>
          </div>

          <div class="mt-4 flex-1 overflow-hidden">
            <% if (!photos.length) { %>
              <p class="text-sm text-horriver-gray">
                Nenhum dado para este período.
              </p>
            <% } else { %>
              <%- renderRankingPodium(photos, [
                { label: "Fotos", value: (row) => row.photos || 0 },
                { label: "Gols", value: (row) => row.goals || 0 },
                { label: "Assist.", value: (row) => row.assists || 0 },
              ]) %>
              <div class="rk-scroll h-full overflow-y-auto" data-skeleton="list">
                <table class="table-sticky w-full text-[11px] rk-has-podium" data-rk-type="photos">
                  <thead class="bg-black/50 sticky top-0 z-10">
                    <tr>
                      <th class="text-left px-2 py-1">#</th>
                      <th class="text-left px-2 py-1">Jogador</th>
                      <th class="text-left px-2 py-1">Posição</th>
                      <th class="text-center px-2 py-1 text-horriver-orange">Fotos</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% photos.forEach((row, idx) => { %>
                      <tr class="border-t border-horriver-border/40 <%= topRowClass(idx) %>">
                        <td class="px-2 py-1"><%= idx + 1 %></td>
                        <td class="px-2 py-1">
                          <%= row.player.name %>
                          <% if (row.player.nickname) { %>
                            (<%= row.player.nickname %>)
                          <% } %>
                        </td>
                        <td class="px-2 py-1 text-horriver-orange text-[10px]">
                          <%= row.player.position %>
                        </td>
                        <td class="px-2 py-1 text-center font-semibold text-horriver-orange">
                          <%= row.photos || 0 %>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- ================= PRESENÇAS ================= -->
      <div id="ranking-presencas" class="card-highlight rounded-3xl p-[1px] rk-anchor">
        <div class="card-inner p-4 md:p-5 flex flex-col h-full min-h-[380px]">
