<script>
  (() => {
    const nav = document.querySelector("[data-rk-jump-nav]");
    if (!nav) return;

    const links = Array.from(nav.querySelectorAll('a[href^="#ranking-"]'));
    const sections = links
      .map((link) => document.querySelector(link.getAttribute("href")))
      .filter(Boolean);
    const scroller = nav.querySelector(".rk-jump-nav__scroller");
    let clickedTarget = null;
    let clickedTargetReached = false;

    const setActive = (id) => {
      links.forEach((link) => {
        const active = link.getAttribute("href") === `#${id}`;
        link.classList.toggle("is-active", active);
        if (active) {
          link.setAttribute("aria-current", "true");
          if (scroller) {
            link.scrollIntoView({
              behavior: "smooth",
              block: "nearest",
              inline: "center",
            });
          }
        } else {
          link.removeAttribute("aria-current");
        }
      });
    };

    links.forEach((link) => {
      link.addEventListener("click", (event) => {
        const target = document.querySelector(link.getAttribute("href"));
        if (!target) return;

        event.preventDefault();
        clickedTarget = target.id;
        clickedTargetReached = false;
        setActive(target.id);
        target.scrollIntoView({ behavior: "smooth", block: "start" });

        if (history.replaceState) {
          history.replaceState(null, "", `#${target.id}`);
        }

      });
    });

    const getCurrentSection = () => {
      const marker = Math.max(150, Math.round(window.innerHeight * 0.24));
      let current = sections[0];

      sections.forEach((section) => {
        const rect = section.getBoundingClientRect();
        if (rect.top <= marker) {
          current = section;
        }
      });

      return current;
    };

    const updateFromScroll = () => {
      const marker = Math.max(150, Math.round(window.innerHeight * 0.24));
      if (clickedTarget) {
        const clickedSection = document.getElementById(clickedTarget);
        if (clickedSection) {
          const rect = clickedSection.getBoundingClientRect();
          if (rect.top <= marker && rect.bottom > marker) {
            clickedTargetReached = true;
            setActive(clickedTarget);
            return;
          }
          if (!clickedTargetReached) return;
        }
        clickedTarget = null;
        clickedTargetReached = false;
      }
      const current = getCurrentSection();
      if (current) setActive(current.id);
    };

    updateFromScroll();
    window.addEventListener("scroll", updateFromScroll, { passive: true });
    window.addEventListener("resize", updateFromScroll);
  })();
</script>
