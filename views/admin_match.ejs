            isGuest: li.dataset.playerGuest === "true",
          });

          const teamsForShare = Array.from(resultsEl.querySelectorAll("[data-team]")).map((box, idx) => {
            const rawName = box.querySelector("[data-team-name]")?.textContent?.trim() || `Time ${idx + 1}`;
            const selectEl = box.querySelector("[data-color-select]");
            const color =
              selectEl?.value ||
              box.getAttribute("data-team-color") ||
              box.querySelector("[data-color-indicator]")?.style?.backgroundColor ||
              "#f97316";
            const players = Array.from(box.querySelectorAll("li")).map(readPlayerFromListItem);
            const nomeCor =
              box.getAttribute("data-team-color-name") ||
              selectEl?.selectedOptions?.[0]?.text ||
              rawName;
            const sponsorName = sponsorNameByLabelClient[nomeCor] || rawName;
            const displayName = sponsorName || rawName;
            const colorName =
              normalizeExportColorLabel(nomeCor) ||
              normalizeExportColorLabel(color) ||
              normalizeExportColorLabel(displayName) ||
              "Vermelho";
            return { name: displayName, color, colorName, players };
          });

          const goalkeepersForShare = Array.from(goalkeeperBenchBox?.querySelectorAll("li") || []).map(
            readPlayerFromListItem
          );

          const getLuminance = (hex) => {
            if (!hex || !hex.startsWith("#") || hex.length < 7) return 0.5;
            const r = parseInt(hex.slice(1, 3), 16) / 255;
            const g = parseInt(hex.slice(3, 5), 16) / 255;
            const b = parseInt(hex.slice(5, 7), 16) / 255;
            const lin = (c) => (c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4));
            return 0.2126 * lin(r) + 0.7152 * lin(g) + 0.0722 * lin(b);
          };

          const escapeHtml = (value = "") =>
            String(value)
              .replace(/&/g, "&amp;")
              .replace(/</g, "&lt;")
              .replace(/>/g, "&gt;")
              .replace(/"/g, "&quot;")
              .replace(/'/g, "&#39;");

          const positionBadge = (pos = "") => {
            const raw = String(pos || "").toUpperCase();
            const key = raw.includes("GOL")
              ? "GOL"
              : raw.includes("ZAG") || raw.includes("DEF")
                ? "ZAG"
                : raw.includes("MEI")
                  ? "MEI"
                  : raw.includes("VOL")
                    ? "VOL"
                    : raw.includes("ATA")
                      ? "ATA"
                      : raw.slice(0, 3);
            const colorsByKey = {
              ATA: { bg: "rgba(239, 68, 68, 0.16)", border: "rgba(239, 68, 68, 0.45)", text: "#fca5a5" },
              MEI: { bg: "rgba(59, 130, 246, 0.16)", border: "rgba(59, 130, 246, 0.45)", text: "#93c5fd" },
              VOL: { bg: "rgba(20, 184, 166, 0.16)", border: "rgba(20, 184, 166, 0.45)", text: "#99f6e4" },
              ZAG: { bg: "rgba(34, 197, 94, 0.16)", border: "rgba(34, 197, 94, 0.45)", text: "#86efac" },
              GOL: { bg: "rgba(250, 204, 21, 0.18)", border: "rgba(250, 204, 21, 0.45)", text: "#fde68a" },
            };
            return {
              label: key || raw || "---",
              ...(colorsByKey[key] || { bg: "rgba(148, 163, 184, 0.14)", border: "rgba(148, 163, 184, 0.35)", text: "#cbd5e1" }),
            };
          };

          const positionGroupKey = (pos = "") => {
            const label = positionBadge(pos).label;
            if (label === "VOL") return "MEI";
            return label;
          };

          const positionRank = (pos = "") => {
            const key = positionGroupKey(pos);
            return ({
              GOL: 0,
              ZAG: 1,
              MEI: 2,
              ATA: 3,
            })[key] ?? 4;
          };

          const sortedPlayersForShare = (players = []) =>
            [...players].sort((a, b) => {
              const rankDiff = positionRank(a.pos) - positionRank(b.pos);
              if (rankDiff !== 0) return rankDiff;
              const aLabel = getPlayerIdentity({ name: a.nome, nickname: a.nickname }).primary;
              const bLabel = getPlayerIdentity({ name: b.nome, nickname: b.nickname }).primary;
              return String(aLabel || a.nome || "").localeCompare(String(bLabel || b.nome || ""), "pt-BR");
            });

          const teamVisualTheme = (team) => {
