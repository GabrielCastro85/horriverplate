                countText: "rgba(255,255,255,0.92)",
                rankText: "#f3f4f6",
              },
            };
            return themeByKey[key] || themeByKey.Vermelho;
          };

          const buildBalancedTitleLines = (value = "") => {
            const clean = String(value || "").replace(/\s+/g, " ").trim();
            if (!clean) return ["Time sem nome"];
            const words = clean.split(" ");
            if (words.length === 1) return [clean];

            let best = null;
            for (let i = 1; i < words.length; i += 1) {
              const lines = [words.slice(0, i).join(" "), words.slice(i).join(" ")];
              const lengths = lines.map((line) => line.length);
              const longest = Math.max(...lengths);
              const diff = Math.abs(lengths[0] - lengths[1]);
              const score = diff * 2 + longest;
              if (!best || score < best.score) {
                best = { lines, longest, score };
              }
            }

            return best?.lines || [clean];
          };

          const teamTitleLayouts = (() => {
