<script>
  <% const currentFinanceView = (typeof financeView !== "undefined" && financeView) || locals.financeView; %>
  window.ADMIN_FINANCE_CONFIG = Object.freeze({
    categoryMap: <%- JSON.stringify(currentFinanceView.cash.categoryOptions) %>,
    participantTypeMeta: <%- JSON.stringify(currentFinanceView.settings.participantTypeMetaMap) %>,
    defaultMonthlyAmount: <%- JSON.stringify(Number(currentFinanceView.settings.values.defaultMonthlyAmount || 0)) %>,
    latePerMatchAmount: <%- JSON.stringify(Number(currentFinanceView.settings.values.latePerMatchAmount || 25)) %>,
  });
</script>
<script src="/js/admin-finance.js?v=<%= assetVersion %>" defer></script>
