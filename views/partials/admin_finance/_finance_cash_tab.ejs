<%
  const currentFinanceView =
    (typeof financeView !== "undefined" && financeView) || locals.financeView;
  const {
    cash,
    summaries: summary,
    filters,
    ui,
    helpers,
    actions,
  } = currentFinanceView;
  const monthTransactions = cash.transactions;
  const selectedTransaction = cash.selectedTransaction;
  const recurringExpenses = cash.recurringExpenses || {};
  const recurringRules = Array.isArray(recurringExpenses.rules) ? recurringExpenses.rules : [];
  const selectedRecurringExpense = recurringExpenses.selectedRecurringExpense || null;
  const transactionTypeOptions = cash.typeOptions;
  const expenseCategoryOptions = cash.categoryOptions.EXPENSE || [];
  const monthOptions = currentFinanceView.navigation.monthOptions || [];
  const yearOptions = currentFinanceView.navigation.yearOptions || [];
  const { selectedTransactionCategories, selectedTransactionIsManual, currentDateInputValue } = ui;
  const {
    formatCurrencyBR,
    formatDateBR,
    decimalToNumber,
    formatDateInput,
    getTransactionCategoryLabel,
  } = helpers;
  const { stateFields, buildFinanceQuery } = actions;
%>

<section class="finance-tab-panel" id="finance-cash">
  <section class="finance-module-top">
    <article class="finance-panel p-5 md:p-6 finance-module-top__lead">
      <%- include("./_finance_section_intro", {
        sectionChipLabel: "Caixa",
        sectionChipTone: "accent",
        sectionBadges: [
          { label: `${monthTransactions.length} lançamento(s)` },
          { label: `${formatCurrencyBR(summary.totalReceivedMonth)} em entradas` },
          { label: `${formatCurrencyBR(summary.totalExpensesMonth)} em saídas` },
        ],
        sectionTitle: "Extrato do período",
        sectionDescription: "A leitura do caixa agora abre com contexto, resumo curto e o extrato como protagonista, enquanto o formulario manual fica ao lado como ferramenta de apoio.",
      }) %>
    </article>

    <form method="GET" action="/admin/finance" class="finance-module-aside-card">
      <div class="space-y-3">
        <div class="finance-kicker">Filtro do extrato</div>
        <div class="text-2xl font-semibold text-horriver-light">Movimentações do recorte</div>
        <p class="finance-subtle">
          Filtre rapidamente o extrato por entradas ou saídas sem sair da competência atual.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div class="finance-dashboard-mini-stat">
          <span>Entradas</span>
          <strong><%= formatCurrencyBR(summary.totalReceivedMonth) %></strong>
        </div>
        <div class="finance-dashboard-mini-stat">
          <span>Saídas</span>
          <strong><%= formatCurrencyBR(summary.totalExpensesMonth) %></strong>
        </div>
      </div>

      <div class="space-y-3">
        <%- stateFields({ tab: 'cash' }, { omit: ["cashType"] }) %>
        <label class="finance-label">Tipo de movimentação
          <select name="cashType" class="finance-select">
            <option value="ALL" <%= filters.cashType === "ALL" ? "selected" : "" %>>Todas</option>
            <option value="INCOME" <%= filters.cashType === "INCOME" ? "selected" : "" %>>Entradas</option>
            <option value="EXPENSE" <%= filters.cashType === "EXPENSE" ? "selected" : "" %>>Saídas</option>
          </select>
        </label>
        <div class="flex flex-wrap gap-2">
          <button type="submit" class="finance-soft-button">Filtrar extrato</button>
          <a href="<%= buildFinanceQuery({ tab: 'cash', cashType: 'ALL' }) %>" class="finance-soft-button">Limpar</a>
        </div>
      </div>
    </form>
  </section>

  <section class="finance-module-metric-strip">
    <article class="finance-module-mini-card">
      <span class="finance-kicker">Caixa atual</span>
      <strong><%= formatCurrencyBR(summary.cashBalance) %></strong>
      <span class="finance-subtle">Saldo consolidado do módulo.</span>
    </article>
    <article class="finance-module-mini-card">
      <span class="finance-kicker">Resultado do mês</span>
      <strong><%= formatCurrencyBR(summary.currentMonthNet) %></strong>
      <span class="finance-subtle">Entradas menos saídas no período.</span>
    </article>
    <article class="finance-module-mini-card finance-module-mini-card--accent">
      <span class="finance-kicker">Entradas automaticas</span>
      <strong><%= formatCurrencyBR(summary.automaticIncomeTotal) %></strong>
      <span class="finance-subtle">Mensalidades e convidados alimentando o caixa.</span>
    </article>
    <article class="finance-module-mini-card">
      <span class="finance-kicker">Lançamentos</span>
      <strong><%= monthTransactions.length %></strong>
      <span class="finance-subtle">Registros visiveis no recorte.</span>
    </article>
  </section>

  <section class="finance-panel p-5 md:p-6 space-y-5" id="finance-recurring">
    <div class="finance-panel-section-head">
      <div class="finance-panel-section-head__copy">
        <div class="finance-kicker">Despesas fixas</div>
        <h3 class="font-title text-xl text-horriver-light mt-2">Aluguel da quadra e recorrências</h3>
        <p class="finance-subtle mt-2">
          Cadastre uma vez e o sistema lança automaticamente a saída no caixa de cada competência, sem duplicar.
        </p>
      </div>
      <div class="finance-panel-section-head__actions">
        <span class="finance-chip"><%= recurringExpenses.activeCount || 0 %> ativa(s)</span>
        <span class="finance-chip"><%= recurringExpenses.generatedThisMonthCount || 0 %> gerada(s) no mês</span>
      </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-[0.9fr_1.3fr] gap-4">
      <form
        method="POST"
        action="<%= selectedRecurringExpense ? `/admin/finance/recurring-expenses/${selectedRecurringExpense.id}/update` : '/admin/finance/recurring-expenses' %>"
        class="finance-panel p-4 space-y-3 bg-black/10"
      >
        <%- stateFields(selectedRecurringExpense ? { tab: 'cash', editRecurringExpenseId: selectedRecurringExpense.id } : { tab: 'cash' }) %>
        <div class="flex items-center justify-between gap-3">
          <div>
            <div class="finance-kicker"><%= selectedRecurringExpense ? 'Editar regra' : 'Nova regra mensal' %></div>
            <div class="text-lg font-semibold text-horriver-light"><%= selectedRecurringExpense ? selectedRecurringExpense.name : 'Despesa fixa mensal' %></div>
          </div>
          <% if (selectedRecurringExpense) { %>
            <a href="<%= buildFinanceQuery({ tab: 'cash' }) %>#finance-recurring" class="finance-chip">Nova</a>
          <% } %>
        </div>

        <label class="finance-label">Nome
          <input type="text" name="name" value="<%= selectedRecurringExpense?.name || 'Aluguel da quadra' %>" class="finance-input" placeholder="Ex.: Aluguel da quadra">
        </label>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <label class="finance-label">Valor mensal
            <input type="text" name="amount" value="<%= selectedRecurringExpense ? decimalToNumber(selectedRecurringExpense.amount).toFixed(2).replace('.', ',') : '' %>" class="finance-input" placeholder="0,00">
          </label>
          <label class="finance-label">Dia do lançamento
            <input type="number" min="1" max="31" name="dayOfMonth" value="<%= selectedRecurringExpense?.dayOfMonth || 1 %>" class="finance-input">
          </label>
        </div>

        <label class="finance-label">Categoria
          <select name="category" class="finance-select">
            <% expenseCategoryOptions.forEach((option) => { %>
              <option value="<%= option.value %>" <%= (selectedRecurringExpense?.category || 'COURT') === option.value ? 'selected' : '' %>><%= option.label %></option>
            <% }) %>
          </select>
        </label>

        <div class="grid grid-cols-2 gap-3">
          <label class="finance-label">Início mês
            <select name="startMonth" class="finance-select">
              <% monthOptions.forEach((option) => { %>
                <option value="<%= option.value %>" <%= (selectedRecurringExpense?.startMonth || filters.month) === option.value ? 'selected' : '' %>><%= option.label %></option>
              <% }) %>
            </select>
          </label>
          <label class="finance-label">Início ano
            <select name="startYear" class="finance-select">
              <% yearOptions.forEach((option) => { %>
                <option value="<%= option %>" <%= (selectedRecurringExpense?.startYear || filters.year) === option ? 'selected' : '' %>><%= option %></option>
              <% }) %>
            </select>
          </label>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <label class="finance-label">Fim mês
            <select name="endMonth" class="finance-select">
              <option value="">Sem fim</option>
              <% monthOptions.forEach((option) => { %>
                <option value="<%= option.value %>" <%= selectedRecurringExpense?.endMonth === option.value ? 'selected' : '' %>><%= option.label %></option>
              <% }) %>
            </select>
          </label>
          <label class="finance-label">Fim ano
            <select name="endYear" class="finance-select">
              <option value="">Sem fim</option>
              <% yearOptions.forEach((option) => { %>
                <option value="<%= option %>" <%= selectedRecurringExpense?.endYear === option ? 'selected' : '' %>><%= option %></option>
              <% }) %>
            </select>
          </label>
        </div>

        <label class="finance-label">Descrição no caixa
          <input type="text" name="description" value="<%= selectedRecurringExpense?.description || 'Aluguel da quadra' %>" class="finance-input" placeholder="Ex.: Aluguel da quadra">
        </label>

        <label class="finance-label">Observação
          <textarea name="note" class="finance-textarea" placeholder="Opcional: contrato, local ou referência do pagamento."><%= selectedRecurringExpense?.note || '' %></textarea>
        </label>

        <label class="inline-flex items-center gap-2 text-sm text-horriver-muted">
          <input type="checkbox" name="isActive" class="accent-horriver-orange" <%= selectedRecurringExpense?.isActive === false ? '' : 'checked' %>>
          Regra ativa
        </label>

        <div class="flex items-center justify-between gap-3">
          <% if (selectedRecurringExpense) { %>
            <button
              type="submit"
              form="delete-recurring-expense-<%= selectedRecurringExpense.id %>"
              class="finance-soft-button text-red-200 border-red-400/35 hover:border-red-300 hover:text-white"
              data-confirm="Excluir esta despesa fixa e todos os lançamentos automáticos já gerados por ela?"
            >
              Excluir
            </button>
          <% } else { %>
            <span class="finance-subtle">Ao salvar, se a regra valer para este mês, o débito entra no caixa automaticamente.</span>
          <% } %>
          <button type="submit" class="finance-cta"><%= selectedRecurringExpense ? 'Salvar regra' : 'Criar despesa fixa' %></button>
        </div>
      </form>

      <% if (selectedRecurringExpense) { %>
        <form id="delete-recurring-expense-<%= selectedRecurringExpense.id %>" method="POST" action="/admin/finance/recurring-expenses/<%= selectedRecurringExpense.id %>/delete" class="hidden">
          <%- stateFields({ tab: 'cash' }) %>
        </form>
      <% } %>

      <div class="finance-panel p-4 space-y-3 bg-black/10">
        <div class="flex items-center justify-between gap-3">
          <div>
            <div class="finance-kicker">Regras cadastradas</div>
            <div class="text-lg font-semibold text-horriver-light">Controle mensal automático</div>
          </div>
          <% if (recurringExpenses.pendingThisMonthCount) { %>
            <span class="finance-status finance-status--warning"><%= recurringExpenses.pendingThisMonthCount %> pendente(s)</span>
          <% } else { %>
            <span class="finance-status finance-status--ok">Mês em dia</span>
          <% } %>
        </div>

        <% if (recurringRules.length) { %>
          <div class="space-y-3">
            <% recurringRules.forEach((rule) => { %>
              <article class="finance-list-item">
                <div class="finance-list-item__body">
                  <div class="finance-list-item__title"><%= rule.name %></div>
                  <div class="finance-list-item__text">
                    <%= rule.amountLabel %> - <%= rule.categoryLabel %> - dia <%= rule.dayOfMonth %>
                  </div>
                  <div class="flex flex-wrap gap-2 mt-2">
                    <span class="finance-chip"><%= rule.isActive ? 'Ativa' : 'Pausada' %></span>
                    <span class="finance-chip">Último: <%= rule.latestRunLabel %></span>
                    <% if (rule.currentGenerated) { %>
                      <span class="finance-chip">Gerada em <%= rule.currentTransactionDateLabel %></span>
                    <% } else if (rule.applicableThisMonth) { %>
                      <span class="finance-chip">Pendente neste mês</span>
                    <% } else { %>
                      <span class="finance-chip">Fora deste mês</span>
                    <% } %>
                  </div>
                </div>
                <div class="finance-list-item__side">
                  <a href="<%= buildFinanceQuery({ tab: 'cash', editRecurringExpenseId: rule.id }) %>#finance-recurring" class="finance-soft-button text-xs">Editar</a>
                  <form method="POST" action="/admin/finance/recurring-expenses/<%= rule.id %>/generate" class="contents">
                    <%- stateFields({ tab: 'cash' }) %>
                    <button type="submit" class="finance-soft-button text-xs" <%= rule.currentGenerated || !rule.applicableThisMonth ? 'disabled' : '' %>>Gerar agora</button>
                  </form>
                  <form method="POST" action="/admin/finance/recurring-expenses/<%= rule.id %>/toggle" class="contents">
                    <%- stateFields({ tab: 'cash' }) %>
                    <button type="submit" class="finance-soft-button text-xs"><%= rule.isActive ? 'Pausar' : 'Ativar' %></button>
                  </form>
                </div>
              </article>
            <% }) %>
          </div>
        <% } else { %>
          <%- include("./_finance_empty_state", {
            emptyStateMessage: "Nenhuma despesa fixa cadastrada. Crie a regra do aluguel da quadra para o débito cair sozinho no caixa todo mês.",
          }) %>
        <% } %>
      </div>
    </div>
  </section>

  <section class="finance-cash-grid">
    <div class="finance-panel p-5 space-y-4">
      <div class="flex items-center justify-between gap-3">
        <div>
          <div class="finance-kicker">Lançamento manual</div>
          <h3 class="font-title text-xl text-horriver-light"><%= selectedTransaction ? 'Editar lancamento manual' : 'Novo lançamento manual' %></h3>
          <p class="finance-subtle">Use esta área para entradas extras e saídas operacionais, como quadra, bola, bebida ou acertos fora da mensalidade.</p>
        </div>
        <% if (selectedTransaction) { %><a href="<%= buildFinanceQuery({ tab: 'cash' }) %>#finance-cash" class="finance-chip">Novo</a><% } %>
      </div>

      <% if (selectedTransaction && !selectedTransactionIsManual) { %>
        <%- include("./_finance_empty_state", {
          emptyStateMessage: "Esse lançamento foi gerado automaticamente por uma mensalidade ou convidado. Para alterar, edite o registro na origem correspondente.",
        }) %>
      <% } else { %>
        <form method="POST" action="<%= selectedTransaction ? `/admin/finance/cash-transactions/${selectedTransaction.id}/update` : '/admin/finance/cash-transactions' %>" class="grid grid-cols-1 gap-3" data-finance-category-form>
          <%- stateFields(selectedTransaction ? { tab: 'cash', editTransactionId: selectedTransaction.id } : { tab: 'cash' }) %>
          <label class="finance-label">Tipo
            <select name="type" class="finance-select" data-finance-type>
              <% transactionTypeOptions.forEach((option) => { %><option value="<%= option.value %>" <%= (selectedTransaction?.type || 'EXPENSE') === option.value ? 'selected' : '' %>><%= option.label %></option><% }) %>
            </select>
          </label>
          <label class="finance-label">Categoria
            <select name="category" class="finance-select" data-finance-category>
              <% selectedTransactionCategories.forEach((option) => { %><option value="<%= option.value %>" <%= selectedTransaction?.category === option.value ? 'selected' : '' %>><%= option.label %></option><% }) %>
            </select>
          </label>
          <label class="finance-label">Valor<input type="text" name="amount" value="<%= selectedTransaction ? decimalToNumber(selectedTransaction.amount).toFixed(2).replace('.', ',') : '' %>" class="finance-input" placeholder="0,00"></label>
          <label class="finance-label">Data<input type="date" name="date" value="<%= selectedTransaction ? formatDateInput(selectedTransaction.date) : currentDateInputValue %>" class="finance-input"></label>
          <label class="finance-label">Descricao<input type="text" name="description" value="<%= selectedTransaction?.description || '' %>" class="finance-input" placeholder="Ex.: Quadra de abril"></label>
          <label class="finance-label">Observação<textarea name="note" class="finance-textarea" placeholder="Opcional: detalhe util para auditoria futura."><%= selectedTransaction?.note || '' %></textarea></label>
          <div class="flex items-center justify-between gap-3">
            <% if (selectedTransaction) { %>
              <button
                type="submit"
                form="delete-cash-<%= selectedTransaction.id %>"
                class="finance-soft-button text-red-200 border-red-400/35 hover:border-red-300 hover:text-white"
                data-confirm="Excluir este lançamento manual do extrato?"
              >
                Excluir lançamento
              </button>
            <% } else { %>
              <span class="finance-subtle">Mensalidades e convidados ja alimentam o caixa automaticamente; aqui entram apenas lançamentos extras.</span>
            <% } %>
            <button type="submit" class="finance-cta"><%= selectedTransaction ? 'Salvar alterações' : 'Registrar lançamento' %></button>
          </div>
        </form>
        <% if (selectedTransaction) { %><form id="delete-cash-<%= selectedTransaction.id %>" method="POST" action="/admin/finance/cash-transactions/<%= selectedTransaction.id %>/delete" class="hidden"><%- stateFields({ tab: 'cash' }) %></form><% } %>
      <% } %>
    </div>

    <div class="finance-panel p-5 md:p-6 space-y-4">
      <div class="finance-panel-section-head">
        <div class="finance-panel-section-head__copy">
          <div class="finance-kicker">Extrato financeiro</div>
          <h3 class="font-title text-xl text-horriver-light mt-2">Leitura completa do período</h3>
        </div>
        <div class="finance-panel-section-head__actions">
          <span class="finance-chip"><%= filters.cashType === "ALL" ? "Tudo" : filters.cashType === "INCOME" ? "Entradas" : "Saídas" %></span>
          <span class="finance-chip"><%= monthTransactions.length %> linha(s)</span>
        </div>
      </div>

      <% if (monthTransactions.length) { %>
        <div class="finance-scroll finance-scroll--desktop-fit">
          <table class="finance-table finance-table--fixed finance-table--compact finance-table--cash w-full">
            <colgroup>
              <col style="width:12%">
              <col style="width:12%">
              <col style="width:12%">
              <col style="width:24%">
              <col style="width:18%">
              <col style="width:10%">
              <col style="width:12%">
            </colgroup>
            <thead>
              <tr>
                <th>Data</th>
                <th>Tipo</th>
                <th>Categoria</th>
                <th>Descricao</th>
                <th>Origem</th>
                <th class="finance-table__numeric--header">Valor</th>
                <th class="finance-table__numeric--header">Ações</th>
              </tr>
            </thead>
            <tbody>
              <% monthTransactions.forEach((transaction) => { %>
                <tr>
                  <td class="finance-table__date"><%= formatDateBR(transaction.date) %></td>
                  <td class="finance-table__status"><span class="finance-status <%= transaction.type === 'INCOME' ? 'finance-status--ok' : 'finance-status--warning' %>"><%= transaction.type === 'INCOME' ? 'Entrada' : 'Saída' %></span></td>
                  <td class="finance-table__cell"><span class="finance-table__subtitle"><%= getTransactionCategoryLabel(transaction.category) %></span></td>
                  <td class="finance-table__cell">
                    <div class="finance-table__stack">
                      <span class="finance-table__title"><%= transaction.description %></span>
                      <% if (transaction.note) { %><span class="finance-table__subtitle"><%= transaction.note %></span><% } %>
                    </div>
                  </td>
                  <td class="finance-table__cell"><span class="finance-table__subtitle"><%= transaction.originLabel %></span></td>
                  <td class="finance-table__numeric <%= transaction.type === 'INCOME' ? 'finance-balance--ok' : 'text-[#fecaca]' %> font-semibold"><%= formatCurrencyBR(transaction.amount) %></td>
                  <td class="finance-table__action">
                    <% if (transaction.origin === 'MANUAL') { %>
                      <div class="flex flex-col items-end gap-2">
                        <a href="<%= buildFinanceQuery({ tab: 'cash', editTransactionId: transaction.id }) %>#finance-cash" class="finance-soft-button text-xs">Editar</a>
                        <button
                          type="submit"
                          form="delete-cash-row-<%= transaction.id %>"
                          class="finance-soft-button text-xs text-red-200 border-red-400/35 hover:border-red-300 hover:text-white"
                          data-confirm="Excluir este lançamento do extrato?"
                        >
                          Excluir
                        </button>
                      </div>
                      <form id="delete-cash-row-<%= transaction.id %>" method="POST" action="/admin/finance/cash-transactions/<%= transaction.id %>/delete" class="hidden">
                        <%- stateFields({ tab: 'cash', cashType: filters.cashType }) %>
                      </form>
                    <% } else { %>
                      <div class="flex flex-col items-end gap-2">
                        <span class="finance-chip">Auto</span>
                        <span class="finance-table__subtitle text-right">Edite na origem</span>
                      </div>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <%- include("./_finance_empty_state", {
          emptyStateMessage: "Nenhum lançamento foi encontrado para esse recorte. Assim que houver pagamentos, convidados ou despesas, o extrato aparece aqui.",
        }) %>
      <% } %>
    </div>
  </section>
</section>
