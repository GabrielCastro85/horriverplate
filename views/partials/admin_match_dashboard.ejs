<%
  const presentPlayerIdSet = new Set(
    (stats || []).filter((stat) => stat.present).map((stat) => stat.playerId)
  );
  const playersForStats = players.filter((player) => presentPlayerIdSet.has(player.id));
  const hasSelectedPlayers = playersForStats.length > 0;
  const statByPlayerId = new Map((stats || []).map((stat) => [stat.playerId, stat]));
  const colorThemeByName = {
    Amarelo: { dot: "#facc15", soft: "rgba(250,204,21,0.12)", border: "rgba(250,204,21,0.42)" },
    Azul: { dot: "#3b82f6", soft: "rgba(59,130,246,0.13)", border: "rgba(59,130,246,0.42)" },
    Preto: { dot: "#e5e7eb", soft: "rgba(229,231,235,0.08)", border: "rgba(229,231,235,0.28)" },
    Vermelho: { dot: "#ef4444", soft: "rgba(239,68,68,0.13)", border: "rgba(239,68,68,0.42)" },
    Branco: { dot: "#f8fafc", soft: "rgba(248,250,252,0.08)", border: "rgba(248,250,252,0.28)" },
    Laranja: { dot: "#ff7a1a", soft: "rgba(255,122,26,0.14)", border: "rgba(255,122,26,0.48)" },
  };
  const normalizeTeamColor = (team, idx = 0) => {
    const raw = String(team?.colorName || team?.name || "").toLowerCase();
    if (raw.includes("amarelo")) return "Amarelo";
    if (raw.includes("azul")) return "Azul";
    if (raw.includes("preto")) return "Preto";
    if (raw.includes("vermelho")) return "Vermelho";
    if (raw.includes("branco")) return "Branco";
    return ["Amarelo", "Azul", "Preto", "Vermelho"][idx % 4];
  };
  const positionRank = (position = "") => {
    const value = String(position).toLowerCase();
    if (value.includes("gol")) return 0;
    if (value.includes("zag")) return 1;
    if (value.includes("vol") || value.includes("mei")) return 2;
    if (value.includes("ata")) return 3;
    return 4;
  };
  const playerById = new Map(players.map((player) => [String(player.id), player]));
  let lineupTeamsForStats =
    lineupData && Array.isArray(lineupData.teams) && lineupData.teams.length
      ? lineupData.teams.map((team, idx) => {
          const colorName = normalizeTeamColor(team, idx);
          const theme = colorThemeByName[colorName] || colorThemeByName.Vermelho;
          const teamPlayers = (Array.isArray(team.players) ? team.players : [])
            .filter((entry) => !entry.guest && playerById.has(String(entry.id)))
            .map((entry) => playerById.get(String(entry.id)))
            .filter((player) => presentPlayerIdSet.has(player.id))
            .sort((a, b) => positionRank(a.position) - positionRank(b.position) || a.name.localeCompare(b.name, "pt-BR"));
          return {
            name: team.name || `Time ${colorName}`,
            colorName,
            theme,
            players: teamPlayers,
            isAdjustmentGroup: false,
          };
        }).filter((team) => team.players.length)
      : [{
          name: "Jogadores presentes",
          colorName: "Rodada",
          theme: colorThemeByName.Vermelho,
          players: [...playersForStats].sort((a, b) => positionRank(a.position) - positionRank(b.position) || a.name.localeCompare(b.name, "pt-BR")),
          isAdjustmentGroup: false,
        }];
  if (lineupData && Array.isArray(lineupData.teams) && lineupData.teams.length) {
    const includedIds = new Set();
    lineupTeamsForStats.forEach((team) => {
      team.players.forEach((player) => includedIds.add(player.id));
    });
    const missingPlayers = playersForStats
      .filter((player) => !includedIds.has(player.id))
      .sort((a, b) => positionRank(a.position) - positionRank(b.position) || a.name.localeCompare(b.name, "pt-BR"));
    if (missingPlayers.length) {
      lineupTeamsForStats.push({
        name: "Goleiros",
        colorName: "Laranja",
        theme: colorThemeByName.Laranja,
        players: missingPlayers,
        isAdjustmentGroup: true,
      });
    }
  }
%>
<section class="admin-panel rounded-[30px] p-5 md:p-7 space-y-6">
  <div class="flex flex-col xl:flex-row xl:items-start xl:justify-between gap-5">
    <div class="max-w-3xl space-y-3">
      <span class="admin-kicker">Central da rodada</span>
      <div class="space-y-2">
        <h1 class="text-2xl md:text-3xl font-semibold tracking-tight text-horriver-light">
          Estatisticas da pelada
        </h1>
        <p class="text-sm md:text-base text-horriver-gray">
          Data:
          <span class="text-horriver-orange font-medium"><%= matchDateLabel %></span>
          <% if (match.description) { %>
            &middot; <%= match.description %>
          <% } %>
        </p>
        <p class="text-sm text-horriver-gray/90 max-w-2xl">
          Primeiro feche a lista de presentes da rodada, depois lance os numeros,
          sorteie os times e finalize a votacao com menos ruído na tela.
        </p>
      </div>
    </div>

    <div class="flex flex-col sm:items-end gap-3">
      <div class="flex flex-wrap gap-2 sm:justify-end text-[11px]">
        <span class="px-3 py-1.5 rounded-full border border-horriver-border text-horriver-light">
          Rodada #<%= match.id %>
        </span>
        <span class="px-3 py-1.5 rounded-full border border-horriver-border text-horriver-light">
          <%= presentPlayersCount %>/<%= players.length %> presentes
        </span>
        <span class="px-3 py-1.5 rounded-full border <%= voteTokensTotal ? 'border-horriver-orange/40 text-horriver-orange' : 'border-horriver-border text-horriver-gray' %>">
          <%= voteTokensTotal ? `${voteTokensUsed}/${voteTokensTotal} links usados` : 'Sem sessao de voto' %>
        </span>
      </div>

      <a
        href="/admin"
        class="w-full sm:w-auto text-center px-4 py-2.5 rounded-full border border-horriver-orange text-xs font-semibold text-horriver-orange hover:bg-horriver-orange hover:text-horriver-bg transition"
      >
        Voltar ao painel
      </a>
    </div>
  </div>

  <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
    <div class="admin-summary-card">
      <div class="admin-section-title">Presencas</div>
      <div class="mt-3 text-2xl font-semibold text-horriver-light"><%= presentPlayersCount %></div>
      <div class="mt-1 text-sm text-horriver-gray">Jogadores marcados na rodada.</div>
    </div>
    <div class="admin-summary-card">
      <div class="admin-section-title">Producao</div>
      <div class="mt-3 text-2xl font-semibold text-horriver-light"><%= totalGoalsCount %></div>
      <div class="mt-1 text-sm text-horriver-gray"><%= totalAssistsCount %> assistencias registradas.</div>
    </div>
    <div class="admin-summary-card">
      <div class="admin-section-title">Votacao</div>
      <div class="mt-3 text-2xl font-semibold text-horriver-light"><%= voteTokensUsed %></div>
      <div class="mt-1 text-sm text-horriver-gray">
        <%= voteTokensTotal ? `${voteTokensPending} ainda pendentes.` : 'Nenhum link gerado ainda.' %>
      </div>
    </div>
    <div class="admin-summary-card">
      <div class="admin-section-title">Status da rodada</div>
      <div class="mt-3 text-xl font-semibold text-horriver-light">
        <%= voteTokensTotal ? (voteSessionClosed ? 'Votacao encerrada' : 'Votacao ativa') : 'Em configuracao' %>
      </div>
      <div class="mt-1 text-sm text-horriver-gray">
        <%= voteTokensTotal ? `Expira em ${voteSession && voteSession.expiresAt ? fmtDateTimeBR(voteSession.expiresAt) : 'sem prazo'}` : 'Pronta para receber stats e sorteio.' %>
      </div>
    </div>
  </div>
</section>

<section id="stats" class="scroll-mt-24 mt-10 space-y-4">
  <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-3">
    <div>
      <span class="admin-section-title">Estatisticas</span>
      <h2 class="mt-2 text-xl md:text-2xl font-semibold text-horriver-light">Controle da rodada</h2>
      <p class="mt-2 text-sm text-horriver-gray">
        Use esta area para preparar a pelada e abrir a janela unica de lancamento de estatisticas.
      </p>
    </div>
    <div class="text-xs text-horriver-gray">
      <%= hasSelectedPlayers ? `${playersForStats.length} jogadores prontos para lancamento.` : "Defina os presentes para liberar o lancamento." %>
    </div>
  </div>
  <div class="admin-panel rounded-[28px] p-5 md:p-6 space-y-4">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-3">
      <div class="space-y-2">
        <span class="admin-section-title">Acoes da rodada</span>
        <h3 class="text-lg font-semibold text-horriver-light">Atalhos principais</h3>
      </div>
      <div class="grid gap-3 sm:grid-cols-3 lg:flex lg:flex-wrap lg:justify-end">
        <a
          href="#sorteador"
          class="rounded-full border border-horriver-border px-4 py-2.5 text-center text-sm font-semibold text-horriver-light hover:border-horriver-orange hover:text-horriver-orange transition"
        >
          Ir para o sorteador
        </a>
        <a
          href="/admin/matches/<%= match.id %>/votes"
          class="rounded-full border border-horriver-border px-4 py-2.5 text-center text-sm font-semibold text-horriver-light hover:border-horriver-orange hover:text-horriver-orange transition"
        >
          Conferir votos
        </a>
        <a
          href="/admin/matches/<%= match.id %>/awards"
          class="rounded-full border border-horriver-border px-4 py-2.5 text-center text-sm font-semibold text-horriver-light hover:border-horriver-orange hover:text-horriver-orange transition"
        >
          Premios e imagem
        </a>
      </div>
    </div>
  </div>

  <div class="admin-panel rounded-[28px] p-5 md:p-6 space-y-5">
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
        <div class="space-y-2">
          <span class="admin-section-title">Lancamento principal</span>
          <h3 class="text-2xl font-semibold text-horriver-light">Stats, foto e time vencedor em uma janela</h3>
          <p class="text-sm text-horriver-gray max-w-2xl">
            O lancamento completo agora acontece no modal: primeiro voce define a foto da home, depois preenche gols
            e assistencias separados pelos times do sorteio. As notas aparecem somente como resultado da votacao.
          </p>
        </div>
        <button
          type="button"
          data-match-dialog-open="stats-wizard"
          class="w-full md:w-auto shrink-0 px-5 py-3 rounded-2xl bg-horriver-orange text-horriver-bg text-sm font-semibold hover:bg-orange-500 transition shadow-card-soft disabled:opacity-50 disabled:cursor-not-allowed"
          <%= hasSelectedPlayers ? "" : "disabled" %>
        >
          Lancar estatisticas
        </button>
      </div>

      <div class="grid gap-3 md:grid-cols-3">
        <div class="admin-subtle-card rounded-2xl p-4">
          <span class="admin-section-title">Presentes</span>
          <div class="mt-3 flex items-end justify-between gap-3">
            <strong class="text-3xl text-horriver-light"><%= presentPlayersCount %></strong>
            <span class="text-xs text-horriver-gray"><%= players.length %> no elenco</span>
          </div>
          <p class="mt-2 text-xs text-horriver-gray">
            <%= presentPlayersCount ? "Lista pronta para o lancamento." : "Selecione quem vai jogar antes dos stats." %>
          </p>
        </div>

        <div class="admin-subtle-card rounded-2xl p-4">
          <span class="admin-section-title">Sorteio</span>
          <div class="mt-3 text-lg font-semibold text-horriver-light">
            <%= lineupData && Array.isArray(lineupData.teams) && lineupData.teams.length ? `${lineupData.teams.length} times salvos` : "Sem time salvo" %>
          </div>
          <p class="mt-2 text-xs text-horriver-gray">
            O modal usa os times visiveis do sorteador ou o ultimo sorteio salvo.
          </p>
        </div>

        <div class="admin-subtle-card rounded-2xl p-4">
          <span class="admin-section-title">Publicacao</span>
          <div class="mt-3 text-lg font-semibold text-horriver-light">
            <%= match.winnerColor ? `Time ${match.winnerColor}` : "Sem vencedor" %>
          </div>
          <p class="mt-2 text-xs text-horriver-gray">
            A foto da home e a cor vencedora sao definidas no lancamento.
          </p>
        </div>
      </div>

      <div class="admin-subtle-card rounded-2xl p-4 md:p-5 space-y-4">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
          <div>
            <span class="admin-section-title">Lista de presentes</span>
            <h4 class="mt-2 text-lg font-semibold text-horriver-light">
              <%= presentPlayersCount ? `${presentPlayersCount} marcado(s) para a pelada` : "Nenhum presente marcado" %>
            </h4>
          </div>
          <button
            type="button"
            data-match-dialog-open="presence"
            class="w-full sm:w-auto rounded-2xl border border-horriver-orange/35 bg-horriver-orange/10 px-4 py-3 text-sm font-semibold text-horriver-orange hover:bg-horriver-orange hover:text-black transition"
          >
            <%= presentPlayersCount ? "Editar presentes" : "Selecionar presentes" %>
          </button>
        </div>

        <% if (hasSelectedPlayers) { %>
          <div class="grid gap-2 max-h-80 overflow-auto pr-1">
            <% playersForStats.forEach((player) => {
                const stat = statByPlayerId.get(player.id);
                const isGoalkeeper = String(player.position || "").toLowerCase().includes("gol");
                const ratingLabel = stat && stat.finalRating != null
                  ? stat.finalRating.toFixed(2).replace(".", ",")
                  : "-";
            %>
              <div class="rounded-2xl border border-horriver-border/60 bg-black/30 px-3 py-2.5">
                <div class="grid gap-3 md:grid-cols-[minmax(180px,1fr),auto] md:items-center">
                  <div class="min-w-0">
                    <p class="truncate text-sm font-semibold text-horriver-light"><%= player.name %></p>
                    <p class="mt-0.5 truncate text-[11px] uppercase text-horriver-orange">
                      <%= player.position %><% if (player.nickname) { %> - <%= player.nickname %><% } %>
                    </p>
                  </div>
                  <div class="grid <%= isGoalkeeper ? 'grid-cols-3 sm:grid-cols-6 md:min-w-[500px]' : 'grid-cols-3 sm:grid-cols-5 md:min-w-[430px]' %> gap-2 text-center text-[11px]">
                    <div class="rounded-xl border border-horriver-border/50 bg-black/30 px-2 py-1.5">
                      <span class="block uppercase text-horriver-gray">OVR</span>
                      <strong class="mt-0.5 block text-horriver-orange"><%= player.overall != null ? player.overall : "-" %></strong>
                    </div>
                    <div class="rounded-xl border border-horriver-border/50 bg-black/30 px-2 py-1.5">
                      <span class="block uppercase text-horriver-gray">Gols</span>
                      <strong class="mt-0.5 block text-horriver-light"><%= stat && stat.goals != null ? stat.goals : 0 %></strong>
                    </div>
                    <div class="rounded-xl border border-horriver-border/50 bg-black/30 px-2 py-1.5">
                      <span class="block uppercase text-horriver-gray">Assist.</span>
                      <strong class="mt-0.5 block text-horriver-light"><%= stat && stat.assists != null ? stat.assists : 0 %></strong>
                    </div>
                    <% if (isGoalkeeper) { %>
                      <div class="rounded-xl border border-horriver-border/50 bg-black/30 px-2 py-1.5">
                        <span class="block uppercase text-horriver-gray">Def.</span>
                        <strong class="mt-0.5 block text-horriver-light"><%= stat && stat.saves != null ? stat.saves : "-" %></strong>
                      </div>
                    <% } %>
                    <div class="rounded-xl border border-horriver-border/50 bg-black/30 px-2 py-1.5">
                      <span class="block uppercase text-horriver-gray">Nota</span>
                      <strong class="mt-0.5 block text-horriver-orange"><%= ratingLabel %></strong>
                    </div>
                    <div class="rounded-xl border border-horriver-border/50 bg-black/30 px-2 py-1.5">
                      <span class="block uppercase text-horriver-gray">Foto</span>
                      <strong class="mt-0.5 block <%= stat && stat.appearedInPhoto ? 'text-emerald-400' : 'text-horriver-gray' %>"><%= stat && stat.appearedInPhoto ? "Sim" : "-" %></strong>
                    </div>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="rounded-2xl border border-dashed border-horriver-border/70 bg-black/20 px-4 py-5 text-sm text-horriver-gray">
            Marque os jogadores confirmados antes de sortear os times ou lancar as estatisticas.
          </div>
        <% } %>
      </div>
  </div>
  <form
    action="/admin/matches/<%= match.id %>/stats/bulk"
    method="POST"
    id="statsForm"
    class="hidden"
    data-autosave="true"
    data-toast="Estatisticas salvas."
  >
    <div class="grid gap-4 xl:grid-cols-[320px,minmax(0,1fr)] items-start">
      <aside class="space-y-4">
        <div class="admin-panel rounded-[28px] p-5 md:p-6 space-y-4">
          <div class="space-y-2">
            <span class="admin-section-title">Elenco da rodada</span>
            <h3 class="text-lg font-semibold text-horriver-light">Quem vai jogar hoje</h3>
          </div>

          <div class="admin-subtle-card rounded-2xl p-4 space-y-3">
            <div class="flex items-center justify-between gap-3">
              <div>
                <div class="text-sm font-medium text-horriver-light"><%= presentPlayersCount %> presentes definidos</div>
                <div class="mt-1 text-xs text-horriver-gray">
                  <%= presentPlayersCount ? "A rodada ja esta filtrada para quem foi confirmado." : "Nenhum nome confirmado ainda para esta pelada." %>
                </div>
              </div>
              <span class="px-3 py-1 rounded-full border border-horriver-border text-[11px] text-horriver-light">
                <%= players.length %> no elenco
              </span>
            </div>

            <button
              type="button"
              data-match-dialog-open="presence"
              class="w-full px-4 py-3 rounded-2xl bg-horriver-orange text-horriver-bg text-sm font-semibold hover:bg-orange-500 transition shadow-card-soft"
            >
              <%= presentPlayersCount ? "Editar presentes" : "Selecionar presentes" %>
            </button>
          </div>
        </div>

        <div class="admin-panel rounded-[28px] p-5 md:p-6 space-y-4">
          <div class="space-y-2">
            <span class="admin-section-title">Contexto da rodada</span>
            <h3 class="text-lg font-semibold text-horriver-light">Configuracao rapida</h3>
          </div>

          <label class="flex flex-col gap-2 text-sm text-horriver-gray">
            Cor do time vencedor (opcional)
            <select
              name="winnerColor"
              class="bg-horriver-dark border border-horriver-border rounded-xl px-3 py-2.5 text-horriver-light"
            >
              <option value="" <%= !match.winnerColor ? "selected" : "" %>>Nenhuma</option>
              <option value="Amarelo" <%= match.winnerColor === "Amarelo" ? "selected" : "" %>>Amarelo</option>
              <option value="Azul" <%= match.winnerColor === "Azul" ? "selected" : "" %>>Azul</option>
              <option value="Preto" <%= match.winnerColor === "Preto" ? "selected" : "" %>>Preto</option>
              <option value="Vermelho" <%= match.winnerColor === "Vermelho" ? "selected" : "" %>>Vermelho</option>
            </select>
          </label>

          <div class="admin-subtle-card rounded-2xl p-4 text-sm text-horriver-light">
            <span class="block font-medium text-horriver-light">Sugestao de uso</span>
            <span class="mt-1 block text-xs text-horriver-gray">
              Feche os presentes primeiro, depois lance stats e so entao siga para sorteador, votacao e torneio.
            </span>
          </div>
        </div>

        <div class="admin-panel rounded-[28px] p-5 md:p-6 space-y-3">
          <div class="space-y-2">
            <span class="admin-section-title">Saida da rodada</span>
            <h3 class="text-lg font-semibold text-horriver-light">Publicacao e conferencias</h3>
          </div>
          <a
            href="/admin/matches/<%= match.id %>/votes"
            class="block w-full rounded-2xl border border-horriver-border px-4 py-3 text-sm font-semibold text-horriver-light hover:border-horriver-orange hover:text-horriver-orange transition"
          >
            Ver votos enviados
          </a>
          <a
            href="/admin/matches/<%= match.id %>/awards"
            class="block w-full rounded-2xl border border-horriver-border px-4 py-3 text-sm font-semibold text-horriver-light hover:border-horriver-orange hover:text-horriver-orange transition"
          >
            Ver premios e baixar imagem
          </a>
          <button
            type="button"
            data-match-dialog-open="stats-wizard"
            class="w-full px-4 py-3 rounded-2xl bg-horriver-orange text-horriver-bg text-sm font-semibold hover:bg-orange-500 transition shadow-card-soft"
            <%= hasSelectedPlayers ? "" : "disabled" %>
          >
            Lancar estatisticas
          </button>
        </div>
      </aside>

      <div class="admin-data-card">
        <div class="border-b border-horriver-border/60 px-5 py-4 md:px-6">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
            <div>
              <h3 class="text-lg font-semibold text-horriver-light">Jogadores da rodada</h3>
              <p class="mt-1 text-sm text-horriver-gray">
                Lance gols, assistencias, nota e aparicao em foto apenas para quem foi confirmado.
              </p>
            </div>
            <div class="text-xs text-horriver-gray">
              <span class="text-horriver-light font-medium"><%= playersForStats.length %></span> jogadores na rodada
            </div>
          </div>
        </div>

        <% if (!hasSelectedPlayers) { %>
          <div class="p-5 md:p-6">
            <div class="admin-subtle-card rounded-[24px] p-6 md:p-8 space-y-4 text-center">
              <div class="space-y-2">
                <span class="admin-section-title">Elenco vazio</span>
                <h3 class="text-xl font-semibold text-horriver-light">Nenhum presente definido ainda</h3>
                <p class="text-sm text-horriver-gray max-w-xl mx-auto">
                  Abra a selecao da rodada, marque quem vai estar presente e confirme. Depois disso a tabela fica enxuta
                  mostrando so os nomes da pelada com as opcoes de lancamento.
                </p>
              </div>
              <div class="flex justify-center">
                <button
                  type="button"
                  data-match-dialog-open="presence"
                  class="px-5 py-3 rounded-2xl bg-horriver-orange text-horriver-bg text-sm font-semibold hover:bg-orange-500 transition shadow-card-soft"
                >
                  Selecionar presentes
                </button>
              </div>
            </div>
          </div>
        <% } else { %>
          <div class="hidden sm:block overflow-x-auto max-h-[70vh]">
            <table class="min-w-full text-xs md:text-sm admin-table">
              <thead class="bg-black/80">
                <tr>
                  <th class="px-3 py-3 text-left font-semibold text-horriver-gray">Jogador</th>
                  <th class="px-3 py-3 text-center font-semibold text-horriver-gray">OVR</th>
                  <th class="px-3 py-3 text-center font-semibold text-horriver-gray">Presente</th>
                  <th class="px-3 py-3 text-center font-semibold text-horriver-gray">Gols</th>
                  <th class="px-3 py-3 text-center font-semibold text-horriver-gray">Assistencias</th>
                  <th class="px-3 py-3 text-center font-semibold text-horriver-gray">Nota</th>
                  <th class="px-3 py-3 text-center font-semibold text-horriver-gray">Foto</th>
                </tr>
              </thead>
              <tbody>
                <% playersForStats.forEach(function(player, idx) {
                     const stat = stats.find(s => s.playerId === player.id);
                %>
                <tr class="border-t border-horriver-border/40 hover:bg-white/10 transition" style="background:<%= idx % 2 === 0 ? 'rgba(255,255,255,0.03)' : 'rgba(255,255,255,0.06)' %>;">
                  <td class="px-3 py-2">
                    <div class="flex flex-col">
                      <span class="font-medium text-horriver-light"><%= player.name %></span>
                      <% if (player.nickname) { %>
                        <span class="text-[11px] text-horriver-gray">"<%= player.nickname %>"</span>
                      <% } %>
                      <span class="text-[10px] uppercase text-horriver-orange mt-1"><%= player.position %></span>
                    </div>
                  </td>
                  <td class="px-3 py-2 text-center align-middle">
                    <% if (player.overall != null) { %>
                      <span class="px-2 py-1 rounded-full bg-horriver-orange text-black text-[11px] font-semibold"><%= player.overall %></span>
                    <% } else { %>
                      <span class="text-horriver-gray text-[11px]">-</span>
                    <% } %>
                  </td>
                  <td class="px-3 py-2 text-center align-middle">
                    <input
                      type="checkbox"
                      name="present_<%= player.id %>"
                      data-player-name="<%= player.name %>"
                      data-player-position="<%= player.position %>"
                      data-player-strength="<%= player.overall != null ? player.overall : '' %>"
                      data-input-scope="desktop"
                      class="w-5 h-5 sm:w-4 sm:h-4 accent-horriver-orange"
                      <%= stat && stat.present ? 'checked' : '' %>
                    />
                  </td>
                  <td class="px-3 py-2 text-center align-middle">
                    <input
                      type="number"
                      name="goals_<%= player.id %>"
                      min="0"
                      step="1"
                      data-input-scope="desktop"
                      class="w-20 sm:w-16 bg-black/40 border border-horriver-border rounded-md px-2 py-1 text-center text-horriver-light text-xs md:text-sm"
                      value="<%= stat && stat.goals != null ? stat.goals : 0 %>"
                    />
                  </td>
                  <td class="px-3 py-2 text-center align-middle">
                    <input
                      type="number"
                      name="assists_<%= player.id %>"
                      min="0"
                      step="1"
                      data-input-scope="desktop"
                      class="w-20 sm:w-16 bg-black/40 border border-horriver-border rounded-md px-2 py-1 text-center text-horriver-light text-xs md:text-sm"
                      value="<%= stat && stat.assists != null ? stat.assists : 0 %>"
                    />
                  </td>
                  <td class="px-3 py-2 text-center align-middle">
                    <input
                      type="text"
                      name="rating_<%= player.id %>"
                      inputmode="decimal"
                      data-input-scope="desktop"
                      class="w-24 sm:w-20 bg-black/40 border border-horriver-border rounded-md px-2 py-1 text-center text-horriver-light text-xs md:text-sm"
                      placeholder="7,50"
                      value="<%= stat && (stat.rating != null || stat.finalRating != null) ? (stat.rating != null ? stat.rating : stat.finalRating).toFixed(2).replace('.', ',') : '' %>"
                    />
                  </td>
                  <td class="px-3 py-2 text-center align-middle">
                    <input
                      type="checkbox"
                      name="photo_<%= player.id %>"
                      data-input-scope="desktop"
                      class="w-5 h-5 sm:w-4 sm:h-4 accent-horriver-orange"
                      <%= stat && stat.appearedInPhoto ? 'checked' : '' %>
                    />
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>

          <div class="sm:hidden space-y-3 p-4">
            <% playersForStats.forEach(function(player) {
                 const stat = stats.find(s => s.playerId === player.id);
            %>
              <div class="rounded-2xl border border-horriver-border bg-black/50 p-3" data-player-card>
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="text-sm font-semibold text-horriver-light"><%= player.name %></p>
                    <% if (player.nickname) { %>
                      <p class="text-[11px] text-horriver-gray">"<%= player.nickname %>"</p>
                    <% } %>
                    <p class="text-[10px] uppercase text-horriver-orange mt-1"><%= player.position %></p>
                  </div>
                  <div>
                    <% if (player.overall != null) { %>
                      <span class="px-2 py-1 rounded-full bg-horriver-orange text-black text-[11px] font-semibold"><%= player.overall %></span>
                    <% } else { %>
                      <span class="text-horriver-gray text-[11px]">-</span>
                    <% } %>
                  </div>
                </div>

                <div class="mt-3 grid grid-cols-2 gap-2 text-[11px]">
                  <label class="flex items-center justify-between gap-2 rounded-xl border border-horriver-border/60 bg-black/40 px-3 py-2">
                    <span>Presente</span>
                    <input
                      type="checkbox"
                      name="present_<%= player.id %>"
                      data-player-name="<%= player.name %>"
                      data-player-position="<%= player.position %>"
                      data-player-strength="<%= player.overall != null ? player.overall : '' %>"
                      data-input-scope="mobile"
                      class="w-5 h-5 accent-horriver-orange"
                      <%= stat && stat.present ? 'checked' : '' %>
                    />
                  </label>

                  <label class="flex items-center justify-between gap-2 rounded-xl border border-horriver-border/60 bg-black/40 px-3 py-2">
                    <span>Foto</span>
                    <input
                      type="checkbox"
                      name="photo_<%= player.id %>"
                      data-input-scope="mobile"
                      class="w-5 h-5 accent-horriver-orange"
                      <%= stat && stat.appearedInPhoto ? 'checked' : '' %>
                    />
                  </label>

                  <label class="flex flex-col gap-1 rounded-xl border border-horriver-border/60 bg-black/40 px-3 py-2">
                    <span>Gols</span>
                    <input
                      type="number"
                      name="goals_<%= player.id %>"
                      min="0"
                      step="1"
                      data-input-scope="mobile"
                      class="w-full bg-black/20 border border-horriver-border rounded-md px-2 py-1 text-center text-horriver-light text-xs"
                      value="<%= stat && stat.goals != null ? stat.goals : 0 %>"
                    />
                  </label>

                  <label class="flex flex-col gap-1 rounded-xl border border-horriver-border/60 bg-black/40 px-3 py-2">
                    <span>Assist.</span>
                    <input
                      type="number"
                      name="assists_<%= player.id %>"
                      min="0"
                      step="1"
                      data-input-scope="mobile"
                      class="w-full bg-black/20 border border-horriver-border rounded-md px-2 py-1 text-center text-horriver-light text-xs"
                      value="<%= stat && stat.assists != null ? stat.assists : 0 %>"
                    />
                  </label>

                  <label class="col-span-2 flex flex-col gap-1 rounded-xl border border-horriver-border/60 bg-black/40 px-3 py-2">
                    <span>Nota</span>
                    <input
                      type="text"
                      name="rating_<%= player.id %>"
                      inputmode="decimal"
                      data-input-scope="mobile"
                      class="w-full bg-black/20 border border-horriver-border rounded-md px-2 py-1 text-center text-horriver-light text-xs"
                      placeholder="7,50"
                      value="<%= stat && (stat.rating != null || stat.finalRating != null) ? (stat.rating != null ? stat.rating : stat.finalRating).toFixed(2).replace('.', ',') : '' %>"
                    />
                  </label>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </div>
    </div>
  </form>
</section>

<div class="match-dialog" data-match-dialog="stats-wizard" hidden>
  <div class="match-dialog__backdrop" data-match-dialog-close></div>
  <div class="match-dialog__panel stats-wizard-dialog" role="dialog" aria-modal="true" aria-labelledby="stats-wizard-title">
    <form
      action="/admin/matches/<%= match.id %>/stats/wizard"
      method="POST"
      enctype="multipart/form-data"
      id="statsWizardForm"
      data-toast="Estatisticas salvas."
    >
      <div class="match-dialog__head">
        <div class="space-y-2">
          <span class="admin-kicker">Lancamento da rodada</span>
          <h2 id="stats-wizard-title" class="text-2xl font-semibold text-horriver-light">
            Time vencedor e estatisticas
          </h2>
          <p class="text-sm text-horriver-gray max-w-2xl">
            Primeiro defina a publicacao da home. Depois lance os numeros pelos times do sorteio salvo.
          </p>
        </div>
        <button type="button" class="match-dialog__close" data-match-dialog-close aria-label="Fechar lancamento">&times;</button>
      </div>

      <div class="match-dialog__body stats-wizard-body">
        <div class="stats-wizard-steps" aria-hidden="true">
          <span class="is-active" data-step-indicator="1">1. Home</span>
          <span data-step-indicator="2">2. Stats</span>
        </div>

        <section class="stats-wizard-step" data-stats-step="1">
          <div class="grid gap-4 lg:grid-cols-[320px,minmax(0,1fr)]">
            <div class="admin-subtle-card rounded-2xl p-4 space-y-4">
              <label class="flex flex-col gap-2 text-sm text-horriver-gray">
                Cor do time vencedor
                <select name="winnerColor" class="bg-horriver-dark border border-horriver-border rounded-xl px-3 py-2.5 text-horriver-light">
                  <option value="" <%= !match.winnerColor ? "selected" : "" %>>Nenhuma</option>
                  <option value="Amarelo" <%= match.winnerColor === "Amarelo" ? "selected" : "" %>>Amarelo</option>
                  <option value="Azul" <%= match.winnerColor === "Azul" ? "selected" : "" %>>Azul</option>
                  <option value="Preto" <%= match.winnerColor === "Preto" ? "selected" : "" %>>Preto</option>
                  <option value="Vermelho" <%= match.winnerColor === "Vermelho" ? "selected" : "" %>>Vermelho</option>
                </select>
              </label>
              <label class="flex flex-col gap-2 text-sm text-horriver-gray">
                Foto do time vencedor
                <input
                  id="matchTeamPhotoInput"
                  type="file"
                  name="teamPhoto"
                  accept="image/jpeg,image/png,image/webp"
                  class="block w-full text-sm text-horriver-gray file:mr-3 file:rounded-full file:border-0 file:bg-horriver-orange file:px-3 file:py-2 file:text-sm file:font-semibold file:text-black"
                />
              </label>
              <p class="text-xs text-horriver-gray">
                Assim que voce escolher uma imagem, o editor de corte aparece ao lado.
              </p>
            </div>
            <div id="matchTeamPhotoCropContainer" class="admin-preview-card hidden space-y-3">
              <div class="flex items-center justify-between gap-2">
                <p class="text-[11px] uppercase tracking-[0.14em] text-horriver-gray/80">
                  Corte da nova foto
                </p>
                <span class="text-[10px] text-horriver-gray/70">Proporcao 16:9</span>
              </div>
              <div class="overflow-hidden rounded-xl border border-horriver-border/60 bg-black/50">
                <img id="matchTeamPhotoCropImage" src="" alt="Pre-visualizacao para corte" />
              </div>
              <div class="flex flex-col sm:flex-row sm:items-center gap-2">
                <button
                  type="button"
                  id="applyMatchTeamPhotoCrop"
                  class="w-full sm:w-auto px-4 py-2 rounded-full border border-horriver-orange/35 text-horriver-orange hover:bg-horriver-orange hover:text-black transition text-sm"
                >
                  Aplicar corte
                </button>
                <p id="matchTeamPhotoCropDone" class="hidden text-[11px] text-green-400">
                  Corte preparado. Ao salvar, a imagem recortada sera enviada.
                </p>
              </div>
              <p id="matchTeamPhotoCropError" class="hidden text-[11px] text-red-400"></p>
            </div>
          </div>
          <div class="mt-4 flex justify-end">
            <button type="button" data-stats-skip-photo class="text-xs font-semibold text-horriver-gray hover:text-horriver-orange">
              Pular e lancar depois pelo painel
            </button>
          </div>
        </section>

        <section class="stats-wizard-step hidden" data-stats-step="2">
          <div class="stats-team-grid" data-stats-team-grid data-lineup-source="<%= lineupData && Array.isArray(lineupData.teams) && lineupData.teams.length ? 'saved' : 'fallback' %>">
            <% lineupTeamsForStats.forEach((team) => {
                const isAdjustmentGroup = !!team.isAdjustmentGroup;
                const allTeamPlayersInPhoto = !isAdjustmentGroup && team.players.length && team.players.every((player) => {
                  const stat = statByPlayerId.get(player.id);
                  return stat && stat.appearedInPhoto;
                });
            %>
              <article class="stats-team-card" style="--team-dot:<%= team.theme.dot %>; --team-soft:<%= team.theme.soft %>; --team-border:<%= team.theme.border %>;">
                <header>
                  <span></span>
                  <div>
                    <strong><%= team.name %></strong>
                    <small><%= team.colorName %> - <%= team.players.length %> jogador(es)</small>
                  </div>
                  <% if (!isAdjustmentGroup) { %>
                    <label class="stats-team-photo-toggle">
                      <input type="checkbox" data-team-photo-toggle <%= allTeamPlayersInPhoto ? "checked" : "" %> />
                      Saiu na foto
                    </label>
                  <% } %>
                </header>
                <% if (!isAdjustmentGroup) { %>
                  <% team.players.forEach((player) => {
                      const stat = statByPlayerId.get(player.id);
                  %>
                    <input type="hidden" data-team-photo-field name="photo_<%= player.id %>" value="<%= stat && stat.appearedInPhoto ? 'on' : '' %>" <%= stat && stat.appearedInPhoto ? "" : "disabled" %> />
                  <% }) %>
                <% } %>
                <div class="stats-team-list">
                  <% team.players.forEach((player) => {
                      const stat = statByPlayerId.get(player.id);
                      const isGoalkeeper = String(player.position || "").toLowerCase().includes("gol");
                  %>
                    <div class="stats-player-row<%= isGoalkeeper ? ' has-saves' : '' %><%= isAdjustmentGroup ? ' has-photo-toggle' : '' %>">
                      <input type="hidden" name="present_<%= player.id %>" value="on" />
                      <div class="min-w-0">
                        <p><%= player.name %></p>
                        <span><%= player.position %><% if (player.nickname) { %> - <%= player.nickname %><% } %></span>
                      </div>
                      <label>
                        Gols
                        <input type="number" name="goals_<%= player.id %>" min="0" step="1" value="<%= stat && stat.goals != null ? stat.goals : 0 %>" />
                      </label>
                      <label>
                        Assist.
                        <input type="number" name="assists_<%= player.id %>" min="0" step="1" value="<%= stat && stat.assists != null ? stat.assists : 0 %>" />
                      </label>
                      <% if (isGoalkeeper) { %>
                        <label>
                          Defesas
                          <input type="number" name="saves_<%= player.id %>" min="0" step="1" placeholder="-" value="<%= stat && stat.saves != null ? stat.saves : "" %>" />
                        </label>
                      <% } %>
                      <label>
                        Nota
                        <span class="stats-rating-output" data-rating-player-id="<%= player.id %>"><%= stat && stat.finalRating != null ? stat.finalRating.toFixed(2).replace('.', ',') : "-" %></span>
                      </label>
                      <% if (isAdjustmentGroup) { %>
                        <label class="stats-photo-toggle">
                          Foto
                          <input type="checkbox" name="photo_<%= player.id %>" <%= stat && stat.appearedInPhoto ? "checked" : "" %> />
                        </label>
                      <% } %>
                    </div>
                  <% }) %>
                </div>
              </article>
            <% }) %>
          </div>
        </section>
      </div>

      <div class="match-dialog__footer">
        <button type="button" class="match-dialog__soft-button" data-match-dialog-close>Cancelar</button>
        <input type="hidden" name="skipWeeklyPhoto" value="0" data-skip-weekly-photo />
        <button type="button" class="match-dialog__soft-button hidden" data-stats-prev>Voltar</button>
        <button type="button" class="match-dialog__primary" data-stats-next>Continuar</button>
        <button type="submit" class="match-dialog__primary hidden" data-stats-submit>Salvar estatisticas</button>
      </div>
    </form>
  </div>
</div>

<section id="votacao" class="scroll-mt-24 mt-12 space-y-4">
  <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-3">
    <div>
      <span class="admin-section-title">Votacao</span>
      <h2 class="mt-2 text-xl md:text-2xl font-semibold text-horriver-light">Controle da votacao da pelada</h2>
      <p class="mt-2 text-sm text-horriver-gray">
        Gere links, acompanhe quem votou e transforme os votos em notas sem misturar isso com o lancamento dos stats.
      </p>
    </div>
    <% if (voteTokensTotal) { %>
      <span class="status-chip <%= voteSessionClosed ? 'status-danger' : 'status-info' %>">
        <%= voteSessionClosed ? 'Votacao encerrada' : 'Votacao ativa' %>
      </span>
    <% } %>
  </div>

  <div class="grid gap-4 xl:grid-cols-[360px,minmax(0,1fr)] items-start">
    <div class="space-y-4">
      <form
        id="voteSessionForm"
        action="/admin/matches/<%= match.id %>/vote-session"
        method="POST"
        class="admin-panel rounded-[28px] p-5 md:p-6 space-y-4"
        data-autosave="true"
        data-toast="Links de votacao gerados."
      >
        <div class="space-y-2">
          <span class="admin-section-title">Sessao</span>
          <h3 class="text-lg font-semibold text-horriver-light">Gerar ou renovar links</h3>
          <p class="text-sm text-horriver-gray">
            Defina a expiracao da sessao e gere os links unicos para os presentes votarem.
          </p>
        </div>
        <label class="flex flex-col gap-2 text-sm text-horriver-gray">
          Expira em (horas)
          <input
            type="number"
            name="expiresHours"
            min="0"
            value="24"
            class="w-full bg-black/50 border border-horriver-border rounded-xl px-3 py-2.5 text-horriver-light"
          />
        </label>
        <button
          type="submit"
          class="w-full px-4 py-3 rounded-2xl bg-horriver-orange text-black font-semibold hover:bg-orange-500 transition"
        >
          Gerar links de votacao
        </button>
      </form>

      <% if (hasVoteSessionTokens) { %>
        <form
          id="applyVotesForm"
          action="/admin/matches/<%= match.id %>/apply-votes"
          method="POST"
          class="admin-panel rounded-[24px] p-5 space-y-3"
          data-toast="Votos aplicados."
          onsubmit="return confirm('Aplicar notas baseadas na votacao? Nao sobrescreve notas ja lancadas.');"
        >
          <div class="space-y-1">
            <span class="admin-section-title">Aplicacao</span>
            <h3 class="text-base font-semibold text-horriver-light">Transformar votos em notas</h3>
            <p class="text-sm text-horriver-gray">
              Calcula notas so para os presentes que ainda nao tiveram nota preenchida manualmente.
            </p>
          </div>
          <button
            type="submit"
            class="w-full px-4 py-3 rounded-2xl bg-horriver-orange text-black font-semibold hover:bg-orange-500 transition"
          >
            Aplicar votos como notas
          </button>
        </form>

        <form
          id="closeVotesForm"
          action="/admin/matches/<%= match.id %>/close-votes"
          method="POST"
          class="admin-panel rounded-[24px] p-5 space-y-3"
          data-toast="Votacao encerrada."
          onsubmit="return confirm('Encerrar a votacao agora? Links restantes serao bloqueados.');"
        >
          <div class="space-y-1">
            <span class="admin-section-title">Encerramento</span>
            <h3 class="text-base font-semibold text-horriver-light">Fechar sessao de votos</h3>
            <p class="text-sm text-horriver-gray">
              Expira a sessao atual e bloqueia imediatamente os links ainda nao usados.
            </p>
          </div>
          <button
            type="submit"
            class="w-full px-4 py-3 rounded-2xl bg-red-600 text-white font-semibold hover:bg-red-500 transition"
          >
            Encerrar votacao
          </button>
        </form>
      <% } %>
    </div>

    <div class="space-y-4">
      <% if (!voteSession || !voteSession.tokens || !voteSession.tokens.length) { %>
        <div class="admin-panel rounded-[28px] p-6">
          <span class="admin-section-title">Sem sessao ativa</span>
          <h3 class="mt-2 text-lg font-semibold text-horriver-light">Nenhum link gerado ainda</h3>
          <p class="mt-2 text-sm text-horriver-gray">
            Gere a sessao quando os presentes da rodada estiverem definidos. A lista de destinatarios aparecera aqui.
          </p>
        </div>
      <% } else { %>
        <div class="admin-panel rounded-[28px] p-5 md:p-6 space-y-4">
          <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-3">
            <div>
              <span class="admin-section-title">Resumo da sessao</span>
              <h3 class="mt-2 text-lg font-semibold text-horriver-light">Links e acompanhamento</h3>
            </div>
            <span class="status-chip <%= voteSessionClosed ? 'status-danger' : 'status-info' %>">
              <%= voteSessionClosed ? 'Votacao encerrada' : 'Votacao ativa' %>
            </span>
          </div>
          <div class="grid gap-3 sm:grid-cols-3">
            <div class="admin-summary-card">
              <div class="admin-section-title">Gerados</div>
              <div class="mt-3 text-2xl font-semibold text-horriver-light"><%= voteTokensTotal %></div>
              <div class="mt-1 text-sm text-horriver-gray">Links criados para esta rodada.</div>
            </div>
            <div class="admin-summary-card">
              <div class="admin-section-title">Votaram</div>
              <div class="mt-3 text-2xl font-semibold text-horriver-light"><%= voteTokensUsed %></div>
              <div class="mt-1 text-sm text-horriver-gray">Jogadores que ja enviaram voto.</div>
            </div>
            <div class="admin-summary-card">
              <div class="admin-section-title">Pendentes</div>
              <div class="mt-3 text-2xl font-semibold text-horriver-light"><%= voteTokensPending %></div>
              <div class="mt-1 text-sm text-horriver-gray">Ainda aguardando resposta.</div>
            </div>
          </div>
          <p class="text-sm text-horriver-gray">
            Sessao criada em <%= fmtDateTimeBR(voteSession.createdAt) %>
            <% if (voteSession.expiresAt) { %>
              &middot; expira em <%= fmtDateTimeBR(voteSession.expiresAt) %>
            <% } else { %>
              &middot; sem expiracao
            <% } %>
          </p>
        </div>

        <div class="admin-data-card">
          <div class="border-b border-horriver-border/60 px-5 py-4 md:px-6">
            <h3 class="text-lg font-semibold text-horriver-light">Destinatarios e links</h3>
            <p class="mt-1 text-sm text-horriver-gray">
              Copie, abra no navegador ou dispare direto pelo WhatsApp sem perder o status de cada jogador.
            </p>
          </div>

          <div class="overflow-x-auto text-[11px] md:text-xs w-full max-h-[60vh]">
            <table class="w-full border-collapse admin-table">
              <thead class="bg-black/80">
                <tr class="border-b border-horriver-border/60 text-horriver-gray/80">
                  <th class="py-2 px-4 text-left font-normal">Jogador</th>
                  <th class="py-2 pr-3 text-left font-normal">Posicao</th>
                  <th class="py-2 pr-3 text-left font-normal">Link</th>
                  <th class="py-2 pr-3 text-left font-normal">WhatsApp</th>
                  <th class="py-2 pr-4 text-left font-normal">Status</th>
                </tr>
              </thead>
              <tbody>
                <% voteSession.tokens.forEach((t, idx) => {
                     const link = `${voteBaseUrl}/votar/${t.token}`;
                     const waRaw = t.player.whatsapp || "";
                     const waDigits = waRaw.replace(/\D/g, "");
                     const msg = `Fala ${t.player.name}! Seu link de votacao da pelada: ${link}`;
                     const waUrl = waDigits ? `https://wa.me/${waDigits}?text=${encodeURIComponent(msg)}` : null;
                %>
                  <tr class="border-b border-horriver-border/40 last:border-0 hover:bg-white/10 transition" style="background:<%= idx % 2 === 0 ? 'rgba(255,255,255,0.03)' : 'rgba(255,255,255,0.06)' %>;">
                    <td class="py-2 px-4 text-horriver-light">
                      <%= t.player.name %>
                      <% if (t.player.nickname) { %>
                        (<%= t.player.nickname %>)
                      <% } %>
                    </td>
                    <td class="py-2 pr-3 text-horriver-orange/90 text-[10px] uppercase whitespace-nowrap">
                      <%= t.player.position %>
                    </td>
                    <td class="py-2 pr-3">
                      <a
                        href="<%= link %>"
                        target="_blank"
                        class="text-horriver-orange hover:underline break-all"
                      >
                        <%= link %>
                      </a>
                    </td>
                    <td class="py-2 pr-3 whitespace-nowrap">
                      <% if (waUrl) { %>
                        <a
                          href="<%= waUrl %>"
                          target="_blank"
                          class="inline-flex items-center px-3 py-1 rounded-full bg-horriver-red text-white hover:bg-horriver-orange transition"
                        >
                          Mandar link
                        </a>
                      <% } else { %>
                        <span class="status-chip status-warning">Sem numero</span>
                      <% } %>
                    </td>
                    <td class="py-2 pr-4">
                      <% if (t.usedAt) { %>
                        <span class="status-chip status-ok">Votou</span>
                      <% } else { %>
                        <span class="status-chip status-pending">Pendente</span>
                      <% } %>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>

<section id="sorteador" class="scroll-mt-24 mt-12 space-y-4">
  <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-3">
    <div>
      <span class="admin-section-title">Sorteador</span>
      <h2 class="mt-2 text-xl md:text-2xl font-semibold text-horriver-light">Sorteador inteligente de times</h2>
      <p class="mt-2 text-sm text-horriver-gray">
        Monte convidados, defina o modelo do sorteio e publique os times sem perder o contexto dos presentes.
      </p>
    </div>
    <div class="text-xs text-horriver-gray">
      Continua usando o overall do ranking e cria ate 4 times, com excedentes indo para o banco.
    </div>
  </div>

  <form id="sorterForm" class="grid gap-4 xl:grid-cols-[360px,minmax(0,1fr)] items-start text-[12px]">
    <div class="space-y-4">
      <div class="admin-panel rounded-[28px] p-5 md:p-6 space-y-4">
        <div class="space-y-2">
          <span class="admin-section-title">Convidados</span>
          <h3 class="text-lg font-semibold text-horriver-light">Adicionar so para este sorteio</h3>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <label class="flex flex-col gap-1 text-horriver-gray">
            Nome
            <input
              type="text"
              id="guestName"
              class="bg-horriver-dark border border-horriver-border rounded-xl px-3 py-2 text-horriver-light"
              placeholder="Ex: Convidado"
            />
          </label>
          <label class="flex flex-col gap-1 text-horriver-gray">
            Posicao
            <select
              id="guestPos"
              class="bg-horriver-dark border border-horriver-border rounded-xl px-3 py-2 text-horriver-light"
            >
              <option>Goleiro</option>
              <option>Zagueiro</option>
              <option>Meia</option>
              <option>Atacante</option>
              <option>Outros</option>
            </select>
          </label>
        </div>
        <label class="flex flex-col gap-1 text-horriver-gray">
          Forca (40-100)
          <input
            type="number"
            id="guestStr"
            min="40"
            max="100"
            value="60"
            class="bg-horriver-dark border border-horriver-border rounded-xl px-3 py-2 text-horriver-light w-full sm:w-28"
          />
        </label>
        <button
          type="button"
          id="addGuestBtn"
          class="w-full sm:w-auto px-4 py-2.5 rounded-full bg-horriver-orange text-black font-semibold hover:bg-orange-500 transition"
        >
          Adicionar convidado
        </button>
        <input type="hidden" name="guests" id="guestsField" />
        <div id="guestList" class="flex flex-wrap gap-2 text-[11px]"></div>
      </div>

      <div class="admin-panel rounded-[28px] p-5 md:p-6 space-y-4">
        <div class="space-y-2">
          <span class="admin-section-title">Modelo do sorteio</span>
          <h3 class="text-lg font-semibold text-horriver-light">Escolha o formato</h3>
          <p class="text-sm text-horriver-gray">
            Defina se o sistema vai trabalhar com 5, 6, 7 ou 8 jogadores por time.
          </p>
        </div>
        <label class="flex flex-col gap-2 text-sm text-horriver-gray">
          Jogadores por time
          <select
            id="playersPerTeam"
            class="bg-horriver-dark border border-horriver-border rounded-xl px-3 py-2.5 text-horriver-light"
          >
            <option value="5">5 por time</option>
            <option value="6" selected>6 por time</option>
            <option value="7">7 por time</option>
            <option value="8">8 por time</option>
          </select>
        </label>
        <p class="text-xs text-horriver-gray">
          O sistema continua criando no maximo 4 times e envia o excedente para o banco.
        </p>
      </div>
    </div>

    <div class="space-y-4">
      <div class="admin-panel rounded-[28px] p-5 md:p-6 space-y-4">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-3">
          <div class="space-y-2">
            <span class="admin-section-title">Cabecas de chave</span>
            <h3 class="text-lg font-semibold text-horriver-light">Travamento manual antes do sorteio</h3>
            <p class="text-sm text-horriver-gray">
              Marque entre os presentes quem deve ocupar uma vaga fixa em cada time.
            </p>
          </div>
          <div class="flex items-center gap-3 flex-wrap">
            <button
              type="button"
              id="sortBtn"
              class="w-full sm:w-auto px-4 py-2.5 rounded-full bg-horriver-orange text-black font-semibold hover:bg-orange-500 transition"
            >
              Sortear times
            </button>
            <span id="sorterStatus" class="text-horriver-gray"></span>
          </div>
        </div>
        <div
          id="seedList"
          class="bg-black/30 border border-horriver-border rounded-2xl p-3 flex flex-wrap gap-2 min-h-[52px]"
        ></div>
        <p class="text-[11px] text-horriver-gray">
          A lista acompanha automaticamente os presentes definidos para esta rodada.
        </p>
      </div>

      <div class="admin-data-card">
        <div class="border-b border-horriver-border/60 px-5 py-4 md:px-6">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
            <div>
              <h3 class="text-lg font-semibold text-horriver-light">Resultado do sorteio</h3>
              <p class="mt-1 text-sm text-horriver-gray">
                Os times, goleiros e banco aparecem aqui prontos para copiar, salvar ou exportar.
              </p>
            </div>
          </div>
        </div>

        <div class="p-5 md:p-6 space-y-4">
          <div class="grid gap-3 text-[12px] w-full [grid-template-columns:repeat(auto-fit,minmax(260px,1fr))] sm:[grid-template-columns:repeat(auto-fit,minmax(320px,1fr))]" id="sorterResults"></div>

          <div class="grid gap-3">
            <div id="goalkeeperBenchBox" class="hidden w-full text-[12px] border border-horriver-border/60 rounded-xl p-3 bg-black/30"></div>
            <div id="availableBox" class="hidden w-full text-[12px] border border-horriver-border/60 rounded-xl p-3 bg-black/30"></div>
            <div id="benchBox" class="hidden text-[12px] border border-horriver-border/60 rounded-xl p-3 bg-black/30"></div>
          </div>

          <div id="sorterShare" class="hidden flex flex-wrap items-center gap-2 text-[12px]">
            <button
              type="button"
              id="copyTeamsBtn"
              class="px-3 py-2 rounded-full bg-horriver-orange text-black font-semibold hover:bg-orange-500 transition"
            >
              Copiar texto
            </button>
            <button
              type="button"
              id="saveTeamsBtn"
              class="px-3 py-2 rounded-full bg-green-500 text-black font-semibold hover:bg-green-400 transition"
            >
              Salvar times
            </button>
            <button
              type="button"
              id="imgTeamsBtn"
              class="px-3 py-2 rounded-full border border-horriver-border text-horriver-light font-semibold hover:border-horriver-orange hover:text-horriver-orange transition"
            >
              Baixar imagem
            </button>
            <span id="shareStatus" class="text-horriver-gray"></span>
          </div>
        </div>
      </div>
    </div>
  </form>

  <form
    id="importTournamentForm"
    action="/admin/matches/<%= match.id %>/tournament/import-from-draw"
    method="POST"
    class="hidden flex flex-wrap items-center gap-2 text-[12px]"
  >
    <% for (let i = 0; i < 4; i += 1) { %>
      <input type="hidden" name="teamNames[<%= i %>]" data-import-name data-index="<%= i %>" />
      <input type="hidden" name="teamColors[<%= i %>]" data-import-color data-index="<%= i %>" />
    <% } %>
    <button
      type="submit"
      id="importTournamentBtn"
      class="px-3 py-2 rounded-full bg-horriver-orange text-black font-semibold hover:bg-orange-500 transition"
    >
      Importar times sorteados
    </button>
    <span id="importTournamentStatus" class="text-horriver-gray"></span>
  </form>
</section>
