    }

    if (imgBtn) {
      imgBtn.addEventListener("click", async () => {
        shareStatus.textContent = "Gerando imagem...";
        try {
          // Carrega html2canvas se ainda não estiver presente
          if (typeof html2canvas === "undefined") {
            await new Promise((resolve, reject) => {
              const s = document.createElement("script");
              s.src = "https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js";
              s.onload = resolve;
              s.onerror = () => reject(new Error("Falha ao carregar html2canvas"));
              document.body.appendChild(s);
            });
          }

          const buildRoundedCanvas = (sourceCanvas, radius) => {
            const output = document.createElement("canvas");
            output.width = sourceCanvas.width;
            output.height = sourceCanvas.height;
            const ctx = output.getContext("2d");
            if (!ctx) return sourceCanvas;

            const width = output.width;
            const height = output.height;
            const r = Math.max(0, Math.min(radius, width / 2, height / 2));

            ctx.clearRect(0, 0, width, height);
            ctx.beginPath();
            ctx.moveTo(r, 0);
            ctx.lineTo(width - r, 0);
            ctx.quadraticCurveTo(width, 0, width, r);
            ctx.lineTo(width, height - r);
            ctx.quadraticCurveTo(width, height, width - r, height);
            ctx.lineTo(r, height);
            ctx.quadraticCurveTo(0, height, 0, height - r);
            ctx.lineTo(0, r);
            ctx.quadraticCurveTo(0, 0, r, 0);
            ctx.closePath();
            ctx.clip();
            ctx.drawImage(sourceCanvas, 0, 0);

            return output;
          };

          const normalizeExportColorLabel = (value) => {
            const raw = value ? String(value).trim().toLowerCase() : "";
            if (raw.includes("amarelo")) return "Amarelo";
            if (raw.includes("vermelho")) return "Vermelho";
            if (raw.includes("azul")) return "Azul";
            if (raw.includes("preto")) return "Preto";
            if (raw.includes("#facc15")) return "Amarelo";
            if (raw.includes("#ef4444")) return "Vermelho";
            if (raw.includes("#3b82f6")) return "Azul";
            if (raw.includes("#18181b") || raw.includes("#111827") || raw.includes("#111111")) return "Preto";
            return null;
          };

          const downloadCanvas = (canvas, filename) =>
            new Promise((resolve, reject) => {
              if (!canvas.toBlob) {
                reject(new Error("Canvas export is not supported."));
                return;
              }

              canvas.toBlob((blob) => {
                if (!blob) {
                  reject(new Error("Could not generate image blob."));
                  return;
                }

                const url = URL.createObjectURL(blob);
                const link = document.createElement("a");
                link.download = filename;
                link.href = url;
                document.body.appendChild(link);
                link.click();
                link.remove();
                setTimeout(() => {
                  URL.revokeObjectURL(url);
                  resolve();
                }, 1000);
              }, "image/png");
            });

          const releaseCanvas = (canvas) => {
            if (!canvas) return;
            canvas.width = 0;
            canvas.height = 0;
          };

          const sponsorNameByLabelClient = {
            Amarelo: "Natureza em Flores",
            Vermelho: "Matheus Gomes Barbearia",
            Azul: "Carrocerias Santana",
            Preto: "Advance Compressores",
          };

          const readPlayerFromListItem = (li) => ({
            nome: li.dataset.playerName || "Jogador",
            nickname: li.dataset.playerNickname || "",
            pos: li.dataset.playerPosition || "",
            isGuest: li.dataset.playerGuest === "true",
          });

          const teamsForShare = Array.from(resultsEl.querySelectorAll("[data-team]")).map((box, idx) => {
            const rawName = box.querySelector("[data-team-name]")?.textContent?.trim() || `Time ${idx + 1}`;
            const selectEl = box.querySelector("[data-color-select]");
            const color =
              selectEl?.value ||
              box.getAttribute("data-team-color") ||
              box.querySelector("[data-color-indicator]")?.style?.backgroundColor ||
              "#f97316";
            const players = Array.from(box.querySelectorAll("li")).map(readPlayerFromListItem);
            const nomeCor =
              box.getAttribute("data-team-color-name") ||
              selectEl?.selectedOptions?.[0]?.text ||
              rawName;
            const sponsorName = sponsorNameByLabelClient[nomeCor] || rawName;
            const displayName = sponsorName || rawName;
            const colorName =
              normalizeExportColorLabel(nomeCor) ||
              normalizeExportColorLabel(color) ||
              normalizeExportColorLabel(displayName) ||
              "Vermelho";
            return { name: displayName, color, colorName, players };
          });

          const goalkeepersForShare = Array.from(goalkeeperBenchBox?.querySelectorAll("li") || []).map(
            readPlayerFromListItem
          );

          const getLuminance = (hex) => {
            if (!hex || !hex.startsWith("#") || hex.length < 7) return 0.5;
            const r = parseInt(hex.slice(1, 3), 16) / 255;
            const g = parseInt(hex.slice(3, 5), 16) / 255;
            const b = parseInt(hex.slice(5, 7), 16) / 255;
            const lin = (c) => (c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4));
            return 0.2126 * lin(r) + 0.7152 * lin(g) + 0.0722 * lin(b);
          };

          const escapeHtml = (value = "") =>
            String(value)
              .replace(/&/g, "&amp;")
              .replace(/</g, "&lt;")
              .replace(/>/g, "&gt;")
              .replace(/"/g, "&quot;")
              .replace(/'/g, "&#39;");

          const positionBadge = (pos = "") => {
            const raw = String(pos || "").toUpperCase();
            const key = raw.includes("GOL")
              ? "GOL"
              : raw.includes("ZAG") || raw.includes("DEF")
                ? "ZAG"
                : raw.includes("MEI")
                  ? "MEI"
                  : raw.includes("VOL")
                    ? "VOL"
                    : raw.includes("ATA")
                      ? "ATA"
                      : raw.slice(0, 3);
            const colorsByKey = {
              ATA: { bg: "rgba(239, 68, 68, 0.16)", border: "rgba(239, 68, 68, 0.45)", text: "#fca5a5" },
              MEI: { bg: "rgba(59, 130, 246, 0.16)", border: "rgba(59, 130, 246, 0.45)", text: "#93c5fd" },
              VOL: { bg: "rgba(20, 184, 166, 0.16)", border: "rgba(20, 184, 166, 0.45)", text: "#99f6e4" },
              ZAG: { bg: "rgba(34, 197, 94, 0.16)", border: "rgba(34, 197, 94, 0.45)", text: "#86efac" },
              GOL: { bg: "rgba(250, 204, 21, 0.18)", border: "rgba(250, 204, 21, 0.45)", text: "#fde68a" },
            };
            return {
              label: key || raw || "---",
              ...(colorsByKey[key] || { bg: "rgba(148, 163, 184, 0.14)", border: "rgba(148, 163, 184, 0.35)", text: "#cbd5e1" }),
            };
          };

          const positionGroupKey = (pos = "") => {
            const label = positionBadge(pos).label;
            if (label === "VOL") return "MEI";
            return label;
          };

          const positionRank = (pos = "") => {
            const key = positionGroupKey(pos);
            return ({
              GOL: 0,
              ZAG: 1,
              MEI: 2,
              ATA: 3,
            })[key] ?? 4;
          };

          const sortedPlayersForShare = (players = []) =>
            [...players].sort((a, b) => {
              const rankDiff = positionRank(a.pos) - positionRank(b.pos);
              if (rankDiff !== 0) return rankDiff;
              const aLabel = getPlayerIdentity({ name: a.nome, nickname: a.nickname }).primary;
              const bLabel = getPlayerIdentity({ name: b.nome, nickname: b.nickname }).primary;
              return String(aLabel || a.nome || "").localeCompare(String(bLabel || b.nome || ""), "pt-BR");
            });

          const teamVisualTheme = (team) => {
            const key =
              normalizeExportColorLabel(team?.colorName) ||
              normalizeExportColorLabel(team?.color) ||
              normalizeExportColorLabel(team?.name) ||
              "Vermelho";
            const themeByKey = {
              Vermelho: {
                border: "rgba(255,107,87,0.58)",
                panelBg:
                  "linear-gradient(180deg, rgba(110, 16, 34, 0.82) 0%, rgba(64, 12, 24, 0.76) 20%, rgba(20, 12, 16, 0.84) 100%)",
                stripBg: "linear-gradient(90deg, #fb7185 0%, #ef4444 54%, #f97316 100%)",
                rowBg: "rgba(255,255,255,0.03)",
                rowBorder: "rgba(255,255,255,0.08)",
                titleText: "#f8fafc",
                labelText: "rgba(255,255,255,0.56)",
                countText: "rgba(255,255,255,0.92)",
                rankText: "#ff8a6d",
              },
              Azul: {
                border: "rgba(94,168,255,0.54)",
                panelBg:
                  "linear-gradient(180deg, rgba(26, 72, 148, 0.82) 0%, rgba(17, 55, 120, 0.76) 18%, rgba(12, 28, 58, 0.84) 100%)",
                stripBg: "linear-gradient(90deg, #7dd3fc 0%, #3b82f6 52%, #1d4ed8 100%)",
                rowBg: "rgba(255,255,255,0.03)",
                rowBorder: "rgba(255,255,255,0.08)",
                titleText: "#f8fafc",
                labelText: "rgba(255,255,255,0.56)",
                countText: "rgba(255,255,255,0.92)",
                rankText: "#71a6ff",
              },
              Amarelo: {
                border: "rgba(255,228,90,0.54)",
                panelBg:
                  "linear-gradient(180deg, rgba(149, 109, 18, 0.82) 0%, rgba(92, 63, 13, 0.76) 18%, rgba(23, 17, 10, 0.84) 100%)",
                stripBg: "linear-gradient(90deg, #fff36b 0%, #fde047 28%, #facc15 60%, #f59e0b 100%)",
                rowBg: "rgba(255,255,255,0.032)",
                rowBorder: "rgba(255,255,255,0.08)",
                titleText: "#f8fafc",
                labelText: "rgba(255,255,255,0.56)",
                countText: "rgba(255,255,255,0.92)",
                rankText: "#f6d454",
              },
              Preto: {
                border: "rgba(203,213,225,0.34)",
                panelBg:
                  "linear-gradient(180deg, rgba(52, 52, 57, 0.82) 0%, rgba(37, 39, 46, 0.76) 18%, rgba(18, 19, 24, 0.84) 100%)",
                stripBg: "linear-gradient(90deg, #f3f4f6 0%, #cbd5e1 42%, #64748b 100%)",
                rowBg: "rgba(255,255,255,0.032)",
                rowBorder: "rgba(255,255,255,0.08)",
                titleText: "#f8fafc",
                labelText: "rgba(255,255,255,0.58)",
                countText: "rgba(255,255,255,0.92)",
                rankText: "#f3f4f6",
              },
            };
            return themeByKey[key] || themeByKey.Vermelho;
          };

          const buildBalancedTitleLines = (value = "") => {
            const clean = String(value || "").replace(/\s+/g, " ").trim();
            if (!clean) return ["Time sem nome"];
            const words = clean.split(" ");
            if (words.length === 1) return [clean];

            let best = null;
            for (let i = 1; i < words.length; i += 1) {
              const lines = [words.slice(0, i).join(" "), words.slice(i).join(" ")];
              const lengths = lines.map((line) => line.length);
              const longest = Math.max(...lengths);
              const diff = Math.abs(lengths[0] - lengths[1]);
              const score = diff * 2 + longest;
              if (!best || score < best.score) {
                best = { lines, longest, score };
              }
            }

            return best?.lines || [clean];
          };

          const teamTitleLayouts = (() => {
            const layouts = teamsForShare.map((team) => ({
              lines: buildBalancedTitleLines(team?.name),
            }));
            const longestLineLength = layouts.reduce(
              (max, layout) => Math.max(max, ...layout.lines.map((line) => line.length)),
              0
            );

            let fontSize = 54;
            let lineHeight = 0.92;
            let minHeight = 104;

            if (longestLineLength >= 14) {
              fontSize = 52;
              minHeight = 108;
            }
            if (longestLineLength >= 17) {
              fontSize = 48;
              lineHeight = 0.94;
              minHeight = 114;
            }
            if (longestLineLength >= 21) {
              fontSize = 44;
              lineHeight = 0.96;
              minHeight = 120;
            }
            if (longestLineLength >= 26) {
              fontSize = 40;
              lineHeight = 0.98;
              minHeight = 126;
            }

            return layouts.map((layout) => ({
              ...layout,
              fontSize,
              lineHeight,
              minHeight,
