          card.style.padding = "34px 34px 24px";
          card.style.borderRadius = "32px";
          card.style.border = "1px solid rgba(255,122,26,0.26)";
          card.style.background =
            "radial-gradient(circle at top left, rgba(118, 24, 50, 0.14) 0%, transparent 30%), radial-gradient(circle at top right, rgba(255, 122, 26, 0.05) 0%, transparent 18%), radial-gradient(circle at bottom right, rgba(24, 44, 82, 0.12) 0%, transparent 30%), linear-gradient(180deg, #2a0005 0%, #160208 34%, #050509 100%)";
          card.style.color = "#f3f4f6";
          card.style.fontFamily = "\"Manrope\", system-ui, -apple-system, sans-serif";
          card.style.boxShadow = "0 24px 56px rgba(0,0,0,0.28)";
          card.style.overflow = "hidden";
          card.style.isolation = "isolate";

          const watermarkHtml = `
            <div style="position:absolute;inset:0;overflow:hidden;pointer-events:none;z-index:0;">
              <div style="position:absolute;inset:0;background:radial-gradient(circle at center, rgba(255,255,255,0.035) 0%, rgba(255,255,255,0.018) 20%, rgba(5,5,9,0) 60%);"></div>
              <img
                src="/img/logo-512x512.svg"
                alt=""
                aria-hidden="true"
                style="position:absolute;top:56%;left:50%;width:860px;height:860px;transform:translate(-50%, -50%);object-fit:contain;opacity:0.085;filter:grayscale(1) brightness(1.52) saturate(0.12);"
              />
            </div>
          `;

          const headerHtml = `
            <div style="position:relative;display:flex;align-items:flex-start;justify-content:space-between;gap:34px;margin-bottom:26px;">
              <div style="display:flex;flex-direction:column;gap:6px;position:relative;z-index:1;">
                <span style="font-size:13px;color:rgba(255,179,106,0.90);font-weight:800;text-transform:uppercase;letter-spacing:0.24em;opacity:0.96;">Horriver Plate</span>
                <div style="position:relative;display:block;margin-top:10px;padding-bottom:30px;">
                  <span style="display:block;font-family:'Bebas Neue', 'Oswald', sans-serif;font-size:74px;font-weight:400;letter-spacing:0.82px;line-height:0.98;color:#f8fafc;">Times Sorteados</span>
                  <span style="position:absolute;left:0;bottom:0;display:block;height:4px;width:260px;border-radius:999px;background:linear-gradient(90deg, rgba(255,122,26,0.98) 0%, rgba(255,122,26,0.45) 34%, rgba(255,122,26,0.10) 100%);"></span>
                </div>
              </div>
              <div style="position:relative;z-index:1;min-width:318px;border:1px solid rgba(255,122,26,0.34);border-radius:28px;background:linear-gradient(180deg, rgba(19,17,24,0.96) 0%, rgba(12,12,16,0.98) 100%);padding:28px 24px 22px;display:flex;align-items:flex-end;justify-content:space-between;gap:22px;">
                <div style="display:flex;flex-direction:column;gap:16px;min-width:0;">
                  <span style="font-size:12px;font-weight:760;line-height:1;color:rgba(226,232,240,0.66);letter-spacing:0.18em;text-transform:uppercase;">Sorteio oficial</span>
                  <div style="font-size:56px;font-weight:900;line-height:0.94;color:#f8fafc;letter-spacing:-0.04em;">${escapeHtml(matchDateLabel)}</div>
                  <div style="font-size:16px;font-weight:780;line-height:1;color:rgba(226,232,240,0.74);letter-spacing:0.02em;">${teamsForShare.length} times</div>
                </div>
                <div style="width:58px;height:58px;border-radius:999px;border:2px solid rgba(255,122,26,0.88);background:rgba(12,12,16,0.82);display:flex;align-items:center;justify-content:center;box-shadow:0 0 0 1px rgba(255,255,255,0.02) inset;">
                  <img src="/img/logo-32x32.svg" alt="Horriver Plate" style="width:30px;height:30px;object-fit:contain;opacity:0.96;" />
                </div>
              </div>
            </div>
            <div style="height:1px;margin-bottom:26px;background:linear-gradient(90deg, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0.05) 40%, rgba(255,255,255,0) 100%);"></div>
          `;

          const gridColumns = teamsForShare.length === 4 ? 2 : 3;
          const teamsHtml = `
            <div style="display:grid;grid-template-columns:repeat(${gridColumns},minmax(0,1fr));gap:18px;">
              ${teamsForShare
                .map((t, idx) => {
                  const theme = teamVisualTheme(t);
                  const sortedPlayers = sortedPlayersForShare(t.players || []);
                  const titleLayout = teamTitleLayouts[idx] || {
                    lines: [String(t.name || `Time ${idx + 1}`)],
                    fontSize: 54,
                    lineHeight: 0.92,
                    minHeight: 104,
                  };
                  return `
                    <div style="position:relative;min-width:0;border:1px solid ${theme.border};border-radius:30px;overflow:hidden;background:${theme.panelBg};box-shadow:0 22px 42px rgba(0,0,0,0.16);">
                      <div style="height:10px;background:${theme.stripBg};"></div>
                      <div style="padding:18px 18px 18px;display:flex;flex-direction:column;gap:18px;">
                        <div style="display:flex;align-items:center;justify-content:space-between;gap:18px;">
                          <div style="display:flex;align-items:center;gap:10px;min-width:0;">
                            <span style="font-size:16px;font-weight:900;line-height:1;color:${theme.rankText};">#${idx + 1}</span>
                            <span style="font-size:11px;font-weight:800;letter-spacing:0.28em;text-transform:uppercase;color:${theme.labelText};white-space:nowrap;">Time sorteado</span>
                          </div>
                          <span style="font-size:14px;font-weight:800;line-height:1;color:${theme.countText};white-space:nowrap;">${sortedPlayers.length} jogadores</span>
                        </div>
                        <div style="display:flex;align-items:center;min-height:${titleLayout.minHeight}px;padding-right:8px;">
                          <div style="display:flex;flex-direction:column;justify-content:center;gap:2px;min-width:0;width:100%;font-family:'Bebas Neue', 'Oswald', sans-serif;font-size:${titleLayout.fontSize}px;font-weight:400;line-height:${titleLayout.lineHeight};letter-spacing:0.55px;color:${theme.titleText};text-transform:uppercase;">
                            ${titleLayout.lines
                              .map(
                                (line) =>
                                  `<span style="display:block;white-space:nowrap;">${escapeHtml(line)}</span>`
                              )
                              .join("")}
                          </div>
                        </div>
                        <span style="margin-top:-4px;height:1px;width:100%;background:linear-gradient(90deg, rgba(255,255,255,0.16) 0%, rgba(255,255,255,0.05) 100%);"></span>
                        <div style="display:flex;flex-direction:column;gap:12px;">
                          ${sortedPlayers
                            .map((p) => {
                              const positionLabel = positionBadge(p.pos).label;
                              const identity = getPlayerIdentity({
                                name: p.nome,
                                nickname: p.nickname,
                                isGuest: p.isGuest,
                              });
                              return `
                                <div style="display:flex;align-items:center;justify-content:space-between;gap:16px;min-height:76px;padding:16px 16px;border-radius:18px;background:${theme.rowBg};border:1px solid ${theme.rowBorder};box-shadow:none;">
                                  <div style="display:flex;align-items:center;min-width:0;flex:1 1 auto;">
                                    <div style="display:flex;flex-direction:column;gap:6px;min-width:0;">
                                      <span style="display:block;min-width:0;max-width:100%;font-size:19px;font-weight:800;line-height:1.16;letter-spacing:-0.01em;color:#f8fafc;white-space:normal;overflow:visible;word-break:break-word;">${escapeHtml(identity.primary)}</span>
                                      ${
                                        identity.secondary || identity.guest
                                          ? `<div style="display:flex;align-items:center;flex-wrap:wrap;column-gap:8px;row-gap:4px;min-width:0;">
                                              ${identity.secondary ? `<span style="display:inline-block;min-width:0;max-width:100%;font-size:13px;font-weight:620;line-height:1.2;color:rgba(226,232,240,0.78);white-space:normal;overflow:visible;word-break:break-word;">${escapeHtml(identity.secondary)}</span>` : ""}
                                              ${identity.guest ? `<span style="display:inline-block;font-size:11px;font-weight:800;line-height:1.1;letter-spacing:0.10em;color:#f1cf8a;text-transform:uppercase;">Convidado</span>` : ""}
                                            </div>`
                                          : ""
                                      }
                                    </div>
                                  </div>
                                  <span style="display:inline-block;flex:0 0 auto;min-width:38px;font-size:13px;font-weight:700;line-height:1;letter-spacing:0.10em;color:rgba(226,232,240,0.62);text-transform:uppercase;text-align:right;">
                                    ${escapeHtml(positionLabel)}
                                  </span>
                                </div>
                              `;
                            })
                            .join("")}
                        </div>
                      </div>
                    </div>
                  `;
                })
                .join("")}
            </div>
          `;

          const gkHtml =
            goalkeepersForShare.length > 0
              ? `
            <div style="margin-top:22px;border:1px solid rgba(199,139,91,0.44);border-radius:28px;overflow:hidden;background:linear-gradient(180deg, rgba(61, 43, 27, 0.4) 0%, rgba(19, 17, 20, 0.78) 100%);">
              <div style="height:10px;background:linear-gradient(90deg, #d4a06d 0%, rgba(199,139,91,0.72) 42%, rgba(199,139,91,0.16) 100%);"></div>
              <div style="padding:18px;">
                <div style="display:flex;align-items:center;justify-content:space-between;gap:14px;margin-bottom:14px;">
                  <div style="font-family:'Bebas Neue', 'Oswald', sans-serif;font-size:28px;line-height:0.95;color:#f8fafc;letter-spacing:1.4px;">Goleiros</div>
                  <div style="font-size:14px;font-weight:700;line-height:1;color:rgba(255,236,213,0.82);">${goalkeepersForShare.length} jogador(es)</div>
                </div>
                <div style="display:flex;flex-direction:column;gap:10px;">
                ${goalkeepersForShare
                  .map((gk) => {
                    const identity = getPlayerIdentity({
                      name: gk.nome,
                      nickname: gk.nickname,
                      isGuest: gk.isGuest,
                    });
                    return `
                      <div style="display:flex;align-items:center;justify-content:space-between;gap:16px;min-height:72px;padding:16px 16px;border-radius:18px;background:rgba(255,255,255,0.028);border:1px solid rgba(255,255,255,0.075);box-shadow:none;">
                        <div style="display:flex;align-items:center;min-width:0;flex:1 1 auto;">
                          <div style="display:flex;flex-direction:column;gap:6px;min-width:0;">
                            <span style="font-size:18px;font-weight:800;line-height:1.16;color:#f8fafc;">${escapeHtml(identity.primary)}</span>
                            ${
                              identity.secondary || identity.guest
                                ? `<div style="display:flex;align-items:center;flex-wrap:wrap;column-gap:8px;row-gap:4px;min-width:0;">
                                    ${identity.secondary ? `<span style="font-size:13px;font-weight:620;line-height:1.2;color:rgba(226,232,240,0.78);">${escapeHtml(identity.secondary)}</span>` : ""}
                                    ${identity.guest ? `<span style="font-size:11px;font-weight:800;letter-spacing:0.10em;color:#f1cf8a;text-transform:uppercase;">Convidado</span>` : ""}
                                  </div>`
                                : ""
                            }
                          </div>
                        </div>
                        <span style="display:inline-block;flex:0 0 auto;min-width:38px;font-size:13px;font-weight:700;line-height:1;letter-spacing:0.10em;color:rgba(226,232,240,0.62);text-transform:uppercase;text-align:right;">GOL</span>
                      </div>
                    `;
                  })
                  .join("")}
                </div>
              </div>
            </div>`
              : "";

          const footerHtml = `
            <div style="display:flex;align-items:center;justify-content:space-between;gap:16px;margin-top:24px;padding-top:16px;border-top:1px solid rgba(255,255,255,0.06);font-size:11px;color:rgba(226,232,240,0.52);text-transform:uppercase;letter-spacing:0.14em;">
              <span>horriverplate.onrender.com</span>
              <span>@_hpfrc</span>
            </div>
          `;

          card.innerHTML = `${watermarkHtml}<div style="position:relative;z-index:1;">${headerHtml + teamsHtml + gkHtml + footerHtml}</div>`;

          const images = Array.from(card.querySelectorAll("img"));
          document.body.appendChild(card);
          await (document.fonts?.ready || Promise.resolve());
          await Promise.all(
            images.map((img) => {
              if (img.complete) return Promise.resolve();
              return new Promise((resolve) => {
                const done = () => resolve();
                img.addEventListener("load", done, { once: true });
                img.addEventListener("error", done, { once: true });
                setTimeout(done, 3000);
              });
            })
          );
          await new Promise((resolve) => requestAnimationFrame(() => requestAnimationFrame(resolve)));
          let canvas = null;
          let roundedCanvas = null;
          try {
            canvas = await html2canvas(card, {
              backgroundColor: null,
              scale: Math.min(2, window.devicePixelRatio || 1.5),
              useCORS: true,
              windowWidth: Math.ceil(card.scrollWidth),
              windowHeight: Math.ceil(card.scrollHeight),
              imageTimeout: 15000,
            });
            roundedCanvas = buildRoundedCanvas(canvas, 68);
            await downloadCanvas(roundedCanvas, "times-sorteio.png");
          } finally {
            releaseCanvas(roundedCanvas);
            releaseCanvas(canvas);
            if (card.isConnected) document.body.removeChild(card);
          }
          shareStatus.textContent = "Imagem baixada.";
        } catch (err) {
          console.error(err);
          shareStatus.textContent = "Erro ao gerar imagem.";
        }
      });
    }

    console.info("Sorteador carregado");
  } catch (err) {
    console.error("Erro no script do sorteador", err);
    if (statusEl) statusEl.textContent = "Erro no script. Veja o console.";
  }
  })();
</script>




