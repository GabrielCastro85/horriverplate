<%
  const pillClass = "inline-flex items-center gap-2 rounded-full border border-horriver-border bg-white/[0.04] px-3 py-2 text-[11px] leading-none text-horriver-light";
  const statCardClass = "rounded-[1.35rem] border border-horriver-border bg-white/[0.04] px-4 py-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]";
  const statCardAccentClass = "rounded-[1.35rem] border border-horriver-orange/30 bg-gradient-to-br from-horriver-orange/12 via-black/35 to-black/60 px-4 py-4 shadow-[0_14px_36px_rgba(0,0,0,0.22)]";
  const emptyStateClass = "rounded-[1.5rem] border border-dashed border-horriver-border bg-gradient-to-br from-horriver-orange/8 via-black/30 to-black/40 px-5 py-5";
  const emptyEyebrowClass = "inline-flex items-center rounded-full border border-horriver-orange/20 bg-horriver-orange/10 px-3 py-1 text-[10px] uppercase tracking-[0.16em] text-[#ffb685]";
  const sectionHeadingClass = "flex items-end justify-between gap-3 flex-wrap";
  const sectionMetaClass = "text-xs text-horriver-gray/80";
  const surfaceSoftClass = "rounded-[1.25rem] border border-horriver-border bg-white/[0.04] shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]";
%>

<section class="page-shell w-full max-w-5xl mx-auto px-4 sm:px-6 animate-fadeIn">
  <header class="page-hero space-y-6">
    <div class="grid gap-5 lg:grid-cols-[auto,1fr,0.9fr] lg:items-start">
      <div class="relative w-32 h-32 rounded-full overflow-hidden border-4 border-horriver-orange/90 shadow-card-soft shrink-0 mx-auto md:mx-0">
        <% if (player.photoUrl) { %>
          <img
            src="<%= thumbUrl(player.photoUrl, 320) %>"
            srcset="<%= thumbUrl(player.photoUrl, 320) %> 1x, <%= thumbUrl(player.photoUrl, 640) %> 2x"
            sizes="128px"
            alt="<%= player.name %>"
            class="w-full h-full object-cover"
          />
        <% } else { %>
          <div class="w-full h-full bg-black/40 flex items-center justify-center text-horriver-gray text-sm">
            Sem foto
          </div>
        <% } %>
      </div>

      <div class="space-y-4 text-center md:text-left">
        <div class="space-y-2">
          <span class="hero-badge text-horriver-gray">
            <span class="hero-icon">JP</span>
            Perfil do jogador
          </span>
          <h1 class="text-3xl md:text-4xl font-title text-horriver-light"><%= player.name %></h1>
          <% if (player.nickname) { %>
            <p class="text-horriver-orange text-sm">(<%= player.nickname %>)</p>
          <% } %>
          <div class="flex flex-wrap gap-2 justify-center md:justify-start">
            <span class="<%= pillClass %>"><strong class="text-horriver-orange font-semibold"><%= player.position || "Sem posicao" %></strong> posicao</span>
            <span class="<%= pillClass %>"><strong class="text-horriver-orange font-semibold"><%= Math.round(latestOverall || 0) %></strong> overall</span>
          </div>
        </div>

        <div class="flex flex-wrap items-center justify-center md:justify-start gap-2 text-sm">
          <button
            type="button"
            id="copyProfileLink"
            class="px-4 py-2 rounded-full border border-horriver-border bg-black/35 text-horriver-light hover:border-horriver-orange hover:text-horriver-orange transition"
          >
            Copiar link do perfil
          </button>
          <span id="copyStatus" class="text-[11px] text-horriver-gray hidden">Copiado!</span>
        </div>
      </div>

      <aside class="page-section">
        <div class="page-section__inner space-y-3">
          <span class="text-[11px] uppercase tracking-[0.16em] text-horriver-gray/78">Radar do jogador</span>
          <h2 class="font-title text-2xl text-horriver-light">Fase atual</h2>
          <p class="text-sm leading-relaxed text-horriver-gray/84">
            Um resumo rapido da presenca, producao e impacto recente de <span class="text-horriver-light font-semibold"><%= player.name %></span>.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="<%= pillClass %>"><strong class="text-horriver-orange font-semibold"><%= totals.matches %></strong> jogos</span>
            <span class="<%= pillClass %>"><strong class="text-horriver-orange font-semibold"><%= totals.goals %></strong> gols</span>
            <span class="<%= pillClass %>"><strong class="text-horriver-orange font-semibold"><%= totals.assists %></strong> assist.</span>
          </div>
        </div>
      </aside>
    </div>

    <div class="quick-stats">
      <article class="quick-stat quick-stat--accent">
        <span class="quick-stat__label">Jogos</span>
        <strong class="quick-stat__value"><%= totals.matches %></strong>
        <span class="quick-stat__sub text-horriver-light/90">presencas registradas</span>
      </article>
      <article class="quick-stat">
        <span class="quick-stat__label">Gols</span>
        <strong class="quick-stat__value"><%= totals.goals %></strong>
        <span class="quick-stat__sub">bolas na rede</span>
      </article>
      <article class="quick-stat">
        <span class="quick-stat__label">Assistencias</span>
        <strong class="quick-stat__value"><%= totals.assists %></strong>
        <span class="quick-stat__sub">passes para gol</span>
      </article>
      <article class="quick-stat">
        <span class="quick-stat__label">Fotos</span>
        <strong class="quick-stat__value"><%= totals.photos %></strong>
        <span class="quick-stat__sub">registros em imagem</span>
      </article>
    </div>
  </header>

  <section class="page-section">
    <div class="page-section__inner page-section__inner--lg space-y-4">
      <div class="<%= sectionHeadingClass %>">
        <div>
          <h2 class="font-title text-2xl text-horriver-light">Conquistas</h2>
          <p class="<%= sectionMetaClass %>">Historico de desbloqueios e marcos do jogador.</p>
        </div>
        <span class="<%= pillClass %>"><strong class="text-horriver-orange font-semibold"><%= achievements.length %></strong> desbloqueadas</span>
      </div>

      <% if (!achievements.length) { %>
        <div class="<%= emptyStateClass %>">
          <span class="<%= emptyEyebrowClass %>">Sem conquista</span>
          <h3 class="mt-4 text-[1.05rem] font-bold text-horriver-light">Ainda nao ha badges liberadas</h3>
          <p class="mt-2 text-sm leading-relaxed text-horriver-gray/90">
            Assim que o jogador atingir os proximos marcos, as conquistas vao aparecer aqui.
          </p>
        </div>
      <% } else { %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <% achievements.forEach(pa => { %>
            <%- include('partials/achievementCard', { ach: {
                  title: pa.achievement.title || pa.achievement.name,
                  description: pa.achievement.description || '',
                  category: pa.achievement.category,
                  rarity: pa.achievement.rarity || 'prata',
                  targetValue: pa.achievement.targetValue,
                  unlockedAt: pa.unlockedAt
            } }) %>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>

  <div class="grid lg:grid-cols-2 gap-4">
    <section class="page-section">
      <div class="page-section__inner page-section__inner--lg space-y-4">
        <div class="<%= sectionHeadingClass %>">
          <div>
            <h2 class="font-title text-2xl text-horriver-light">Evolucao das notas</h2>
            <p class="<%= sectionMetaClass %>">Linha de desempenho com base nas notas registradas.</p>
          </div>
        </div>

        <% if (!ratingsSeries.length) { %>
          <div class="<%= emptyStateClass %>">
            <span class="<%= emptyEyebrowClass %>">Sem notas</span>
            <h3 class="mt-4 text-[1.05rem] font-bold text-horriver-light">Ainda nao existem avaliacoes suficientes</h3>
            <p class="mt-2 text-sm leading-relaxed text-horriver-gray/90">
              As notas das proximas peladas vao desenhar a curva de desempenho aqui.
            </p>
          </div>
        <% } else { %>
          <div class="<%= surfaceSoftClass %> p-4">
            <svg viewBox="0 0 100 40" class="w-full h-36 text-horriver-orange">
              <% const maxR = 10, minR = 0; const n = ratingsSeries.length; const step = n > 1 ? 100/(n-1) : 0; let path=''; ratingsSeries.forEach((p,i)=>{ const x = i*step; const y = 40 - ((p.rating - minR)/(maxR-minR))*40; path += (i===0? 'M':' L')+x+','+y; }); %>
              <path d="<%= path %>" fill="none" stroke="currentColor" stroke-width="1.8" />
            </svg>
          </div>
        <% } %>
      </div>
    </section>

    <section class="page-section">
      <div class="page-section__inner page-section__inner--lg space-y-4">
        <div class="<%= sectionHeadingClass %>">
          <div>
            <h2 class="font-title text-2xl text-horriver-light">Gols por mes</h2>
            <p class="<%= sectionMetaClass %>">Distribuicao de gols ao longo do tempo.</p>
          </div>
        </div>

        <% if (!goalsByMonth.length) { %>
          <div class="<%= emptyStateClass %>">
            <span class="<%= emptyEyebrowClass %>">Sem gols</span>
            <h3 class="mt-4 text-[1.05rem] font-bold text-horriver-light">Nenhum gol registrado ainda</h3>
            <p class="mt-2 text-sm leading-relaxed text-horriver-gray/90">
              Quando os gols entrarem na conta, o historico mensal aparece aqui automaticamente.
            </p>
          </div>
        <% } else { 
             const sortedGoals = [...goalsByMonth].sort((a, b) => new Date(a.label + "-01") - new Date(b.label + "-01"));
             const monthNames = ["jan", "fev", "mar", "abr", "mai", "jun", "jul", "ago", "set", "out", "nov", "dez"];
             const maxG = Math.max(...sortedGoals.map(g => g.value), 1);
        %>
          <div class="w-full overflow-x-auto <%= surfaceSoftClass %> p-4">
            <div class="flex items-end gap-3 h-48 min-w-[640px]">
            <% sortedGoals.forEach(g => { 
                 const [year, month] = g.label.split("-");
                 const monthIdx = Math.max(1, Math.min(12, parseInt(month, 10)));
                 const monthLabel = monthNames[monthIdx - 1] || month;
                 const maxBarPx = 160;
                 const barHeight = Math.max(8, Math.round((g.value / maxG) * maxBarPx));
            %>
              <div class="flex-1 flex flex-col items-center">
                <div class="flex flex-col items-center w-full">
                  <div class="w-full rounded-t-md bg-gradient-to-t from-horriver-red to-horriver-orange relative" style="height:<%= barHeight %>px">
                    <span class="absolute inset-0 bg-horriver-orange/30 rounded-t-md"></span>
                  </div>
                  <span class="text-[11px] text-horriver-light mt-1"><%= g.value %></span>
                  <span class="text-[10px] text-horriver-gray mt-1"><%= monthLabel %>/<%= year.slice(-2) %></span>
                </div>
              </div>
            <% }) %>
            </div>
          </div>
        <% } %>
      </div>
    </section>
  </div>

  <section class="page-section">
    <div class="page-section__inner page-section__inner--lg space-y-4">
      <div class="<%= sectionHeadingClass %>">
        <div>
          <h2 class="font-title text-2xl text-horriver-light">Partidas recentes</h2>
          <p class="<%= sectionMetaClass %>">Recorte das aparicoes mais novas do jogador.</p>
        </div>
      </div>

      <% if (!recentMatches.length) { %>
        <div class="<%= emptyStateClass %>">
          <span class="<%= emptyEyebrowClass %>">Sem partidas</span>
          <h3 class="mt-4 text-[1.05rem] font-bold text-horriver-light">Ainda nao ha historico recente</h3>
          <p class="mt-2 text-sm leading-relaxed text-horriver-gray/90">
            Conforme novas peladas forem registradas, os ultimos jogos aparecem aqui com gols, assistencias e nota.
          </p>
        </div>
      <% } else { %>
        <div class="space-y-3">
          <% recentMatches.forEach(m => { %>
            <div class="<%= surfaceSoftClass %> p-4 flex flex-col md:flex-row md:items-center md:justify-between gap-3 text-sm">
              <div class="space-y-1">
                <p class="text-horriver-light font-medium"><%= m.desc || 'Pelada' %></p>
                <p class="text-[11px] uppercase tracking-[0.14em] text-horriver-gray/72"><%= new Date(m.date).toLocaleDateString('pt-BR', { timeZone: 'America/Sao_Paulo' }) %></p>
              </div>
              <div class="flex flex-wrap gap-2 text-[11px] text-horriver-gray">
                <span class="<%= pillClass %>">G <strong class="text-horriver-orange font-semibold"><%= m.goals || 0 %></strong></span>
                <span class="<%= pillClass %>">A <strong class="text-horriver-orange font-semibold"><%= m.assists || 0 %></strong></span>
                <span class="<%= pillClass %>">Nota <strong class="text-horriver-orange font-semibold"><%= m.rating ?? '-' %></strong></span>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>
</section>

<script>
  (function () {
    const btn = document.getElementById("copyProfileLink");
    const status = document.getElementById("copyStatus");
    if (!btn || !navigator.clipboard) return;

    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        if (status) {
          status.classList.remove("hidden");
          status.textContent = "Copiado!";
          setTimeout(() => status.classList.add("hidden"), 2000);
        }
      } catch (err) {
        if (status) {
          status.classList.remove("hidden");
          status.textContent = "Erro ao copiar";
          setTimeout(() => status.classList.add("hidden"), 2000);
        }
      }
    });
  })();
</script>
