        content: attr(data-label);
        color: rgba(178, 184, 194, 0.82);
        font-size: 0.56rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        line-height: 1;
        text-transform: uppercase;
      }
    }
  </style>

  <!-- Cabeçalho da pelada -->
