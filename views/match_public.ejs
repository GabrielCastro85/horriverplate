                            Penaltis: <%= game.homePenalties %>-<%= game.awayPenalties %>
                          </span>
                        <% } %>
                      </div>
                    <% } %>
                  </div>
                <% }); %>
              </div>
            </div>
          <% }); %>

          <div class="export-footer export-only">@horriverplate</div>
        </div>
      </div>
    </section>
  <% } %>

