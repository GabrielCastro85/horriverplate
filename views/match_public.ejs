        margin-bottom: 16px;
      }
      body.is-exporting .tournament-export .export-title {
        font-size: 26px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      body.is-exporting .tournament-export .export-subtitle {
        font-size: 14px;
        color: rgba(148, 163, 184, 0.9);
        margin-top: 4px;
      }
