<%
  const fmtDate = (d) =>
    d ? new Date(d).toLocaleDateString("pt-BR", { timeZone: 'America/Sao_Paulo' }) : "-";

  const fmtRating = (val) => {
    if (val === null || val === undefined || Number.isNaN(val)) return "—";
    return Number(val).toFixed(2).replace(".", ",");
  };

  const safeStats = Array.isArray(stats) ? stats : [];
  const showRatings = typeof ratingsReleased !== "undefined"
    ? !!ratingsReleased
    : match && match.votingStatus === "CLOSED";
  const statsColspan = showRatings ? 8 : 7;
  const totalGoals = safeStats.reduce((sum, s) => sum + (Number(s.goals) || 0), 0);
  const totalAssists = safeStats.reduce((sum, s) => sum + (Number(s.assists) || 0), 0);
  const totalPhotos = safeStats.reduce((sum, s) => sum + (s.appearedInPhoto ? 1 : 0), 0);
  const playerName = (row) =>
    row && row.player
      ? `${row.player.name}${row.player.nickname ? ` (${row.player.nickname})` : ""}`
      : "-";
  const topScorer = [...safeStats].sort((a, b) =>
    (b.goals || 0) - (a.goals || 0) ||
    (b.assists || 0) - (a.assists || 0) ||
    playerName(a).localeCompare(playerName(b))
  )[0] || null;
  const topAssistant = [...safeStats].sort((a, b) =>
    (b.assists || 0) - (a.assists || 0) ||
    (b.goals || 0) - (a.goals || 0) ||
    playerName(a).localeCompare(playerName(b))
  )[0] || null;
  const topRated = showRatings
    ? ([...safeStats]
        .filter((s) => s.rating != null)
        .sort((a, b) =>
          Number(b.rating || 0) - Number(a.rating || 0) ||
          (b.goals || 0) - (a.goals || 0) ||
          (b.assists || 0) - (a.assists || 0)
        )[0] || null)
    : null;
  const votingOpen = !showRatings;
%>

<section class="space-y-6 animate-fadeIn">
  <style>
    .match-center-hero {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(148, 163, 184, 0.22);
      border-radius: 1.5rem;
      background:
        radial-gradient(circle at top left, rgba(255, 122, 26, 0.18), transparent 38%),
        radial-gradient(circle at bottom right, rgba(139, 19, 32, 0.22), transparent 42%),
        linear-gradient(135deg, rgba(9, 9, 13, 0.98), rgba(5, 5, 9, 0.92));
      box-shadow: 0 20px 48px rgba(0, 0, 0, 0.34);
    }
    .match-center-kicker {
      display: inline-flex;
      width: fit-content;
      border: 1px solid rgba(255, 122, 26, 0.28);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.35);
      padding: 0.35rem 0.7rem;
      color: #ffb685;
      font-size: 0.62rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    .match-summary-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
    }
    @media (min-width: 768px) {
      .match-summary-grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }
    }
    .match-summary-card {
      min-width: 0;
      border: 1px solid rgba(148, 163, 184, 0.18);
      border-radius: 1rem;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.016)),
        rgba(0, 0, 0, 0.28);
      padding: 0.85rem;
    }
    .match-summary-card span {
      display: block;
      color: rgba(178, 184, 194, 0.82);
      font-size: 0.62rem;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .match-summary-card strong {
      display: block;
      margin-top: 0.35rem;
      color: #fff7f2;
      font-size: 1.45rem;
      line-height: 1;
    }
    .match-summary-card small {
      display: block;
      margin-top: 0.35rem;
      color: rgba(245, 245, 245, 0.72);
      font-size: 0.72rem;
      line-height: 1.2;
      overflow-wrap: anywhere;
    }
    .match-vote-note {
      border: 1px solid rgba(255, 122, 26, 0.24);
      border-radius: 1rem;
      background: rgba(255, 122, 26, 0.08);
      padding: 0.8rem 0.95rem;
      color: rgba(245, 245, 245, 0.86);
      font-size: 0.78rem;
      line-height: 1.45;
    }
    @media (max-width: 640px) {
      .match-stats-table {
        min-width: 0 !important;
        display: block;
      }
      .match-stats-table thead {
        display: none;
      }
      .match-stats-table tbody {
        display: grid;
        gap: 0.65rem;
        padding: 0.75rem;
      }
      .match-stats-table tr {
        display: grid;
        grid-template-columns: 2rem minmax(0, 1fr) auto;
        gap: 0.55rem;
        border: 1px solid rgba(148, 163, 184, 0.16);
        border-radius: 1rem;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.016)),
          rgba(0, 0, 0, 0.28);
        padding: 0.75rem;
      }
      .match-stats-table td {
        position: static !important;
        padding: 0 !important;
        background: transparent !important;
        border: 0;
      }
      .match-stats-table td:nth-child(1) {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: 999px;
        background: rgba(255, 122, 26, 0.14) !important;
        color: #fff7f2;
        font-weight: 800;
      }
      .match-stats-table td:nth-child(2) {
        min-width: 0;
        white-space: normal;
      }
      .match-stats-table td:nth-child(3) {
        justify-self: end;
        align-self: start;
        border: 1px solid rgba(255, 122, 26, 0.28);
        border-radius: 999px;
        background: rgba(255, 122, 26, 0.08) !important;
        padding: 0.25rem 0.45rem !important;
        line-height: 1;
      }
      .match-stats-table td:nth-child(n+4) {
        display: inline-flex;
        min-height: 2.8rem;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.18rem;
        border-radius: 0.8rem;
        background: rgba(255, 255, 255, 0.045) !important;
        color: #f8fafc;
        font-weight: 800;
        text-align: center;
      }
