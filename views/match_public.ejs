<%
  const fmtDate = (d) =>
    d ? new Date(d).toLocaleDateString("pt-BR", { timeZone: 'America/Sao_Paulo' }) : "-";

  const fmtRating = (val) => {
    if (val === null || val === undefined || Number.isNaN(val)) return "—";
    return Number(val).toFixed(2).replace(".", ",");
  };

  const safeStats = Array.isArray(stats) ? stats : [];
  const showRatings = typeof ratingsReleased !== "undefined"
    ? !!ratingsReleased
    : match && match.votingStatus === "CLOSED";
  const hasSaves = safeStats.some((s) => s.saves != null);
  const statsColspan = (showRatings ? 8 : 7) + (hasSaves ? 1 : 0);
  const totalGoals = safeStats.reduce((sum, s) => sum + (Number(s.goals) || 0), 0);
  const totalAssists = safeStats.reduce((sum, s) => sum + (Number(s.assists) || 0), 0);
  const totalPhotos = safeStats.reduce((sum, s) => sum + (s.appearedInPhoto ? 1 : 0), 0);
  const playerName = (row) =>
    row && row.player
      ? `${row.player.name}${row.player.nickname ? ` (${row.player.nickname})` : ""}`
      : "-";
  const topScorer = [...safeStats].sort((a, b) =>
    (b.goals || 0) - (a.goals || 0) ||
    (b.assists || 0) - (a.assists || 0) ||
    playerName(a).localeCompare(playerName(b))
  )[0] || null;
  const topAssistant = [...safeStats].sort((a, b) =>
    (b.assists || 0) - (a.assists || 0) ||
    (b.goals || 0) - (a.goals || 0) ||
    playerName(a).localeCompare(playerName(b))
  )[0] || null;
  const topRated = showRatings
    ? ([...safeStats]
        .filter((s) => s.rating != null)
        .sort((a, b) =>
          Number(b.rating || 0) - Number(a.rating || 0) ||
          (b.goals || 0) - (a.goals || 0) ||
          (b.assists || 0) - (a.assists || 0)
        )[0] || null)
    : null;
  const votingOpen = !showRatings;
%>

<section class="space-y-6 animate-fadeIn">
