      <%
        var semiGames = gamesByStage['SEMI'] || [];
        var finalGames = gamesByStage['FINAL'] || [];
        var hasKnockout = semiGames.length > 0 || finalGames.length > 0;
      %>
      <% if (hasKnockout) { %>
      <%
        var fGame = finalGames.length > 0 ? finalGames[0] : null;
        var fHome = fGame ? teamById.get(fGame.homeTeamId) : null;
        var fAway = fGame ? teamById.get(fGame.awayTeamId) : null;
        var fHomeWin = fGame && fGame.winnerTeamId != null && fGame.winnerTeamId === fGame.homeTeamId;
        var fAwayWin = fGame && fGame.winnerTeamId != null && fGame.winnerTeamId === fGame.awayTeamId;
        var fHasScore = fGame && fGame.homeGoals != null && fGame.awayGoals != null;
        var champion = fGame && fGame.winnerTeamId ? teamById.get(fGame.winnerTeamId) : null;
        var connColor = 'rgba(255,122,26,0.32)';
      %>
      <div class="rounded-2xl border border-horriver-border/50 bg-black/25 p-4 overflow-x-auto">
        <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-horriver-gray/50 mb-4">Chave do Torneio</p>
        <table style="border-collapse:collapse;border-spacing:0;table-layout:fixed;">
          <tbody>
            <% if (semiGames.length >= 2) { %>
            <tr>
              <td style="vertical-align:top;padding-bottom:10px;width:260px;">
                <div class="trn-bracket-label">Semifinais</div>
                <% var g0 = semiGames[0]; var h0=teamById.get(g0.homeTeamId); var a0=teamById.get(g0.awayTeamId); var hw0=g0.winnerTeamId!=null&&g0.winnerTeamId===g0.homeTeamId; var aw0=g0.winnerTeamId!=null&&g0.winnerTeamId===g0.awayTeamId; var hs0=g0.homeGoals!=null&&g0.awayGoals!=null; %>
