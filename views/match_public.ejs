              <% } else { %>
                <% safeStats.forEach((s, idx) => { %>
                  <tr class="border-t border-horriver-red/30 hover:bg-white/5 transition-colors" data-name="<%= (s.player.name || '').toLowerCase() %>" data-position="<%= (s.player.position || '').toLowerCase() %>" data-present="<%= s.present ? 1 : 0 %>" data-goals="<%= s.goals || 0 %>" data-assists="<%= s.assists || 0 %>" data-saves="<%= s.saves != null ? s.saves : -1 %>" <%- showRatings ? `data-rating="${s.rating != null ? s.rating : 0}"` : "" %> data-photo="<%= s.appearedInPhoto ? 1 : 0 %>">

                    <!-- # -->
                    <td class="px-3 py-2 text-[11px] text-horriver-gray sticky left-0 z-10 bg-black/90" data-label="#"><%= idx + 1 %></td>

