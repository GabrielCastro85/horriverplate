  <section class="match-center-hero p-4 md:p-5 space-y-4">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
      <div>
        <span class="match-center-kicker">Resumo da pelada</span>
        <h2 class="mt-3 font-title text-2xl text-horriver-light">Match Center</h2>
      </div>
      <div class="flex flex-wrap gap-2">
        <span class="inline-flex rounded-full border border-horriver-border bg-black/35 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.12em] text-horriver-gray">
          <%= safeStats.length %> jogadores
        </span>
        <span class="inline-flex rounded-full border <%= votingOpen ? 'border-horriver-orange/50 bg-horriver-orange/10 text-horriver-orange' : 'border-emerald-400/30 bg-emerald-400/10 text-emerald-300' %> px-3 py-1 text-[10px] font-bold uppercase tracking-[0.12em]">
          <%= votingOpen ? "Votacao aberta" : "Votacao encerrada" %>
