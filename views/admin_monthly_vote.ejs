<%
  const fmtDateTimeBR = (d) =>
    d ? new Date(d).toLocaleString("pt-BR", { timeZone: "America/Sao_Paulo", hour12: false }) : "-";
  const monthlyVoteStatusClass = monthlyVoteClosed ? "status-danger" : "status-info";
  const monthlyVoteStatusLabel = monthlyVoteClosed ? "Votação encerrada" : "Votação ativa";
  const rankingRows = Array.isArray(monthlyVoteRanking) ? monthlyVoteRanking : [];
  const suggestedCandidateIds = new Set(
    rankingRows.filter((row) => row.eligible).slice(0, 6).map((row) => Number(row.id))
  );
%>

<section class="space-y-4">
  <header class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
    <div>
      <p class="text-xs text-horriver-gray uppercase tracking-[0.2em]">Painel</p>
      <h1 class="font-title text-2xl text-horriver-light">Votação do mês</h1>
      <p class="text-sm text-horriver-gray">Ranking do mês, candidatos editáveis e links para votar.</p>
    </div>
    <div class="flex w-full md:w-auto flex-col sm:flex-row sm:flex-wrap items-stretch sm:items-center gap-2">
      <% if (monthlyVoteSession) { %>
        <form action="/admin/monthly-vote/<%= monthlyVoteSession.id %>/close" method="POST" onsubmit="return confirm('Encerrar a votação do mês agora? Os links não vão mais funcionar.');">
          <button
            type="submit"
            class="w-full sm:w-auto inline-flex items-center justify-center px-4 py-2 rounded-full bg-red-600/80 text-white text-xs font-semibold hover:bg-red-500 transition"
          >
            Encerrar votação
          </button>
        </form>
      <% } %>
      <a
        href="/admin"
        class="w-full sm:w-auto inline-flex items-center justify-center px-4 py-2 rounded-full bg-horriver-dark border border-horriver-border text-horriver-light text-xs hover:border-horriver-orange transition"
      >
        Voltar ao painel
      </a>
    </div>
  </header>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="bg-black/40 border border-horriver-border rounded-2xl p-4 space-y-3">
      <h3 class="font-semibold text-lg text-horriver-light">Gerar votação</h3>
      <form action="/admin/monthly-vote-session" method="POST" class="space-y-3" data-toast="Votacao do mês gerada.">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          <label class="flex flex-col gap-1 text-sm text-horriver-gray">
            Mês
            <select name="month" id="monthlyVoteMonth" class="bg-horriver-dark border border-horriver-border rounded px-3 py-2 text-horriver-light">
              <% (monthNames || []).forEach((name, idx) => { const val = idx + 1; %>
                <option value="<%= val %>" <%= mvMonth === val ? "selected" : "" %>><%= name %></option>
              <% }) %>
            </select>
          </label>
          <label class="flex flex-col gap-1 text-sm text-horriver-gray">
            Ano
            <input
              type="number"
              name="year"
              id="monthlyVoteYear"
              value="<%= mvYear %>"
              class="bg-horriver-dark border border-horriver-border rounded px-3 py-2 text-horriver-light"
            />
          </label>
        </div>
        <% if (monthlyVoteError) { %>
          <p class="text-xs text-red-400">
            <% if (monthlyVoteError === 'noVoters') { %>
              Nenhum jogador presente no mês para votar.
            <% } else if (monthlyVoteError === 'noCandidates') { %>
              Nenhum candidato com pelo menos 2 peladas no mês.
            <% } else if (monthlyVoteError === 'tooManyCandidates') { %>
              Selecione no máximo 6 candidatos.
            <% } else { %>
              Erro ao gerar votação. Tente novamente.
            <% } %>
          </p>
        <% } %>
        <% if (monthlyVoteCreated) { %>
          <p class="text-xs text-emerald-400">Votação gerada com sucesso.</p>
        <% } %>
        <div class="flex flex-col sm:flex-row gap-2">
          <button
            type="button"
            id="openMonthlyCandidateModal"
            class="w-full px-4 py-2 rounded-full bg-horriver-orange text-black font-semibold hover:bg-orange-500 transition"
            <%= rankingRows.some((row) => row.eligible) ? "" : "disabled" %>
          >
            Revisar classificados
          </button>
          <button
            type="button"
            id="refreshMonthlyRanking"
            class="w-full sm:w-auto px-4 py-2 rounded-full bg-horriver-dark border border-horriver-border text-horriver-light text-xs hover:border-horriver-orange transition"
          >
            Ver ranking
          </button>
        </div>
        <div
          id="monthlyCandidateModal"
          class="fixed inset-0 z-[80] hidden items-center justify-center bg-black/80 p-4"
          role="dialog"
          aria-modal="true"
          aria-labelledby="monthlyCandidateModalTitle"
        >
          <div class="w-full max-w-4xl max-h-[86vh] overflow-hidden rounded-2xl border border-horriver-orange/45 bg-[#09090d] shadow-card-soft">
            <div class="flex items-start justify-between gap-4 border-b border-horriver-border/60 px-4 py-3">
              <div>
                <h4 id="monthlyCandidateModalTitle" class="text-lg font-semibold text-horriver-light">Revisar classificados</h4>
                <p class="text-[11px] text-horriver-gray">Os 6 sugeridos já vêm marcados. Desmarque e escolha outros elegíveis antes de liberar os links.</p>
              </div>
              <button type="button" id="closeMonthlyCandidateModal" class="rounded-full border border-horriver-border px-3 py-1 text-xs text-horriver-light hover:border-horriver-orange">
                Fechar
              </button>
            </div>
            <div class="max-h-[62vh] overflow-y-auto p-4">
              <% if (!rankingRows.length) { %>
                <p class="text-sm text-horriver-gray">Nenhum jogador com presença nesse mês.</p>
              <% } else { %>
                <div class="grid md:grid-cols-2 gap-3">
                  <% rankingRows.forEach((row) => {
                       const checked = suggestedCandidateIds.has(Number(row.id));
                  %>
                    <label class="flex gap-3 rounded-xl border <%= row.eligible ? 'border-horriver-border/60 bg-black/50' : 'border-horriver-border/30 bg-black/25 opacity-55' %> p-3 text-[11px]">
                      <input
                        type="checkbox"
                        name="candidateIds"
                        value="<%= row.id %>"
                        class="mt-1 h-4 w-4 accent-horriver-orange"
                        data-monthly-candidate-checkbox
                        <%= checked ? "checked" : "" %>
                        <%= row.eligible ? "" : "disabled" %>
                      />
                      <div class="min-w-0 flex-1">
                        <div class="flex items-start justify-between gap-2">
                          <div class="min-w-0">
                            <p class="text-horriver-light font-semibold truncate">#<%= row.rank %> <%= row.name %></p>
                            <% if (row.nickname) { %>
                              <p class="text-horriver-gray truncate">"<%= row.nickname %>"</p>
                            <% } %>
                          </div>
                          <span class="status-chip <%= row.eligible ? (checked ? 'status-ok' : 'status-info') : 'status-warning' %>">
                            <%= row.eligible ? (checked ? 'Sugerido' : 'Elegível') : 'Menos de 2 jogos' %>
                          </span>
                        </div>
                        <div class="mt-3 grid grid-cols-4 gap-2 text-center">
                          <span class="rounded-lg border border-horriver-border/40 bg-black/40 px-2 py-1">Score<br><strong class="text-horriver-orange"><%= row.score.toFixed ? row.score.toFixed(4) : row.score %></strong></span>
                          <span class="rounded-lg border border-horriver-border/40 bg-black/40 px-2 py-1">Nota<br><strong class="text-horriver-orange"><%= String(row.avgRating).replace('.', ',') %></strong></span>
                          <span class="rounded-lg border border-horriver-border/40 bg-black/40 px-2 py-1">Jogos<br><strong class="text-horriver-orange"><%= row.matches %></strong></span>
                          <span class="rounded-lg border border-horriver-border/40 bg-black/40 px-2 py-1">G/A<br><strong class="text-horriver-orange"><%= row.goals %>/<%= row.assists %></strong></span>
                        </div>
                      </div>
                    </label>
                  <% }) %>
                </div>
              <% } %>
            </div>
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 border-t border-horriver-border/60 px-4 py-3">
              <p id="monthlyCandidateCount" class="text-[11px] text-horriver-gray">0 selecionados</p>
              <button
                type="submit"
                id="submitMonthlyVoteSession"
                class="w-full sm:w-auto px-4 py-2 rounded-full bg-horriver-orange text-black font-semibold hover:bg-orange-500 transition"
              >
                Gerar links com selecionados
              </button>
            </div>
          </div>
        </div>
        <button
          type="submit"
          class="hidden"
          aria-hidden="true"
          tabindex="-1"
        >
          Gerar links
        </button>
      </form>
    </div>

    <div class="lg:col-span-2 bg-black/40 border border-horriver-border rounded-2xl p-4 space-y-3">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
        <h3 class="font-semibold text-lg text-horriver-light">Candidatos do mês</h3>
        <% if (monthlyVoteSession) { %>
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-[11px] text-horriver-gray">
              Sessao: <%= (monthlyVoteSession.month || mvMonth) %>/<%= (monthlyVoteSession.year || mvYear) %>
            </span>
            <span class="status-chip <%= monthlyVoteStatusClass %>"><%= monthlyVoteStatusLabel %></span>
          </div>
        <% } %>
      </div>

      <% if (!monthlyVoteSession || !monthlyVoteCandidates.length) { %>
        <p class="text-sm text-horriver-gray">Nenhuma sessao criada ainda.</p>
      <% } else { %>
        <div class="flex flex-wrap items-center justify-between gap-2">
          <p class="text-[11px] text-horriver-gray">Vencedor atual baseado nos votos.</p>
          <button
            type="button"
            id="exportMonthlyWinnerBtn"
            class="w-full sm:w-auto inline-flex items-center justify-center px-3 py-2 rounded-full bg-horriver-orange text-black text-[11px] font-semibold hover:bg-orange-500 transition disabled:opacity-60 disabled:cursor-not-allowed"
            <%= monthlyVoteWinner ? "" : "disabled" %>
          >
            Exportar card do vencedor
          </button>
        </div>
        <div class="rounded-xl border border-horriver-border/60 bg-black/50 p-3">
          <p class="text-[11px] text-horriver-gray mb-2">Parcial de votos</p>
          <div class="h-[220px]">
            <canvas id="monthlyVotesChart" aria-label="Grafico de votos" role="img"></canvas>
          </div>
        </div>
        <div class="grid sm:grid-cols-2 gap-3">
          <% monthlyVoteCandidates.forEach((c) => { %>
            <div class="rounded-xl border border-horriver-border/60 bg-black/50 p-3 text-[11px]">
              <div class="flex items-start gap-3">
                <img
                  src="<%= thumbUrl(c.photoUrl || '/img/logo-64x64.svg', 96) %>"
                  srcset="<%= thumbUrl(c.photoUrl || '/img/logo-64x64.svg', 96) %> 1x, <%= thumbUrl(c.photoUrl || '/img/logo-64x64.svg', 192) %> 2x"
                  sizes="56px"
                  alt="<%= c.name %>"
                  class="w-14 h-14 rounded-full object-cover border border-horriver-orange/60 bg-horriver-dark shrink-0"
                  width="56"
                  height="56"
                />

                <div class="min-w-0 flex-1">
                  <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                      <p class="text-horriver-light font-semibold truncate"><%= c.name %></p>
                      <% if (c.nickname) { %>
                        <p class="text-horriver-gray truncate">"<%= c.nickname %>"</p>
                      <% } %>
                    </div>
                    <div class="text-right shrink-0">
                      <p class="text-horriver-gray">Votos</p>
                      <p class="text-horriver-orange font-semibold text-sm"><%= (monthlyVoteCounts && monthlyVoteCounts[c.id]) || 0 %></p>
                    </div>
                  </div>

                  <div class="mt-3 grid grid-cols-2 gap-2">
                    <div class="rounded-lg border border-horriver-border/50 bg-black/40 px-2 py-2 text-center">
                      <p class="text-horriver-orange font-semibold"><%= c.matches %></p>
                      <p class="text-horriver-gray">Peladas</p>
                    </div>
                    <div class="rounded-lg border border-horriver-border/50 bg-black/40 px-2 py-2 text-center">
                      <p class="text-horriver-orange font-semibold"><%= c.goals ?? c.avgGoals %></p>
                      <p class="text-horriver-gray">Gols</p>
                    </div>
                    <div class="rounded-lg border border-horriver-border/50 bg-black/40 px-2 py-2 text-center">
                      <p class="text-horriver-orange font-semibold"><%= c.assists ?? c.avgAssists %></p>
                      <p class="text-horriver-gray">Assist.</p>
                    </div>
                    <div class="rounded-lg border border-horriver-border/50 bg-black/40 px-2 py-2 text-center">
                      <p class="text-horriver-orange font-semibold"><%= String(c.avgRating).replace('.', ',') %></p>
                      <p class="text-horriver-gray">Média</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

      <% if (monthlyVoteTokens && monthlyVoteTokens.length) { %>
        <div class="pt-2 border-t border-horriver-border/60">
          <h4 class="text-sm text-horriver-light font-semibold mb-2">Links de votação</h4>
          <div class="overflow-x-auto text-[11px] pb-1">
            <table class="min-w-[520px] border-collapse">
              <thead>
                <tr class="border-b border-horriver-border/60 text-horriver-gray/80">
                  <th class="py-2 pr-3 text-left font-normal">Jogador</th>
                  <th class="py-2 pr-3 text-left font-normal">Link</th>
                  <th class="py-2 pr-3 text-left font-normal">WhatsApp</th>
                  <th class="py-2 pr-3 text-left font-normal">Status</th>
                  <th class="py-2 pr-3 text-left font-normal">Votou</th>
                </tr>
              </thead>
              <tbody>
                  <% monthlyVoteTokens.forEach((t) => {
                       const link = `${voteBaseUrl}/monthly-vote/${t.token}`;
                       const waRaw = t.player?.whatsapp || "";
                       const waDigits = waRaw.replace(/\\D/g, "");
                       const msg = `Fala ${t.player?.name || "jogador"}! Seu link de votação para craque do mês: ${link}`;
                       const waUrl = waDigits ? `https://wa.me/${waDigits}?text=${encodeURIComponent(msg)}` : null;
                  %>
                    <tr class="border-b border-horriver-border/40 last:border-0">
                      <td class="py-2 pr-3 text-horriver-light"><%= t.player?.name || "Jogador" %></td>
                      <td class="py-2 pr-3">
                        <a href="<%= link %>" target="_blank" class="text-horriver-orange hover:underline break-all"><%= link %></a>
                      </td>
                      <td class="py-2 pr-3">
                        <% if (waUrl) { %>
                          <a
                            href="<%= waUrl %>"
                            target="_blank"
                            class="inline-flex items-center px-3 py-1 rounded-full bg-horriver-red text-white hover:bg-horriver-orange transition"
                          >
                            Mandar link
                          </a>
                        <% } else { %>
                          <span class="status-chip status-warning">Sem numero</span>
                        <% } %>
                      </td>
                      <td class="py-2 pr-3 whitespace-nowrap">
                        <span class="status-chip <%= t.usedAt ? 'status-ok' : 'status-pending' %>">
                          <%= t.usedAt ? "Usado" : "Pendente" %>
                        </span>
                      </td>
                      <td class="py-2 pr-3 whitespace-nowrap">
                        <span class="status-chip <%= t.usedAt ? 'status-ok' : 'status-pending' %>">
                          <%= t.usedAt ? "Sim" : "Não" %>
                        </span>
                      </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <section class="bg-black/40 border border-horriver-border rounded-2xl p-4 space-y-3">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
      <div>
        <h3 class="font-semibold text-lg text-horriver-light">Ranking de classificação</h3>
        <p class="text-[11px] text-horriver-gray">Score = média de gols x 0,3 + média de assistências x 0,2 + média de nota x 0,5.</p>
      </div>
      <span class="text-[11px] text-horriver-gray"><%= monthNames[mvMonth - 1] %> <%= mvYear %></span>
    </div>
    <% if (!rankingRows.length) { %>
      <p class="text-sm text-horriver-gray">Nenhum jogador com presença nesse mês.</p>
    <% } else { %>
      <div class="overflow-x-auto text-[11px]">
        <table class="min-w-[760px] w-full border-collapse">
          <thead>
            <tr class="border-b border-horriver-border/60 text-horriver-gray/80">
              <th class="py-2 pr-3 text-left font-normal">#</th>
              <th class="py-2 pr-3 text-left font-normal">Jogador</th>
              <th class="py-2 pr-3 text-left font-normal">Status</th>
              <th class="py-2 pr-3 text-right font-normal">Score</th>
              <th class="py-2 pr-3 text-right font-normal">Nota</th>
              <th class="py-2 pr-3 text-right font-normal">Jogos</th>
              <th class="py-2 pr-3 text-right font-normal">Gols</th>
              <th class="py-2 pr-3 text-right font-normal">Assist.</th>
              <th class="py-2 pr-3 text-right font-normal">Fotos</th>
            </tr>
          </thead>
          <tbody>
            <% rankingRows.forEach((row) => {
                 const isSuggested = suggestedCandidateIds.has(Number(row.id));
            %>
              <tr class="border-b border-horriver-border/40 last:border-0">
                <td class="py-2 pr-3 text-horriver-gray"><%= row.rank %></td>
                <td class="py-2 pr-3 text-horriver-light">
                  <%= row.name %>
                  <% if (row.nickname) { %><span class="text-horriver-gray">("<%= row.nickname %>")</span><% } %>
                </td>
                <td class="py-2 pr-3">
                  <span class="status-chip <%= row.eligible ? (isSuggested ? 'status-ok' : 'status-info') : 'status-warning' %>">
                    <%= row.eligible ? (isSuggested ? 'Top 6 automático' : 'Elegível') : 'Menos de 2 jogos' %>
                  </span>
                </td>
                <td class="py-2 pr-3 text-right text-horriver-orange font-semibold"><%= row.score.toFixed ? row.score.toFixed(4) : row.score %></td>
                <td class="py-2 pr-3 text-right text-horriver-light"><%= String(row.avgRating).replace('.', ',') %></td>
                <td class="py-2 pr-3 text-right text-horriver-light"><%= row.matches %></td>
                <td class="py-2 pr-3 text-right text-horriver-light"><%= row.goals %></td>
                <td class="py-2 pr-3 text-right text-horriver-light"><%= row.assists %></td>
                <td class="py-2 pr-3 text-right text-horriver-light"><%= row.photos %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>

  <% if (monthlyVoteSession) { %>
    <div class="bg-black/40 border border-horriver-border rounded-2xl p-4 space-y-3">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2">
        <h3 class="font-semibold text-lg text-horriver-light">Votos registrados</h3>
        <form action="/admin/monthly-vote/<%= monthlyVoteSession.id %>/delete" method="POST" onsubmit="return confirm('Excluir está votação e todos os votos?');">
          <button type="submit" class="w-full sm:w-auto px-4 py-2 rounded-full bg-red-600/80 text-white text-xs font-semibold hover:bg-red-500 transition">
            Excluir votação
          </button>
        </form>
      </div>

      <% if (!monthlyVoteBallots || !monthlyVoteBallots.length) { %>
        <p class="text-sm text-horriver-gray">Nenhum voto registrado ainda.</p>
      <% } else { %>
        <div class="overflow-x-auto text-[11px]">
          <table class="min-w-full border-collapse">
            <thead>
              <tr class="border-b border-horriver-border/60 text-horriver-gray/80">
                <th class="py-2 pr-3 text-left font-normal">Quem votou</th>
                <th class="py-2 pr-3 text-left font-normal">Votou em</th>
                <th class="py-2 pr-3 text-left font-normal">Quando</th>
              </tr>
            </thead>
            <tbody>
              <% monthlyVoteBallots.forEach((b) => { %>
                <tr class="border-b border-horriver-border/40 last:border-0">
                  <td class="py-2 pr-3 text-horriver-light"><%= b.token?.player?.name || "Jogador" %></td>
                  <td class="py-2 pr-3 text-horriver-light"><%= b.candidate?.name || "Jogador" %></td>
                  <td class="py-2 pr-3 text-horriver-gray"><%= fmtDateTimeBR(b.createdAt) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  <% } %>
</section>

<% if (monthlyVoteClosed) { %>
  <section class="mt-6 bg-black/40 border border-horriver-border rounded-2xl p-4 space-y-3">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
      <h3 class="font-semibold text-lg text-horriver-light">Vencedores registrados</h3>
      <span class="text-[11px] text-horriver-gray">Apos encerrar a votação</span>
    </div>
    <% if (!winnersHistory || !winnersHistory.length) { %>
      <p class="text-sm text-horriver-gray">Nenhum vencedor registrado ainda.</p>
    <% } else { %>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% winnersHistory.forEach((winner) => { %>
          <div class="rounded-xl border border-horriver-border/60 bg-black/50 p-3 text-[11px]">
            <p class="text-horriver-light font-semibold"><%= winner.name %></p>
            <p class="text-horriver-gray"><%= monthNames[winner.month - 1] %> <%= winner.year %></p>
            <p class="text-horriver-gray">Votos: <span class="text-horriver-orange font-semibold"><%= winner.votes %></span></p>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>
<% } %>

<script>
  (function () {
    const modal = document.getElementById("monthlyCandidateModal");
    const openBtn = document.getElementById("openMonthlyCandidateModal");
    const closeBtn = document.getElementById("closeMonthlyCandidateModal");
    const submitBtn = document.getElementById("submitMonthlyVoteSession");
    const countEl = document.getElementById("monthlyCandidateCount");
    const refreshBtn = document.getElementById("refreshMonthlyRanking");
    const monthInput = document.getElementById("monthlyVoteMonth");
    const yearInput = document.getElementById("monthlyVoteYear");
    const boxes = Array.from(document.querySelectorAll("[data-monthly-candidate-checkbox]"));
    const maxCandidates = 6;

    const updateCount = () => {
      const selected = boxes.filter((box) => box.checked).length;
      if (countEl) {
        countEl.textContent = `${selected} selecionado${selected === 1 ? "" : "s"} de ${maxCandidates}`;
        countEl.classList.toggle("text-red-400", selected < 1 || selected > maxCandidates);
        countEl.classList.toggle("text-horriver-gray", selected >= 1 && selected <= maxCandidates);
      }
      if (submitBtn) {
        submitBtn.disabled = selected < 1 || selected > maxCandidates;
        submitBtn.classList.toggle("opacity-60", submitBtn.disabled);
        submitBtn.classList.toggle("cursor-not-allowed", submitBtn.disabled);
      }
    };

    const openModal = () => {
      if (!modal) return;
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      updateCount();
    };

    const closeModal = () => {
      if (!modal) return;
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    };

    boxes.forEach((box) => {
      box.addEventListener("change", () => {
        const selected = boxes.filter((item) => item.checked);
        if (selected.length > maxCandidates) {
          box.checked = false;
          alert(`Selecione no máximo ${maxCandidates} candidatos.`);
        }
        updateCount();
      });
    });

    if (openBtn) openBtn.addEventListener("click", openModal);
    if (closeBtn) closeBtn.addEventListener("click", closeModal);
    if (modal) {
      modal.addEventListener("click", (event) => {
        if (event.target === modal) closeModal();
      });
    }
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeModal();
    });

    if (refreshBtn && monthInput && yearInput) {
      refreshBtn.addEventListener("click", () => {
        const month = monthInput.value || "<%= mvMonth %>";
        const year = yearInput.value || "<%= mvYear %>";
        window.location.href = `/admin/monthly-vote?mvMonth=${encodeURIComponent(month)}&mvYear=${encodeURIComponent(year)}`;
      });
    }

    updateCount();
  })();
</script>

<script>
  (function () {
    const btn = document.getElementById("exportMonthlyWinnerBtn");
    if (!btn) return;

    const sessionId = <%- monthlyVoteSession ? monthlyVoteSession.id : 'null' %>;
    const isMonthlyClosed = <%- monthlyVoteClosed ? 'true' : 'false' %>;

    btn.addEventListener("click", async () => {
      if (!isMonthlyClosed) {
        alert("Encerre a votação antes de exportar o card do vencedor. Clique em 'Encerrar votação' e tente novamente.");
        return;
      }
      if (!sessionId) return;

      const original = btn.textContent;
      btn.disabled = true;
      btn.textContent = "Gerando...";
      try {
        const res = await fetch(`/share/monthly-craque.jpg?sessionId=${sessionId}`);
        if (!res.ok) throw new Error(`Erro ${res.status}`);
        const blob = await res.blob();
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = `craque-do-mes-<%= mvMonth %>-<%= mvYear %>.jpg`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
      } catch (err) {
        console.error("[export] Falha:", err);
        alert("Não foi possível gerar a imagem. Tente novamente.");
      } finally {
        btn.textContent = original;
        btn.disabled = false;
      }
    });
  })();
</script>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
  (function () {
    const canvas = document.getElementById("monthlyVotesChart");
    if (!canvas || typeof Chart === "undefined") return;
    const data = <%- JSON.stringify({
      labels: (monthlyVoteCandidates || []).map((c) => c.name),
      values: (monthlyVoteCandidates || []).map((c) => (monthlyVoteCounts && monthlyVoteCounts[c.id]) || 0),
    }) %>;

    const colors = [
      "#ff6b6b",
      "#f4d35e",
      "#4ecdc4",
      "#5dade2",
      "#af7ac5",
      "#f39c12",
      "#2ecc71",
      "#e67e22",
      "#1abc9c",
      "#3498db",
      "#9b59b6",
      "#e74c3c",
    ];

    new Chart(canvas, {
      type: "pie",
      data: {
        labels: data.labels,
        datasets: [
          {
            data: data.values,
            backgroundColor: data.labels.map((_, i) => colors[i % colors.length]),
            borderColor: "rgba(15, 17, 21, 0.9)",
            borderWidth: 2,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: "bottom",
            labels: {
              color: "rgba(245,245,245,0.8)",
              boxWidth: 12,
              padding: 12,
              font: { size: 11 },
            },
          },
        },
      },
    });
  })();
</script>
