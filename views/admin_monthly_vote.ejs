</style>
<script>
  (function () {
    const btn = document.getElementById("exportMonthlyWinnerBtn");
    const root = document.getElementById("monthlyWinnerExportRoot");
    if (!btn || !root) return;

    const isMonthlyClosed = <%- monthlyVoteClosed ? 'true' : 'false' %>;

    const buildRoundedCanvas = (sourceCanvas, radius) => {
      const output = document.createElement("canvas");
      output.width = sourceCanvas.width;
      output.height = sourceCanvas.height;
      const ctx = output.getContext("2d");
      if (!ctx) return sourceCanvas;

      const width = output.width;
      const height = output.height;
      const r = Math.max(0, Math.min(radius, width / 2, height / 2));

      ctx.clearRect(0, 0, width, height);
      ctx.beginPath();
      ctx.moveTo(r, 0);
      ctx.lineTo(width - r, 0);
      ctx.quadraticCurveTo(width, 0, width, r);
      ctx.lineTo(width, height - r);
      ctx.quadraticCurveTo(width, height, width - r, height);
      ctx.lineTo(r, height);
      ctx.quadraticCurveTo(0, height, 0, height - r);
      ctx.lineTo(0, r);
      ctx.quadraticCurveTo(0, 0, r, 0);
      ctx.closePath();
      ctx.clip();
      ctx.drawImage(sourceCanvas, 0, 0);

      return output;
    };

    const downloadCanvas = (canvas, filename) =>
      new Promise((resolve, reject) => {
        if (!canvas.toBlob) {
          reject(new Error("Canvas export is not supported."));
          return;
        }

        canvas.toBlob((blob) => {
          if (!blob) {
            reject(new Error("Could not generate image blob."));
            return;
          }

          const url = URL.createObjectURL(blob);
          const link = document.createElement("a");
          link.download = filename;
          link.href = url;
          document.body.appendChild(link);
          link.click();
          link.remove();
          setTimeout(() => {
            URL.revokeObjectURL(url);
            resolve();
          }, 1000);
        }, "image/png");
      });

    const releaseCanvas = (canvas) => {
      if (!canvas) return;
      canvas.width = 0;
      canvas.height = 0;
    };

    btn.addEventListener("click", async () => {
      if (!isMonthlyClosed) {
        alert("Encerre a votacao antes de exportar o card do vencedor. Clique em 'Encerrar votacao' e tente novamente.");
        return;
      }
      btn.disabled = true;
      btn.textContent = "Gerando...";
      let canvas = null;
      let roundedCanvas = null;
      try {
        await (document.fonts?.ready || Promise.resolve());

        const imgs = Array.from(root.querySelectorAll("img"));
        await Promise.all(imgs.map((img) => {
          if (img.complete && img.naturalHeight !== 0) return Promise.resolve();
          return new Promise((resolve) => {
            img.addEventListener("load", resolve, { once: true });
            img.addEventListener("error", resolve, { once: true });
            setTimeout(resolve, 8000);
          });
        }));

        await new Promise((resolve) => requestAnimationFrame(() => requestAnimationFrame(resolve)));

        const SCALE = Math.min(2, window.devicePixelRatio || 1.5);
        const exportWidth = Math.ceil(root.offsetWidth || root.getBoundingClientRect().width || 900);
        const exportHeight = Math.ceil(root.scrollHeight || root.getBoundingClientRect().height || 520);
        canvas = await html2canvas(root, {
          scale: SCALE,
          backgroundColor: null,
          useCORS: true,
          allowTaint: false,
          logging: false,
          width: exportWidth,
          height: exportHeight,
          windowWidth: exportWidth,
          windowHeight: exportHeight,
          imageTimeout: 15000,
        });
        roundedCanvas = buildRoundedCanvas(canvas, 34 * SCALE);
        await downloadCanvas(roundedCanvas, `craque-do-mes-${<%= mvMonth %>}-${<%= mvYear %>}.png`);
      } catch (err) {
        console.error(err);
        alert("Nao foi possivel gerar a imagem.");
      } finally {
        releaseCanvas(roundedCanvas);
        releaseCanvas(canvas);
        btn.disabled = false;
        btn.textContent = "Exportar card do vencedor";
      }
    });
  })();
</script>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
  (function () {
    const canvas = document.getElementById("monthlyVotesChart");
    if (!canvas || typeof Chart === "undefined") return;
    const data = <%- JSON.stringify({
      labels: (monthlyVoteCandidates || []).map((c) => c.name),
      values: (monthlyVoteCandidates || []).map((c) => (monthlyVoteCounts && monthlyVoteCounts[c.id]) || 0),
    }) %>;

    const colors = [
      "#ff6b6b",
      "#f4d35e",
      "#4ecdc4",
      "#5dade2",
      "#af7ac5",
      "#f39c12",
      "#2ecc71",
      "#e67e22",
      "#1abc9c",
      "#3498db",
      "#9b59b6",
      "#e74c3c",
    ];

    new Chart(canvas, {
      type: "pie",
      data: {
        labels: data.labels,
        datasets: [
          {
            data: data.values,
            backgroundColor: data.labels.map((_, i) => colors[i % colors.length]),
            borderColor: "rgba(15, 17, 21, 0.9)",
            borderWidth: 2,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: "bottom",
            labels: {
              color: "rgba(245,245,245,0.8)",
              boxWidth: 12,
              padding: 12,
              font: { size: 11 },
            },
          },
        },
      },
    });
  })();
</script>
