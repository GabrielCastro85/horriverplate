<%
  const fmtDateTimeBR = (d) =>
    d ? new Date(d).toLocaleString("pt-BR", { timeZone: "UTC", hour12: false }) : "-";
  const monthlyVoteStatusClass = monthlyVoteClosed ? "status-danger" : "status-info";
  const monthlyVoteStatusLabel = monthlyVoteClosed ? "Votacao encerrada" : "Votacao ativa";
%>

<section class="space-y-4">
  <header class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
    <div>
      <p class="text-xs text-horriver-gray uppercase tracking-[0.2em]">Painel</p>
      <h1 class="font-title text-2xl text-horriver-light">Votacao do mes</h1>
      <p class="text-sm text-horriver-gray">Top 6 (minimo 2 peladas no mes) e links para votar.</p>
    </div>
    <div class="flex w-full md:w-auto flex-col sm:flex-row sm:flex-wrap items-stretch sm:items-center gap-2">
      <% if (monthlyVoteSession) { %>
        <form action="/admin/monthly-vote/<%= monthlyVoteSession.id %>/close" method="POST" onsubmit="return confirm('Encerrar a votacao do mes agora? Os links nao vao mais funcionar.');">
          <button
            type="submit"
            class="w-full sm:w-auto inline-flex items-center justify-center px-4 py-2 rounded-full bg-red-600/80 text-white text-xs font-semibold hover:bg-red-500 transition"
          >
            Encerrar votacao
          </button>
        </form>
      <% } %>
      <a
        href="/admin"
        class="w-full sm:w-auto inline-flex items-center justify-center px-4 py-2 rounded-full bg-horriver-dark border border-horriver-border text-horriver-light text-xs hover:border-horriver-orange transition"
      >
        Voltar ao painel
      </a>
    </div>
  </header>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="bg-black/40 border border-horriver-border rounded-2xl p-4 space-y-3">
      <h3 class="font-semibold text-lg text-horriver-light">Gerar votacao</h3>
      <form action="/admin/monthly-vote-session" method="POST" class="space-y-3" data-toast="Votacao do mes gerada.">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          <label class="flex flex-col gap-1 text-sm text-horriver-gray">
            Mes
            <select name="month" class="bg-horriver-dark border border-horriver-border rounded px-3 py-2 text-horriver-light">
              <% (monthNames || []).forEach((name, idx) => { const val = idx + 1; %>
                <option value="<%= val %>" <%= mvMonth === val ? "selected" : "" %>><%= name %></option>
              <% }) %>
            </select>
          </label>
          <label class="flex flex-col gap-1 text-sm text-horriver-gray">
            Ano
            <input
              type="number"
              name="year"
              value="<%= mvYear %>"
              class="bg-horriver-dark border border-horriver-border rounded px-3 py-2 text-horriver-light"
            />
          </label>
        </div>
        <% if (monthlyVoteError) { %>
          <p class="text-xs text-red-400">
            <% if (monthlyVoteError === 'noVoters') { %>
              Nenhum jogador presente no mes para votar.
            <% } else if (monthlyVoteError === 'noCandidates') { %>
              Nenhum candidato com pelo menos 2 peladas no mes.
            <% } else { %>
              Erro ao gerar votacao. Tente novamente.
            <% } %>
          </p>
        <% } %>
        <% if (monthlyVoteCreated) { %>
          <p class="text-xs text-emerald-400">Votacao gerada com sucesso.</p>
        <% } %>
        <button
          type="submit"
          class="w-full px-4 py-2 rounded-full bg-horriver-orange text-black font-semibold hover:bg-orange-500 transition"
        >
          Gerar links
        </button>
      </form>
    </div>

    <div class="lg:col-span-2 bg-black/40 border border-horriver-border rounded-2xl p-4 space-y-3">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
        <h3 class="font-semibold text-lg text-horriver-light">Candidatos do mes</h3>
        <% if (monthlyVoteSession) { %>
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-[11px] text-horriver-gray">
              Sessao: <%= (monthlyVoteSession.month || mvMonth) %>/<%= (monthlyVoteSession.year || mvYear) %>
            </span>
            <span class="status-chip <%= monthlyVoteStatusClass %>"><%= monthlyVoteStatusLabel %></span>
          </div>
        <% } %>
      </div>

      <% if (!monthlyVoteSession || !monthlyVoteCandidates.length) { %>
        <p class="text-sm text-horriver-gray">Nenhuma sessao criada ainda.</p>
      <% } else { %>
        <div class="flex flex-wrap items-center justify-between gap-2">
          <p class="text-[11px] text-horriver-gray">Vencedor atual baseado nos votos.</p>
          <button
            type="button"
            id="exportMonthlyWinnerBtn"
            class="w-full sm:w-auto inline-flex items-center justify-center px-3 py-2 rounded-full bg-horriver-orange text-black text-[11px] font-semibold hover:bg-orange-500 transition disabled:opacity-60 disabled:cursor-not-allowed"
            <%= monthlyVoteWinner ? "" : "disabled" %>
          >
            Exportar card do vencedor
          </button>
        </div>
        <div class="rounded-xl border border-horriver-border/60 bg-black/50 p-3">
          <p class="text-[11px] text-horriver-gray mb-2">Parcial de votos</p>
          <div class="h-[220px]">
            <canvas id="monthlyVotesChart" aria-label="Grafico de votos" role="img"></canvas>
          </div>
        </div>
        <div class="grid sm:grid-cols-2 gap-3">
          <% monthlyVoteCandidates.forEach((c) => { %>
            <div class="rounded-xl border border-horriver-border/60 bg-black/50 p-3 text-[11px]">
              <div class="flex items-start gap-3">
                <img
                  src="<%= thumbUrl(c.photoUrl || '/img/logo-64x64.svg', 96) %>"
                  srcset="<%= thumbUrl(c.photoUrl || '/img/logo-64x64.svg', 96) %> 1x, <%= thumbUrl(c.photoUrl || '/img/logo-64x64.svg', 192) %> 2x"
                  sizes="56px"
                  alt="<%= c.name %>"
                  class="w-14 h-14 rounded-full object-cover border border-horriver-orange/60 bg-horriver-dark shrink-0"
                  width="56"
                  height="56"
                />

                <div class="min-w-0 flex-1">
                  <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                      <p class="text-horriver-light font-semibold truncate"><%= c.name %></p>
                      <% if (c.nickname) { %>
                        <p class="text-horriver-gray truncate">"<%= c.nickname %>"</p>
                      <% } %>
                    </div>
                    <div class="text-right shrink-0">
                      <p class="text-horriver-gray">Votos</p>
                      <p class="text-horriver-orange font-semibold text-sm"><%= (monthlyVoteCounts && monthlyVoteCounts[c.id]) || 0 %></p>
                    </div>
                  </div>

                  <div class="mt-3 grid grid-cols-2 gap-2">
                    <div class="rounded-lg border border-horriver-border/50 bg-black/40 px-2 py-2 text-center">
                      <p class="text-horriver-orange font-semibold"><%= c.matches %></p>
                      <p class="text-horriver-gray">Peladas</p>
                    </div>
                    <div class="rounded-lg border border-horriver-border/50 bg-black/40 px-2 py-2 text-center">
                      <p class="text-horriver-orange font-semibold"><%= c.goals ?? c.avgGoals %></p>
                      <p class="text-horriver-gray">Gols</p>
                    </div>
                    <div class="rounded-lg border border-horriver-border/50 bg-black/40 px-2 py-2 text-center">
                      <p class="text-horriver-orange font-semibold"><%= c.assists ?? c.avgAssists %></p>
                      <p class="text-horriver-gray">Assist.</p>
                    </div>
                    <div class="rounded-lg border border-horriver-border/50 bg-black/40 px-2 py-2 text-center">
                      <p class="text-horriver-orange font-semibold"><%= String(c.avgRating).replace('.', ',') %></p>
                      <p class="text-horriver-gray">Media</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

      <% if (monthlyVoteTokens && monthlyVoteTokens.length) { %>
        <div class="pt-2 border-t border-horriver-border/60">
          <h4 class="text-sm text-horriver-light font-semibold mb-2">Links de votacao</h4>
          <div class="overflow-x-auto text-[11px] pb-1">
            <table class="min-w-[520px] border-collapse">
              <thead>
                <tr class="border-b border-horriver-border/60 text-horriver-gray/80">
                  <th class="py-2 pr-3 text-left font-normal">Jogador</th>
                  <th class="py-2 pr-3 text-left font-normal">Link</th>
                  <th class="py-2 pr-3 text-left font-normal">WhatsApp</th>
                  <th class="py-2 pr-3 text-left font-normal">Status</th>
                  <th class="py-2 pr-3 text-left font-normal">Votou</th>
                </tr>
              </thead>
              <tbody>
                  <% monthlyVoteTokens.forEach((t) => {
                       const link = `${voteBaseUrl}/monthly-vote/${t.token}`;
                       const waRaw = t.player?.whatsapp || "";
                       const waDigits = waRaw.replace(/\\D/g, "");
                       const msg = `Fala ${t.player?.name || "jogador"}! Seu link de votação para craque do mês: ${link}`;
                       const waUrl = waDigits ? `https://wa.me/${waDigits}?text=${encodeURIComponent(msg)}` : null;
                  %>
                    <tr class="border-b border-horriver-border/40 last:border-0">
                      <td class="py-2 pr-3 text-horriver-light"><%= t.player?.name || "Jogador" %></td>
                      <td class="py-2 pr-3">
                        <a href="<%= link %>" target="_blank" class="text-horriver-orange hover:underline break-all"><%= link %></a>
                      </td>
                      <td class="py-2 pr-3">
                        <% if (waUrl) { %>
                          <a
                            href="<%= waUrl %>"
                            target="_blank"
                            class="inline-flex items-center px-3 py-1 rounded-full bg-horriver-red text-white hover:bg-horriver-orange transition"
                          >
                            Mandar link
                          </a>
                        <% } else { %>
                          <span class="status-chip status-warning">Sem numero</span>
                        <% } %>
                      </td>
                      <td class="py-2 pr-3 whitespace-nowrap">
                        <span class="status-chip <%= t.usedAt ? 'status-ok' : 'status-pending' %>">
                          <%= t.usedAt ? "Usado" : "Pendente" %>
                        </span>
                      </td>
                      <td class="py-2 pr-3 whitespace-nowrap">
                        <span class="status-chip <%= t.usedAt ? 'status-ok' : 'status-pending' %>">
                          <%= t.usedAt ? "Sim" : "Nao" %>
                        </span>
                      </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <% if (monthlyVoteSession) { %>
    <div class="bg-black/40 border border-horriver-border rounded-2xl p-4 space-y-3">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2">
        <h3 class="font-semibold text-lg text-horriver-light">Votos registrados</h3>
        <form action="/admin/monthly-vote/<%= monthlyVoteSession.id %>/delete" method="POST" onsubmit="return confirm('Excluir esta votacao e todos os votos?');">
          <button type="submit" class="w-full sm:w-auto px-4 py-2 rounded-full bg-red-600/80 text-white text-xs font-semibold hover:bg-red-500 transition">
            Excluir votacao
          </button>
        </form>
      </div>

      <% if (!monthlyVoteBallots || !monthlyVoteBallots.length) { %>
        <p class="text-sm text-horriver-gray">Nenhum voto registrado ainda.</p>
      <% } else { %>
        <div class="overflow-x-auto text-[11px]">
          <table class="min-w-full border-collapse">
            <thead>
              <tr class="border-b border-horriver-border/60 text-horriver-gray/80">
                <th class="py-2 pr-3 text-left font-normal">Quem votou</th>
                <th class="py-2 pr-3 text-left font-normal">Votou em</th>
                <th class="py-2 pr-3 text-left font-normal">Quando</th>
              </tr>
            </thead>
            <tbody>
              <% monthlyVoteBallots.forEach((b) => { %>
                <tr class="border-b border-horriver-border/40 last:border-0">
                  <td class="py-2 pr-3 text-horriver-light"><%= b.token?.player?.name || "Jogador" %></td>
                  <td class="py-2 pr-3 text-horriver-light"><%= b.candidate?.name || "Jogador" %></td>
                  <td class="py-2 pr-3 text-horriver-gray"><%= fmtDateTimeBR(b.createdAt) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  <% } %>
</section>

<% if (monthlyVoteClosed) { %>
  <section class="mt-6 bg-black/40 border border-horriver-border rounded-2xl p-4 space-y-3">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
      <h3 class="font-semibold text-lg text-horriver-light">Vencedores registrados</h3>
      <span class="text-[11px] text-horriver-gray">Apos encerrar a votacao</span>
    </div>
    <% if (!winnersHistory || !winnersHistory.length) { %>
      <p class="text-sm text-horriver-gray">Nenhum vencedor registrado ainda.</p>
    <% } else { %>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% winnersHistory.forEach((winner) => { %>
          <div class="rounded-xl border border-horriver-border/60 bg-black/50 p-3 text-[11px]">
            <p class="text-horriver-light font-semibold"><%= winner.name %></p>
            <p class="text-horriver-gray"><%= monthNames[winner.month - 1] %> <%= winner.year %></p>
            <p class="text-horriver-gray">Votos: <span class="text-horriver-orange font-semibold"><%= winner.votes %></span></p>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>
<% } %>

<% if (monthlyVoteSession && monthlyVoteWinner) { %>
  <div class="fixed -left-[9999px] top-0 w-[1200px]" aria-hidden="true">
    <section id="monthlyWinnerExportRoot" class="monthly-export-card">
      <img src="/img/logo-32x32.svg" alt="" class="monthly-export-watermark" />

      <header class="monthly-export-header">
        <div class="monthly-export-brand">
          <div class="monthly-export-brand-row">
            <img src="/img/logo-32x32.svg" alt="Horriver Plate" class="monthly-export-brand-logo" />
            <span class="monthly-export-brand-name">Horriver Plate</span>
          </div>
          <h2 class="monthly-export-title">Craque do mes</h2>
        </div>
        <div class="monthly-export-meta">
          <span class="monthly-export-meta-line"></span>
          <p class="monthly-export-date"><%= monthNames[mvMonth - 1] %> / <%= mvYear %></p>
        </div>
      </header>

      <div class="monthly-export-divider"></div>

      <section class="monthly-export-hero">
        <div class="monthly-export-hero-main">
          <div class="monthly-export-avatar">
            <img
              src="<%= monthlyVoteWinner.photoUrl || '/img/logo-64x64.svg' %>"
              alt="<%= monthlyVoteWinner.name %>"
            />
          </div>
          <div class="monthly-export-info">
            <p class="monthly-export-kicker">Destaque do mes</p>
            <h3 class="monthly-export-name"><%= monthlyVoteWinner.name %></h3>
            <% if (monthlyVoteWinner.nickname) { %>
              <p class="monthly-export-nick">"<%= monthlyVoteWinner.nickname %>"</p>
            <% } %>
          </div>
        </div>
      </section>

      <div class="monthly-export-stats">
        <div class="monthly-export-stat">
          <span class="label">Peladas</span>
          <span class="value"><%= monthlyVoteWinner.matches ?? 0 %></span>
        </div>
        <div class="monthly-export-stat">
          <span class="label">Gols</span>
          <span class="value"><%= monthlyVoteWinner.goals ?? 0 %></span>
        </div>
        <div class="monthly-export-stat">
          <span class="label">Assist.</span>
          <span class="value"><%= monthlyVoteWinner.assists ?? 0 %></span>
        </div>
        <div class="monthly-export-stat">
          <span class="label">Fotos</span>
          <span class="value"><%= monthlyVoteWinner.photos ?? 0 %></span>
        </div>
        <div class="monthly-export-stat monthly-export-stat--wide">
          <span class="label">Media</span>
          <span class="value"><%= String(monthlyVoteWinner.avgRating || 0).replace('.', ',') %></span>
        </div>
      </div>

      <footer class="monthly-export-footer">
        <span>@_hpfrc</span>
        <span class="dot">&bull;</span>
        <span>horriverplate</span>
      </footer>
    </section>
  </div>
<% } %>

<style>
  .monthly-export-card {
    position: relative;
    overflow: hidden;
    width: 1200px;
    padding: 36px 38px 28px;
    border-radius: 34px;
    border: 1px solid rgba(255, 122, 26, 0.16);
    background:
      radial-gradient(circle at top left, rgba(118, 24, 50, 0.12) 0%, transparent 32%),
      radial-gradient(circle at top right, rgba(255, 122, 26, 0.04) 0%, transparent 18%),
      radial-gradient(circle at bottom right, rgba(24, 44, 82, 0.12) 0%, transparent 28%),
      linear-gradient(180deg, #2a0005 0%, #160208 34%, #050509 100%);
    color: #f3f4f6;
    font-family: "Manrope", system-ui, sans-serif;
    box-shadow: 0 24px 56px rgba(0, 0, 0, 0.28);
  }
  .monthly-export-watermark {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 560px;
    height: 560px;
    transform: translate(-50%, -44%);
    opacity: 0.025;
    filter: grayscale(1) brightness(0.96) blur(2px);
    pointer-events: none;
    user-select: none;
  }
  .monthly-export-header {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 36px;
  }
  .monthly-export-brand {
    display: flex;
    flex-direction: column;
    gap: 11px;
  }
  .monthly-export-brand-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .monthly-export-brand-logo {
    width: 28px;
    height: 28px;
    object-fit: contain;
    opacity: 0.8;
  }
  .monthly-export-brand-name {
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255, 179, 106, 0.9);
  }
  .monthly-export-kicker {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(226, 232, 240, 0.76);
  }
  .monthly-export-title {
    font-family: "Bebas Neue", "Oswald", sans-serif;
    font-size: 76px;
    font-weight: 400;
    line-height: 0.94;
    letter-spacing: 0.82px;
    color: #f8fafc;
  }
  .monthly-export-subtitle {
    display: none;
  }
  .monthly-export-meta {
    min-width: 260px;
    padding-top: 8px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
  }
  .monthly-export-meta-line {
    width: 92px;
    height: 1px;
    opacity: 0.66;
    background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.22) 100%);
  }
  .monthly-export-date {
    font-size: 39px;
    font-weight: 870;
    line-height: 0.98;
    letter-spacing: -0.038em;
    color: #f8fafc;
    text-align: right;
  }
  .monthly-export-meta-label {
    font-size: 12px;
    font-weight: 740;
    line-height: 1;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(226, 232, 240, 0.6);
    text-align: right;
  }
  .monthly-export-divider {
    position: relative;
    z-index: 1;
    height: 1px;
    margin: 34px 0 38px;
    opacity: 0.62;
    background: linear-gradient(90deg, rgba(34,197,94,0.50) 0%, rgba(250,204,21,0.52) 28%, rgba(239,68,68,0.48) 58%, rgba(59,130,246,0.50) 100%);
  }
  .monthly-export-hero {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    align-items: center;
    padding: 24px 26px;
    border-radius: 30px;
    border: 1px solid rgba(255, 122, 26, 0.22);
    background:
      linear-gradient(180deg, rgba(255,255,255,0.025), rgba(0,0,0,0.16)),
      rgba(0, 0, 0, 0.14);
  }
  .monthly-export-hero-main {
    display: grid;
    grid-template-columns: 124px 1fr;
    gap: 24px;
    align-items: center;
    justify-content: center;
    max-width: 760px;
    margin: 0 auto;
  }
  .monthly-export-avatar {
    width: 124px;
    height: 124px;
    border-radius: 28px;
    overflow: hidden;
    border: 1px solid rgba(255, 122, 26, 0.24);
    background: rgba(0, 0, 0, 0.28);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.22);
  }
  .monthly-export-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .monthly-export-info {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: center;
    text-align: center;
  }
  .monthly-export-name {
    margin: 0;
    font-family: "Bebas Neue", "Oswald", sans-serif;
    font-size: 68px;
    font-weight: 400;
    line-height: 0.92;
    letter-spacing: 0.7px;
    color: #f8fafc;
  }
  .monthly-export-nick {
    margin-top: 2px;
    font-size: 18px;
    font-weight: 600;
    line-height: 1.12;
    color: rgba(203, 213, 225, 0.56);
  }
  .monthly-export-copy {
    display: none;
  }
  .monthly-export-votes-box {
    display: none;
  }
  .monthly-export-votes-label {
    display: none;
  }
  .monthly-export-votes-value {
    display: none;
  }
  .monthly-export-stats {
    position: relative;
    z-index: 1;
    margin-top: 22px;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
  }
  .monthly-export-stat {
    border-radius: 22px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255,255,255,0.02), rgba(0,0,0,0.12)),
      rgba(0, 0, 0, 0.16);
    padding: 16px 12px;
    text-align: center;
  }
  .monthly-export-stat--wide {
    border-color: rgba(255, 122, 26, 0.18);
  }
  .monthly-export-stat .label {
    display: block;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(203, 213, 225, 0.68);
  }
  .monthly-export-stat .value {
    display: block;
    margin-top: 8px;
    font-size: 30px;
    font-weight: 700;
    color: #ff7a1a;
  }
  .monthly-export-footer {
